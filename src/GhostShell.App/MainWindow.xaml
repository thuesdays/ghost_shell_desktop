<Window x:Class="GhostShell.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
        xmlns:nav="clr-namespace:GhostShell.App.Navigation"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Ghost Shell"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="CenterScreen"
        Width="1280" Height="820"
        MinWidth="980" MinHeight="640"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        Background="{StaticResource BgBase}">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="32"
            ResizeBorderThickness="6"
            CornerRadius="0"
            UseAeroCaptionButtons="False"
            GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <!-- ────────────────────────────────────────────────────────────
         Sidebar row templates: section label vs clickable item.
         A DataTemplateSelector picks between them per row, which
         keeps the ItemsControl markup minimal and avoids putting
         routed events inside Style triggers (which WPF rejects).
         ──────────────────────────────────────────────────────────── -->
    <Window.Resources>
        <!-- Section header — non-interactive, just a label -->
        <DataTemplate x:Key="SidebarSectionTemplate">
            <TextBlock Text="{Binding Label}"
                       Foreground="{StaticResource TextDim}"
                       FontSize="9.5"
                       FontWeight="SemiBold"
                       Margin="14,16,12,4"/>
        </DataTemplate>

        <!-- Nav item — Button so Click "just works" inside templates -->
        <DataTemplate x:Key="SidebarItemTemplate">
            <Button Click="OnNavItemClicked"
                    Tag="{Binding PageKey}"
                    HorizontalContentAlignment="Stretch"
                    Cursor="Hand"
                    Margin="6,1"
                    Padding="10,7"
                    BorderThickness="0"
                    Background="Transparent">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgActive}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <!-- Per-page icon hue. The IconBrush comes from the
                         row VM (Overview blue, Profiles green, Runs
                         orange, etc.) so the sidebar reads as a colour
                         map at a glance — mirrors the legacy web's
                         hue palette. Saturation/value is consistent
                         across the set so no single icon dominates. -->
                    <TextBlock Text="{Binding Icon}"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="14"
                               Width="22"
                               Foreground="{Binding IconBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Label}"
                               Foreground="{StaticResource Text}"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="2,0,0,0"/>
                </StackPanel>
            </Button>
        </DataTemplate>

        <nav:SidebarRowTemplateSelector x:Key="SidebarRowSelector"
                                        SectionTemplate="{StaticResource SidebarSectionTemplate}"
                                        ItemTemplate="{StaticResource SidebarItemTemplate}"/>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderStrong}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ─── TITLE BAR ─── -->
            <Grid Grid.Row="0" Background="{StaticResource BgDeep}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                    <Border Width="18" Height="18" CornerRadius="3"
                            Background="{StaticResource Accent}">
                        <TextBlock Text="G" FontSize="11" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                               Foreground="{StaticResource Text}"
                               FontSize="12" FontWeight="SemiBold"
                               Text="Ghost Shell"/>
                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                               Foreground="{StaticResource TextDim}"
                               FontFamily="{StaticResource FontMono}"
                               FontSize="10.5"
                               Text="0.2.0-phase3"/>
                </StackPanel>

                <Border Grid.Column="1" Background="Transparent"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <!-- Glyphs come from Segoe MDL2 Assets (Win10 1809+
                         and Win11). Fluent-only codepoints like E949/E739
                         render as empty boxes on Win10. -->
                    <Button Style="{StaticResource ChromeButton}"
                            Click="OnMinimize" ToolTip="Minimize">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Text="&#xE921;"/>
                    </Button>
                    <Button Style="{StaticResource ChromeButton}"
                            Click="OnToggleMaximize"
                            ToolTip="Maximize / Restore">
                        <TextBlock x:Name="MaxIcon" FontFamily="Segoe MDL2 Assets"
                                   FontSize="10" Text="&#xE922;"/>
                    </Button>
                    <Button Style="{StaticResource ChromeButtonClose}"
                            Click="OnClose" ToolTip="Close">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Text="&#xE8BB;"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ─── BODY: sidebar + content ─── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="232"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── SIDEBAR ─── -->
                <Border Grid.Column="0" Background="{StaticResource BgSidebar}"
                        BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                    <DockPanel LastChildFill="True">
                        <!-- Footer (status indicator) -->
                        <Border DockPanel.Dock="Bottom" Padding="14,10"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="0,1,0,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource DimText}" Text="Status"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Ellipse Width="6" Height="6"
                                             Fill="{StaticResource OkBrush}"
                                             VerticalAlignment="Center"/>
                                    <TextBlock Margin="6,0,0,0"
                                               Foreground="{StaticResource Text}"
                                               FontSize="11"
                                               Text="Idle — 0 active runs"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Nav list -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding NavItems}"
                                          ItemTemplateSelector="{StaticResource SidebarRowSelector}"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- ─── CONTENT ─── -->
                <ContentControl Grid.Column="1" Content="{Binding Current}"
                                Background="{StaticResource BgBase}"/>
            </Grid>
        </Grid>
    </Border>

</Window>
