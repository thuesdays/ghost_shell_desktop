<Window x:Class="GhostShell.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
        xmlns:nav="clr-namespace:GhostShell.App.Navigation"
        xmlns:common="clr-namespace:GhostShell.App.Common"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Ghost Shell"
        Icon="Assets/AppIcon.ico"
        WindowStartupLocation="CenterScreen"
        Width="1280" Height="820"
        MinWidth="980" MinHeight="640"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        Background="{StaticResource BgBase}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        RenderOptions.ClearTypeHint="Enabled">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="32"
            ResizeBorderThickness="6"
            CornerRadius="0"
            UseAeroCaptionButtons="False"
            GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <!-- ────────────────────────────────────────────────────────────
         Sidebar row templates: section label vs clickable item.
         A DataTemplateSelector picks between them per row, which
         keeps the ItemsControl markup minimal and avoids putting
         routed events inside Style triggers (which WPF rejects).
         ──────────────────────────────────────────────────────────── -->
    <Window.Resources>
        <!-- Phase 71m — collapsed/expanded sidebar.
             The sidebar Border (named "SidebarBorder" below) animates
             between a 64-px icon-only rail and a 232-px full menu on
             hover. Section headers + item labels react to the Border's
             IsMouseOver state so they fade in only when the user is
             actively pointing at the sidebar. The Border overflows its
             64-px Grid column with Panel.ZIndex=10 so the content
             pane never shifts when the menu expands. -->

        <!-- Phase 71p — modern section template.
             • Collapsed sidebar: a thin horizontal divider line
               (no text) to keep the rail focused on icons while
               still grouping items visually.
             • Expanded sidebar: small all-uppercase-ish bold
               label tinted TextDim. The label sits inside the
               same fixed-height row so the underlying nav items
               keep their Y-coordinates whether the sidebar is
               collapsed or expanded — no vertical jump on hover. -->
        <DataTemplate x:Key="SidebarSectionTemplate">
            <Grid Height="22" Margin="0,10,0,2">
                <Border Height="1"
                        Background="{StaticResource Border}"
                        Opacity="0.45"
                        Margin="16,0,16,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding ElementName=SidebarBorder, Path=IsMouseOver,
                                             Converter={StaticResource InverseBoolToVis}}"/>
                <TextBlock Text="{Binding Label}"
                           Foreground="{StaticResource TextDim}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Margin="18,0,12,0"
                           VerticalAlignment="Center"
                           Visibility="{Binding ElementName=SidebarBorder, Path=IsMouseOver,
                                                Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </DataTemplate>

        <!-- Phase 71m — group row template. Same icon/label layout as
             a regular nav item, but instead of navigating on click it
             toggles a Popup flyout to the right showing the group's
             Children. The host Grid wires MouseEnter/Leave to
             OnGroupMouseEnter/Leave (code-behind), which manages a
             grace-timer so the user can shuffle the cursor across
             the gap between button and popup without losing it. -->
        <DataTemplate x:Key="SidebarGroupTemplate">
            <Grid x:Name="GroupHost"
                  MouseEnter="OnGroupMouseEnter"
                  MouseLeave="OnGroupMouseLeave"
                  Tag="{Binding}"
                  Background="Transparent">
                <Grid Margin="0,1" Height="36">
                    <!-- Phase 71p — group row mirrors the
                         SidebarItemTemplate's visual stack:
                         hover/active pill on the right, accent
                         bar on the left when popup is open. -->
                    <Border x:Name="GroupBd"
                            Background="Transparent"
                            CornerRadius="0,8,8,0"
                            Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ElementName=GroupHost, Path=IsMouseOver}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentSoft}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <Border Width="3"
                            HorizontalAlignment="Left"
                            Background="{StaticResource Accent}"
                            CornerRadius="0,2,2,0"
                            Margin="0,5">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Opacity" Value="0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                    <Grid Margin="0,0,8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Icon}"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="20"
                                   Foreground="{Binding IconBrush}"
                                   Opacity="1"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   UseLayoutRounding="True"
                                   SnapsToDevicePixels="True"
                                   TextOptions.TextRenderingMode="ClearType"
                                   TextOptions.TextFormattingMode="Ideal"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Label}"
                                   Foreground="{StaticResource Text}"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,0"
                                   TextTrimming="CharacterEllipsis"
                                   UseLayoutRounding="True"
                                   SnapsToDevicePixels="True"
                                   TextOptions.TextRenderingMode="ClearType"
                                   TextOptions.TextFormattingMode="Ideal"
                                   Visibility="{Binding ElementName=SidebarBorder, Path=IsMouseOver,
                                                        Converter={StaticResource BoolToVis}}"/>
                        <!-- Chevron rotates 90° when popup is open
                             so the user has a clear "expanded" cue
                             beyond the active accent bar. -->
                        <TextBlock Grid.Column="2"
                                   Text="&#xE76C;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="10"
                                   Foreground="{StaticResource TextDim}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   Visibility="{Binding ElementName=SidebarBorder, Path=IsMouseOver,
                                                        Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </Grid>
                <!-- Hover-flyout popup. StaysOpen=True keeps it on
                     screen while we juggle MouseEnter/Leave manually
                     in code-behind via the IsExpanded VM flag. -->
                <Popup IsOpen="{Binding IsExpanded, Mode=OneWay}"
                       PlacementTarget="{Binding ElementName=GroupHost}"
                       Placement="Right"
                       HorizontalOffset="2"
                       StaysOpen="True"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border Background="{StaticResource BgSidebar}"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="6"
                            MinWidth="180"
                            MouseEnter="OnGroupPopupMouseEnter"
                            MouseLeave="OnGroupPopupMouseLeave"
                            Tag="{Binding}">
                        <StackPanel>
                            <TextBlock Text="{Binding Label}"
                                       Foreground="{StaticResource TextDim}"
                                       FontSize="9.5"
                                       FontWeight="SemiBold"
                                       Margin="8,4,8,8"/>
                            <!-- Phase 71m fix — DynamicResource (not Static)
                                 because SidebarItemTemplate is declared
                                 BELOW SidebarGroupTemplate in this same
                                 ResourceDictionary, and StaticResource
                                 can't resolve forward references. The
                                 dynamic lookup happens at first popup
                                 render, by which time both templates
                                 are registered. -->
                            <ItemsControl ItemsSource="{Binding Children}"
                                          ItemTemplate="{DynamicResource SidebarItemTemplate}"/>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </DataTemplate>

        <!-- Phase 71p — modern nav-item template.
             Three visual states layered cleanly:
               1) Default: transparent background, icon at full hue,
                  label at primary text color.
               2) Hover: BgHover background fills the right-pill
                  shape (rounded only on the right so the active
                  bar can slot flush against the sidebar edge).
               3) Selected: AccentSoft tint background + 3 px
                  vertical accent bar at the left edge — the
                  signature "left rail" indicator used by Linear,
                  Vercel, Notion, Figma.
             36 px row height + 1 px vertical margin = consistent
             rhythm across collapsed/expanded states. -->
        <DataTemplate x:Key="SidebarItemTemplate">
            <Button Click="OnNavItemClicked"
                    Tag="{Binding PageKey}"
                    HorizontalContentAlignment="Stretch"
                    Cursor="Hand"
                    BorderThickness="0"
                    Background="Transparent"
                    Padding="0"
                    ToolTip="{Binding Label}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid Margin="0,1" Height="36">
                            <!-- Hover/active background pill.
                                 CornerRadius asymmetric: rounded on
                                 the right only so the vertical
                                 accent bar can sit flush with the
                                 sidebar's left edge without a gap. -->
                            <Border x:Name="Bd"
                                    Background="Transparent"
                                    CornerRadius="0,8,8,0"
                                    Margin="0,0,8,0"/>

                            <!-- Active accent bar (3 px wide, full
                                 row height). Hidden by default;
                                 fades in via DataTrigger when row
                                 IsSelected. CornerRadius on the
                                 right makes it look "pulled out"
                                 from the sidebar edge. -->
                            <Border x:Name="ActiveBar"
                                    Width="3"
                                    HorizontalAlignment="Left"
                                    Background="{StaticResource Accent}"
                                    CornerRadius="0,2,2,0"
                                    Margin="0,5"
                                    Opacity="0"/>

                            <Grid Margin="0,0,8,0">
                                <Grid.ColumnDefinitions>
                                    <!-- Fixed icon column = sidebar
                                         collapsed width minus right
                                         margin, so icons land dead-
                                         centre in the 64 px rail. -->
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           x:Name="IconText"
                                           Text="{Binding Icon}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="20"
                                           Foreground="{Binding IconBrush}"
                                           Opacity="1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           UseLayoutRounding="True"
                                           SnapsToDevicePixels="True"
                                           TextOptions.TextRenderingMode="ClearType"
                                           TextOptions.TextFormattingMode="Ideal"/>
                                <TextBlock Grid.Column="1"
                                           x:Name="LabelText"
                                           Text="{Binding Label}"
                                           Foreground="{StaticResource Text}"
                                           FontSize="14"
                                           FontWeight="Medium"
                                           VerticalAlignment="Center"
                                           Margin="0,0,0,0"
                                           TextTrimming="CharacterEllipsis"
                                           UseLayoutRounding="True"
                                           SnapsToDevicePixels="True"
                                           TextOptions.TextRenderingMode="ClearType"
                                           TextOptions.TextFormattingMode="Ideal"
                                           Visibility="{Binding ElementName=SidebarBorder, Path=IsMouseOver,
                                                                Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentSoft}"/>
                                <Setter TargetName="ActiveBar" Property="Opacity" Value="1"/>
                                <Setter TargetName="LabelText" Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>

        <nav:SidebarRowTemplateSelector x:Key="SidebarRowSelector"
                                        SectionTemplate="{StaticResource SidebarSectionTemplate}"
                                        ItemTemplate="{StaticResource SidebarItemTemplate}"
                                        GroupTemplate="{StaticResource SidebarGroupTemplate}"/>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderStrong}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ─── TITLE BAR ─── -->
            <Grid Grid.Row="0" Background="{StaticResource BgDeep}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                    <Border Width="18" Height="18" CornerRadius="3"
                            Background="{StaticResource Accent}">
                        <TextBlock Text="G" FontSize="11" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
                               Foreground="{StaticResource Text}"
                               FontSize="12" FontWeight="SemiBold"
                               Text="Ghost Shell"/>
                    <!-- Version stamped from Assembly.GetName().Version
                         (sourced from VERSION file via Directory.Build.props).
                         Set on the window at construction time so this
                         binding picks it up without a separate VM. -->
                    <TextBlock x:Name="VersionLabel"
                               Margin="10,0,0,0" VerticalAlignment="Center"
                               Foreground="{StaticResource TextDim}"
                               FontFamily="{StaticResource FontMono}"
                               FontSize="10.5"/>
                    <!-- Phase 71v — Back chip. Visible ONLY when the
                         user reached the current page via an in-page
                         deep link (Overview tile, "View all runs",
                         etc.) — i.e. when the navigation back-stack
                         is non-empty. Sidebar/footer clicks reset
                         the stack so this chip stays hidden during
                         normal section-to-section browsing.
                         IsHitTestVisibleInChrome=True so the click
                         isn't eaten by the WindowChrome drag region. -->
                    <Button Margin="14,0,0,0"
                            Padding="10,4"
                            Cursor="Hand"
                            Command="{Binding GoBackCommand}"
                            ToolTip="{Binding BackTooltip}"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Background" Value="{StaticResource AccentSoft}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                                       Text="&#xE72B;"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                            <TextBlock Text="Back" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Border Grid.Column="1" Background="Transparent"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <!-- Phase 29 — notification bell with severity-tinted
                         badge. The badge collapses when ActiveCount=0
                         so plain-state windows aren't littered with
                         empty pills. Click toggles the slide-out
                         drawer below. -->
                    <Button Style="{StaticResource ChromeButton}"
                            Command="{Binding Notifications.OpenDrawerCommand}"
                            ToolTip="Notifications"
                            Padding="12,0">
                        <Grid>
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Text="&#xEA8F;"/>
                            <Border CornerRadius="8" MinWidth="14" Height="14"
                                    Padding="3,0"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,-3,-6,0"
                                    Visibility="{Binding Notifications.HasActive, Converter={StaticResource BoolToVis}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource Accent}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Notifications.BadgeSeverity}" Value="critical">
                                                <Setter Property="Background" Value="{StaticResource ErrBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Notifications.BadgeSeverity}" Value="warning">
                                                <Setter Property="Background" Value="{StaticResource WarnBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Notifications.BadgeSeverity}" Value="success">
                                                <Setter Property="Background" Value="{StaticResource OkBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Notifications.BadgeText}"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Button>
                    <!-- Glyphs come from Segoe MDL2 Assets (Win10 1809+
                         and Win11). Fluent-only codepoints like E949/E739
                         render as empty boxes on Win10. -->
                    <Button Style="{StaticResource ChromeButton}"
                            Click="OnMinimize" ToolTip="Minimize">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Text="&#xE921;"/>
                    </Button>
                    <Button Style="{StaticResource ChromeButton}"
                            Click="OnToggleMaximize"
                            ToolTip="Maximize / Restore">
                        <TextBlock x:Name="MaxIcon" FontFamily="Segoe MDL2 Assets"
                                   FontSize="10" Text="&#xE922;"/>
                    </Button>
                    <Button Style="{StaticResource ChromeButtonClose}"
                            Click="OnClose" ToolTip="Close">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Text="&#xE8BB;"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ─── BODY: sidebar + content ─── -->
            <!-- Phase 71s — body Grid carries a soft BlurEffect when
                 the active page is busy hydrating data. The blur is
                 hardware-accelerated (BlurEffect renders on the GPU
                 via D3D), so it stays smooth even while the page's
                 background work threads churn. The LoadingOverlay
                 below sits as a sibling at Grid.Row="1" so the dim
                 backdrop + spinner card render crisply ON TOP of the
                 blurred content (and over the sidebar). -->
            <Grid Grid.Row="1">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <BlurEffect Radius="8"
                                                    KernelType="Gaussian"
                                                    RenderingBias="Performance"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <!-- Phase 71m fix — column is Auto so it tracks
                         the SidebarBorder's animated Width. Content in
                         column 1 (*) reflows smoothly as the sidebar
                         expands/collapses. The earlier `Width="64"`
                         clamped Border.Width to the cell width during
                         layout, which is why the storyboard "appeared
                         to do nothing" — labels still rendered (because
                         their Visibility binding still flipped) but
                         everything was crushed into the 64-px rail. -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── SIDEBAR ─── -->
                <Border x:Name="SidebarBorder"
                        Grid.Column="0"
                        Background="{StaticResource BgSidebar}"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="0,0,1,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <!-- Default = collapsed (icons only). -->
                            <Setter Property="Width" Value="64"/>
                            <Style.Triggers>
                                <!-- Phase 71m — animate Width on
                                     IsMouseOver. EnterActions runs the
                                     forward storyboard, ExitActions
                                     reverses it. 180 ms feels snappy
                                     without flickering on quick
                                     pointer-cross-overs. -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Width"
                                                                 To="240"
                                                                 Duration="0:0:0.20">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Width"
                                                                 To="64"
                                                                 Duration="0:0:0.18">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseIn"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <DockPanel LastChildFill="True">
                        <!-- Phase 71p — minimal status footer.
                             • Collapsed: just a centred green pulse dot
                               (with ToolTip for context) — keeps the
                               rail clean and uniform width.
                             • Expanded: dot + readable status text on
                               the left, no "Status" label (the live
                               dot makes it obvious). -->
                        <!-- Phase 71r — fixed-height Status footer.
                             Bug fix: previously the inner Grid sized
                             to its currently-visible child (8 px when
                             collapsed → just the Ellipse; ~16 px when
                             expanded → Ellipse + TextBlock). That 8-px
                             swing propagated up the DockPanel so the
                             FooterItems (Settings) jumped during the
                             sidebar Width animation. Pinning the Grid
                             to Height=20 keeps the footer's vertical
                             footprint constant in both states. -->
                        <Border DockPanel.Dock="Bottom"
                                Padding="0,10,0,12"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="0,1,0,0">
                            <Grid Height="20">
                                <Ellipse Width="8" Height="8"
                                         Fill="{StaticResource OkBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         ToolTip="Idle — 0 active runs"
                                         Visibility="{Binding ElementName=SidebarBorder, Path=IsMouseOver,
                                                              Converter={StaticResource InverseBoolToVis}}"/>
                                <StackPanel Orientation="Horizontal"
                                            Margin="20,0,0,0"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding ElementName=SidebarBorder, Path=IsMouseOver,
                                                                 Converter={StaticResource BoolToVis}}">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{StaticResource OkBrush}"
                                             VerticalAlignment="Center"/>
                                    <TextBlock Margin="10,0,0,0"
                                               Foreground="{StaticResource Text}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Text="Idle — 0 active runs"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Phase 71q — Settings (and any future bottom-
                             pinned utility items) lives in FooterItems
                             docked just ABOVE the Status footer. Same
                             template selector as the main nav, so it
                             gets the active accent bar / hover pill
                             treatment for free. -->
                        <ItemsControl DockPanel.Dock="Bottom"
                                      Margin="0,0,0,6"
                                      ItemsSource="{Binding FooterItems}"
                                      ItemTemplateSelector="{StaticResource SidebarRowSelector}"/>

                        <!-- Phase 71o — main nav list. ScrollBarVisibility=Auto
                             would still show a thin scroll lane while
                             measuring; the compressed item heights now
                             fit the full menu in any reasonable window
                             height (~640 px min). Disabled = no rail
                             at all. -->
                        <ScrollViewer VerticalScrollBarVisibility="Disabled"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding NavItems}"
                                          ItemTemplateSelector="{StaticResource SidebarRowSelector}"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- ─── CONTENT ─── -->
                <ContentControl Grid.Column="1" Content="{Binding Current}"
                                Background="{StaticResource BgBase}"/>
            </Grid>

            <!-- ─── Phase 29 — Notifications drawer overlay ───
                 Spans the body row only (Grid.Row=1) so the title bar
                 stays accessible. Backdrop = semi-transparent click-
                 to-close; the panel slides in from the right edge. -->
            <Grid Grid.Row="1"
                  Visibility="{Binding Notifications.IsDrawerOpen, Converter={StaticResource BoolToVis}}">
                <!-- Backdrop. Click anywhere outside the panel to dismiss. -->
                <Rectangle Fill="#80000000">
                    <Rectangle.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding Notifications.CloseDrawerCommand}"/>
                    </Rectangle.InputBindings>
                </Rectangle>

                <!-- Panel — fixed 380 px wide on the right edge -->
                <Border HorizontalAlignment="Right"
                        Width="380"
                        Background="{StaticResource BgBase}"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Drawer header -->
                        <Border Grid.Row="0" Padding="16,14"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🔔  Notifications"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource Text}"/>
                                    <TextBlock Foreground="{StaticResource TextMuted}"
                                               FontSize="11" Margin="0,2,0,0">
                                        <Run Text="{Binding Notifications.ActiveCount, Mode=OneWay}"/>
                                        <Run Text=" active"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="↻"
                                            Command="{Binding Notifications.RefreshCommand}"
                                            Padding="8,4" Margin="0,0,4,0"
                                            ToolTip="Refresh"/>
                                    <Button Content="✓ all"
                                            Command="{Binding Notifications.DismissAllCommand}"
                                            Padding="8,4" Margin="0,0,4,0"
                                            ToolTip="Dismiss all"/>
                                    <Button Content="✕"
                                            Command="{Binding Notifications.CloseDrawerCommand}"
                                            Padding="8,4"
                                            ToolTip="Close"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- List -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Notifications.Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="14,12"
                                                BorderBrush="{StaticResource Border}"
                                                BorderThickness="0,0,0,1"
                                                Background="Transparent">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.Notifications.ActivateCommand,
                                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Severity dot -->
                                                <Ellipse Grid.Column="0"
                                                         Width="8" Height="8"
                                                         VerticalAlignment="Top"
                                                         Margin="0,6,10,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="{StaticResource Accent}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Severity}" Value="critical">
                                                                    <Setter Property="Fill" Value="{StaticResource ErrBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Severity}" Value="warning">
                                                                    <Setter Property="Fill" Value="{StaticResource WarnBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Severity}" Value="success">
                                                                    <Setter Property="Fill" Value="{StaticResource OkBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{StaticResource Text}"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding Body}"
                                                               Style="{StaticResource MutedText}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0"/>
                                                    <TextBlock Foreground="{StaticResource TextDim}"
                                                               FontSize="9.5"
                                                               FontFamily="{StaticResource FontMono}"
                                                               Margin="0,4,0,0"
                                                               Text="{Binding CreatedAt, StringFormat='yyyy-MM-dd HH:mm'}"/>
                                                </StackPanel>

                                                <!-- Dismiss button — click handled inline so the
                                                     parent Border's MouseBinding (Activate) doesn't
                                                     also fire on the same press, which would both
                                                     dismiss AND navigate. -->
                                                <Button Grid.Column="2"
                                                        Content="✕"
                                                        Padding="6,2"
                                                        Click="OnNotificationDismissClicked"
                                                        CommandParameter="{Binding}"
                                                        Command="{Binding DataContext.Notifications.DismissCommand,
                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                        ToolTip="Dismiss"
                                                        VerticalAlignment="Top"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Empty state -->
                        <Border Grid.Row="1" Padding="40"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding Notifications.HasActive, Converter={StaticResource InverseBoolToVis}}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="🌿" FontSize="40"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextDim}"/>
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource MutedText}"
                                           HorizontalAlignment="Center"
                                           Text="All clear."/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ─── Phase 71s — window-level loading overlay ───
                 Drawn on top of EVERYTHING in the body row (sidebar +
                 content + drawer) so the dim+spinner card sits clean
                 above the GaussianBlur. Spans only Grid.Row="1" so
                 the title bar buttons (min/max/close) stay clickable
                 even while a page is hydrating. -->
            <common:LoadingOverlay Grid.Row="1"
                                   IsActive="{Binding IsBusy}"
                                   Caption="Loading data…"/>
        </Grid>
    </Border>

</Window>
