  Phase 34 — Domains page. Three-list editor for my domains, target domains,
  and domains to block. Live counts + debounced autosave with status flash.
-->
<UserControl x:Class="GhostShell.App.Views.DomainsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:DomainsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BgBase}">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="Auto"/>  <!-- info banner -->
            <RowDefinition Height="*"/>     <!-- content -->
        </Grid.RowDefinitions>

        <!-- ─── Header ─── -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Style="{StaticResource PageTitle}"
                       Text="Domains"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
            <Border Grid.Row="1" Style="{StaticResource Card}"
                    Padding="14,10" Margin="0,12,0,0">
                <TextBlock Style="{StaticResource PageSubtitle}"
                           TextWrapping="Wrap"
                           Text="Your own properties, target domains, and domains to ignore."/>
            </Border>
        </Grid>

        <!-- ─── Info Banner ─── -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14,10" Margin="0,0,0,8"
                Background="{StaticResource BgRaised}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="💡" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Style="{StaticResource MutedText}"
                           TextWrapping="Wrap"
                           Text="Search terms have moved to Scripts. Configure them inside a `loop` step."/>
            </StackPanel>
        </Border>

        <!-- ─── Three Columns ─── -->
        <!-- Switched from WrapPanel(Width=360 each) to a 3-column Grid
             with equal `*` widths so all three cards always sit on
             one row, shrinking proportionally with the window. The
             outer ScrollViewer kicks in only when the cards get
             narrower than usable (very small window). -->
        <Grid Grid.Row="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- My Domains Column -->
                    <Border Grid.Column="0" Margin="0,0,8,0"
                            Background="{StaticResource BgRaised}"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14,12">
                        <StackPanel>
                            <!-- Title -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="🏠  " FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="My domains" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource Text}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Help text -->
                            <TextBlock Style="{StaticResource MutedText}"
                                       TextWrapping="Wrap" Margin="0,0,0,12"
                                       FontSize="11"
                                       Text="Domains you own. Click-ad steps will skip these to preserve your ad budget."/>

                            <!-- TextBox -->
                            <TextBox Text="{Binding MyDomainsText, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas,Courier New,monospace"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="240"
                                     Margin="0,0,0,10"
                                     Padding="8,6"/>

                            <!-- Footer -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Style="{StaticResource MutedText}" FontSize="10"
                                           Text="{Binding MyCount, StringFormat='{}{0} domains'}"/>
                                <TextBlock Grid.Column="1"
                                           Style="{StaticResource MutedText}" FontSize="10"
                                           Text="Autosaved"
                                           Visibility="{Binding IsSaving, Converter={StaticResource InverseBoolToVis}}"/>
                                <TextBlock Grid.Column="1"
                                           Style="{StaticResource MutedText}" FontSize="10"
                                           Text="Saving..."
                                           Visibility="{Binding IsSaving, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Target Domains Column -->
                    <Border Grid.Column="1" Margin="4,0,4,0"
                            Background="{StaticResource BgRaised}"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14,12">
                        <StackPanel>
                            <!-- Title -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="🎯  " FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Target domains" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource Text}" VerticalAlignment="Center"/>
                                <Border Padding="6,2" Margin="8,0,0,0" CornerRadius="3"
                                        Background="{StaticResource BgDeep}">
                                    <TextBlock Text="optional" FontSize="9" Foreground="{StaticResource TextDim}"/>
                                </Border>
                            </StackPanel>

                            <!-- Help text -->
                            <TextBlock Style="{StaticResource MutedText}"
                                       TextWrapping="Wrap" Margin="0,0,0,12"
                                       FontSize="11"
                                       Text="Competitor domains to prioritize. Steps targeting these domains get longer dwell time and boosted click probability."/>

                            <!-- TextBox -->
                            <TextBox Text="{Binding TargetDomainsText, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas,Courier New,monospace"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="240"
                                     Margin="0,0,0,10"
                                     Padding="8,6"/>

                            <!-- Footer -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Style="{StaticResource MutedText}" FontSize="10"
                                           Text="{Binding TargetCount, StringFormat='{}{0} domains'}"/>
                                <TextBlock Grid.Column="1"
                                           Style="{StaticResource MutedText}" FontSize="10"
                                           Text="Autosaved"
                                           Visibility="{Binding IsSaving, Converter={StaticResource InverseBoolToVis}}"/>
                                <TextBlock Grid.Column="1"
                                           Style="{StaticResource MutedText}" FontSize="10"
                                           Text="Saving..."
                                           Visibility="{Binding IsSaving, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Block List Column -->
                    <Border Grid.Column="2" Margin="8,0,0,0"
                            Background="{StaticResource BgRaised}"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14,12">
                        <StackPanel>
                            <!-- Title -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="🚫  " FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Block list" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource Text}" VerticalAlignment="Center"/>
                                <Border Padding="6,2" Margin="8,0,0,0" CornerRadius="3"
                                        Background="{StaticResource BgDeep}">
                                    <TextBlock Text="optional" FontSize="9" Foreground="{StaticResource TextDim}"/>
                                </Border>
                            </StackPanel>

                            <!-- Help text -->
                            <TextBlock Style="{StaticResource MutedText}"
                                       TextWrapping="Wrap" Margin="0,0,0,12"
                                       FontSize="11"
                                       Text="Domains to ignore entirely. These are excluded from competitor reports and never targeted by steps."/>

                            <!-- TextBox -->
                            <TextBox Text="{Binding BlockDomainsText, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas,Courier New,monospace"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="240"
                                     Margin="0,0,0,10"
                                     Padding="8,6"/>

                            <!-- Footer -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Style="{StaticResource MutedText}" FontSize="10"
                                           Text="{Binding BlockCount, StringFormat='{}{0} domains'}"/>
                                <TextBlock Grid.Column="1"
                                           Style="{StaticResource MutedText}" FontSize="10"
                                           Text="Autosaved"
                                           Visibility="{Binding IsSaving, Converter={StaticResource InverseBoolToVis}}"/>
                                <TextBlock Grid.Column="1"
                                           Style="{StaticResource MutedText}" FontSize="10"
                                           Text="Saving..."
                                           Visibility="{Binding IsSaving, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
