  Phase 28 — Traffic dashboard. Mirrors the legacy web's traffic page:
  range dropdown + 5 stat cards + line chart + 2 tables (by-profile,
  by-domain) with a per-profile filter on the domains table.
-->
<UserControl x:Class="GhostShell.App.Views.TrafficView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:TrafficViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BgBase}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="Auto"/>  <!-- stat cards -->
            <RowDefinition Height="Auto"/>  <!-- chart -->
            <RowDefinition Height="Auto"/>  <!-- tables -->
            <RowDefinition Height="Auto"/>  <!-- explanation -->
        </Grid.RowDefinitions>

        <!-- ─── Header ─── -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource PageTitle}"
                           Text="📈  Traffic"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox MinWidth="160"
                              ItemsSource="{Binding RangeOptions}"
                              SelectedItem="{Binding SelectedRange}"/>
                </WrapPanel>
            </Grid>
            <Border Grid.Row="1" Style="{StaticResource Card}"
                    Padding="14,10" Margin="0,12,0,0">
                <TextBlock Style="{StaticResource PageSubtitle}"
                           TextWrapping="Wrap"
                           Text="Bandwidth accounting per profile + per domain. Bytes are measured at the proxy layer (TCP-level, includes TLS overhead + headers + compressed bodies); requests count individual HTTP transactions including cache hits. Aggregated hourly — no URLs or response bodies are stored."/>
            </Border>
        </Grid>

        <!-- ─── Stat cards ─── -->
        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="TOTAL BYTES" Style="{StaticResource MutedText}" FontSize="10"/>
                    <TextBlock Text="{Binding TotalBytesText}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource Accent}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="TOTAL REQUESTS" Style="{StaticResource MutedText}" FontSize="10"/>
                    <TextBlock Text="{Binding TotalRequestsText}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="PROFILES" Style="{StaticResource MutedText}" FontSize="10"/>
                    <TextBlock Text="{Binding ProfileCountText}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="DOMAINS" Style="{StaticResource MutedText}" FontSize="10"/>
                    <TextBlock Text="{Binding DomainCountText}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource Card}" Padding="14,12">
                <StackPanel>
                    <TextBlock Text="AVG / REQ" Style="{StaticResource MutedText}" FontSize="10"/>
                    <TextBlock Text="{Binding AvgBytesText}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ─── Chart ─── -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="14,12,14,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="📊  Time series"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}"/>
                    <TextBlock Grid.Column="1" Text="{Binding ChartCaption}"
                               Style="{StaticResource MutedText}" FontSize="10"
                               VerticalAlignment="Center"/>
                </Grid>
                <Canvas Grid.Row="1" x:Name="ChartCanvas"
                        Height="220"
                        Margin="0,0,0,14"
                        Background="Transparent"/>
            </Grid>
        </Border>

        <!-- ─── Tables: by profile + by domain ─── -->
        <Grid Grid.Row="3" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- By profile -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0" Margin="0,0,7,0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top"
                               Text="👤  By profile"
                               Foreground="{StaticResource Text}"
                               FontSize="13" FontWeight="SemiBold"
                               Margin="14,12,14,8"/>
                    <DataGrid ItemsSource="{Binding ByProfile}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              Margin="0,0,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Profile"  Binding="{Binding ProfileName}"             Width="*"/>
                            <DataGridTextColumn Header="Bytes"    Binding="{Binding Bytes}"                   Width="100"/>
                            <DataGridTextColumn Header="Requests" Binding="{Binding Requests, StringFormat=N0}" Width="100"/>
                            <DataGridTextColumn Header="Domains"  Binding="{Binding DomainCount}"             Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- By domain -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="0" Margin="7,0,0,0">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="14,12,14,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="🌐  Top domains"
                                   Foreground="{StaticResource Text}"
                                   FontSize="13" FontWeight="SemiBold"/>
                        <ComboBox Grid.Column="1"
                                  MinWidth="160"
                                  ItemsSource="{Binding ProfileFilters}"
                                  SelectedItem="{Binding DomainProfileFilter}"
                                  ToolTip="Filter by profile (empty = all)"/>
                    </Grid>
                    <DataGrid ItemsSource="{Binding ByDomain}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              HeadersVisibility="Column"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Domain"   Binding="{Binding Domain}"                  Width="*"/>
                            <DataGridTextColumn Header="Bytes"    Binding="{Binding Bytes}"                   Width="100"/>
                            <DataGridTextColumn Header="Requests" Binding="{Binding Requests, StringFormat=N0}" Width="100"/>
                            <DataGridTextColumn Header="Profiles" Binding="{Binding ProfileCount}"            Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ─── Explanation ─── -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Padding="14,10" Margin="0,0,0,14">
            <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" FontSize="11">
                <Run FontWeight="SemiBold" Foreground="{StaticResource Text}" Text="How traffic is captured: "/>
                <Run Text="every byte that flows through the per-profile auth-proxy forwarder is counted at the TCP layer, so HTTPS bodies are measured by their on-the-wire size (TLS overhead + headers + gzipped body). Profiles that launch without a proxy report no bytes here — that's expected."/>
                <LineBreak/>
                <LineBreak/>
                <Run FontWeight="SemiBold" Foreground="{StaticResource Text}" Text="Privacy: "/>
                <Run Text="only the hostname (e.g. example.com) is ever recorded — no URLs, query strings, headers, or response bodies. Aggregation is per (profile, domain, hour) so the table stays small."/>
            </TextBlock>
        </Border>
    </Grid>
    </ScrollViewer>
</UserControl>
