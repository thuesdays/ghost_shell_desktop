<UserControl x:Class="GhostShell.App.Views.RunsView"
             x:Name="PageRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:RunsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Row context menu — View logs / Mark failed.
             ContextMenu lives in a separate visual tree so its plain
             bindings see the row's DataContext (a Run) rather than
             the page VM. We pin DataContext to PageRoot via x:Reference,
             then grab the row item via PlacementTarget.DataContext for
             CommandParameter — same pattern Profiles + Sessions use. -->
        <ContextMenu x:Key="RunRowMenu"
                     DataContext="{Binding DataContext, Source={x:Reference PageRoot}}">
            <MenuItem Header="View logs for this run"
                      Command="{Binding ViewLogsCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
            <Separator/>
            <MenuItem Header="Mark failed"
                      Command="{Binding MarkFailedCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
        </ContextMenu>
    </UserControl.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header        -->
            <RowDefinition Height="Auto"/>  <!-- stats toolbar -->
            <RowDefinition Height="Auto"/>  <!-- filter row    -->
            <RowDefinition Height="*"/>     <!-- table         -->
            <RowDefinition Height="Auto"/>  <!-- pagination    -->
        </Grid.RowDefinitions>

        <!-- Header + clear-history toolbar — buttons can wrap to a
             second line when window is narrow. -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource PageTitle}"
                           Text="Run history"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="🗑  Clear &gt; 30d"
                            Command="{Binding ClearCommand}"
                            CommandParameter="30"
                            Margin="0,0,4,4"/>
                    <Button Content="&gt; 7d"
                            Command="{Binding ClearCommand}"
                            CommandParameter="7"
                            Margin="0,0,4,4"/>
                    <Button Content="&gt; 1d"
                            Command="{Binding ClearCommand}"
                            CommandParameter="1"
                            Margin="0,0,4,4"/>
                    <Button Content="all"
                            Command="{Binding ClearCommand}"
                            CommandParameter=""
                            Margin="0,0,0,4"/>
                </WrapPanel>
            </Grid>
            <Border Grid.Row="1" Style="{StaticResource Card}"
                    Padding="14,10" Margin="0,12,0,0">
                <TextBlock Style="{StaticResource PageSubtitle}"
                           TextWrapping="Wrap"
                           Text="All monitoring runs stored in the database."/>
            </Border>
        </Grid>

        <!-- Stats toolbar -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="10,8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                    <TextBlock FontFamily="{StaticResource FontMono}" FontSize="14"
                               Foreground="{StaticResource Text}" Text="{Binding Total}"/>
                    <TextBlock Margin="6,0,0,0" Style="{StaticResource MutedText}" Text="total" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Foreground="{StaticResource TextDim}" Text="·" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                    <TextBlock FontFamily="{StaticResource FontMono}" FontSize="14"
                               Foreground="{StaticResource OkBrush}" Text="{Binding Successful}"/>
                    <TextBlock Margin="6,0,0,0" Style="{StaticResource MutedText}" Text="successful" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Foreground="{StaticResource TextDim}" Text="·" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                    <TextBlock FontFamily="{StaticResource FontMono}" FontSize="14"
                               Foreground="{StaticResource ErrBrush}" Text="{Binding Failed}"/>
                    <TextBlock Margin="6,0,0,0" Style="{StaticResource MutedText}" Text="failed" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Foreground="{StaticResource TextDim}" Text="·" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,18,0">
                    <TextBlock FontFamily="{StaticResource FontMono}" FontSize="14"
                               Foreground="{StaticResource WarnBrush}" Text="{Binding Running}"/>
                    <TextBlock Margin="6,0,0,0" Style="{StaticResource MutedText}" Text="running" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Foreground="{StaticResource TextDim}" Text="·" Margin="0,0,8,0"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsFiltered, Converter={StaticResource BoolToVis}}"/>
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding IsFiltered, Converter={StaticResource BoolToVis}}">
                    <TextBlock FontFamily="{StaticResource FontMono}" FontSize="14"
                               Foreground="{StaticResource Accent}" Text="{Binding Shown}"/>
                    <TextBlock Margin="6,0,0,0" Style="{StaticResource MutedText}" Text="shown" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Filter row: status, profile, time range, search, page size, reset -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="10,8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0" Margin="0,0,8,0" MinWidth="120"
                          ItemsSource="{Binding StatusOptions}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding StatusFilter, Mode=TwoWay}"
                          ToolTip="Status"/>

                <ComboBox Grid.Column="1" Margin="0,0,8,0" MinWidth="160"
                          ItemsSource="{Binding ProfileFilterOptions}"
                          SelectedItem="{Binding ProfileFilter, Mode=TwoWay}"
                          ToolTip="Profile"/>

                <ComboBox Grid.Column="2" Margin="0,0,8,0" MinWidth="120"
                          ItemsSource="{Binding TimeRangeOptions}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Hours"
                          SelectedValue="{Binding TimeRangeHours, Mode=TwoWay}"
                          ToolTip="Time range"/>

                <TextBox  Grid.Column="3" Margin="0,0,8,0"
                          Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ToolTip="Search by id, profile, or exit:CODE"
                          Tag="Search…"/>

                <ComboBox Grid.Column="4" Margin="0,0,8,0" MinWidth="60"
                          ItemsSource="{Binding PageSizeOptions}"
                          SelectedItem="{Binding PageSize, Mode=TwoWay}"
                          ToolTip="Page size"/>

                <Button   Grid.Column="5" Content="Reset"
                          Command="{Binding ResetFiltersCommand}"
                          Visibility="{Binding IsFiltered, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="3">
            <!-- Empty state — stretched to fill the whole row so it
                 anchors the eye in the middle of the page rather
                 than collapsing to a thin strip near the top. -->
            <Border Style="{StaticResource Card}" Padding="40"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock FontSize="48" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextDim}" Text="∅"/>
                    <TextBlock Margin="0,14,0,6" HorizontalAlignment="Center"
                               Style="{StaticResource PageTitle}" FontSize="16"
                               Text="No runs yet"/>
                    <TextBlock HorizontalAlignment="Center" Style="{StaticResource MutedText}"
                               Text="Start a profile from the Profiles page to see runs here."/>
                    <TextBlock HorizontalAlignment="Center" Style="{StaticResource MutedText}"
                               Margin="0,4,0,0"
                               Visibility="{Binding IsFiltered, Converter={StaticResource BoolToVis}}"
                               Text="(or widen the time range / clear the search to see existing rows)"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Padding="0"
                    Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVis}}">
                <DataGrid ItemsSource="{Binding Items}"
                          SelectionMode="Single">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow"
                               BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="ContextMenu" Value="{StaticResource RunRowMenu}"/>
                            <!-- Phase 53 — tighten row height to compact the table.
                                 5px vertical padding + smaller font size = denser layout.
                                 Phase 71kk — 32→36. The 30px RowActionButton in the
                                 action column had no breathing room (cell padding
                                 eats 2-3px top + bottom), which clipped the bottom of
                                 the View-logs glyph. 4 extra px is the smallest bump
                                 that lets the icon render fully without making the
                                 grid feel padded. -->
                            <Setter Property="Height" Value="36"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"        Binding="{Binding Id}" Width="60" IsReadOnly="True"/>
                        <DataGridTextColumn Header="STARTED"  Binding="{Binding StartedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="160" IsReadOnly="True"/>
                        <DataGridTextColumn Header="PROFILE"  Binding="{Binding ProfileName}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="DURATION" Binding="{Binding Duration, StringFormat=hh\\:mm\\:ss}" Width="90" IsReadOnly="True"/>
                        <DataGridTextColumn Header="REQ"      Binding="{Binding TotalQueries}" Width="60" IsReadOnly="True"/>
                        <DataGridTextColumn Header="ADS"      Binding="{Binding TotalAds}"     Width="60" IsReadOnly="True"/>
                        <DataGridTextColumn Header="CAPTCHA"  Binding="{Binding Captchas}"     Width="80" IsReadOnly="True"/>

                        <!-- Status as a coloured pill — green "OK" for
                             clean exit, amber "running" while alive,
                             red exit code on failure. Mirrors the
                             legacy .pill / .pill-healthy / .pill-
                             critical / .pill-warning chips on the web
                             dashboard. The Border style + the
                             foreground brush both come from converters
                             over the whole Run row, so we get one
                             coherent colour family per state without
                             needing the ViewModel to compute strings. -->
                        <DataGridTemplateColumn Header="STATUS" Width="100" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{Binding ., Converter={StaticResource RunToPillStyle}}"
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource PillText}"
                                                   Text="{Binding StatusLabel}"
                                                   Foreground="{Binding ., Converter={StaticResource RunToPillForeground}}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="REASON"   Binding="{Binding StopReason}"   Width="130" IsReadOnly="True"/>

                        <!-- Per-row action strip — primary affordance
                             is "View logs", which navigates to the
                             Logs page with a profile/run filter pre-
                             applied. Mark-failed is visible when
                             running, delete is visible when finished. -->
                        <DataGridTemplateColumn Header="" Width="150" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <!-- View logs — Segoe Fluent
                                             "Page" glyph (E7C3). Same
                                             icon as the sidebar Logs
                                             entry so the affordance
                                             reads as "go to that
                                             page". -->
                                        <Button Style="{StaticResource RowActionButton}"
                                                ToolTip="View logs for this run"
                                                Command="{Binding DataContext.ViewLogsCommand,
                                                          Source={x:Reference PageRoot}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Style="{StaticResource RowActionIcon}"
                                                       FontSize="14"
                                                       Foreground="{StaticResource Accent}"
                                                       Text="&#xE7C3;"/>
                                        </Button>

                                        <!-- Mark failed — visible only
                                             while the run is still
                                             alive. -->
                                        <Button Style="{StaticResource RowActionDanger}"
                                                ToolTip="Mark this run as failed"
                                                Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding DataContext.MarkFailedCommand,
                                                          Source={x:Reference PageRoot}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Style="{StaticResource RowActionIcon}"
                                                       FontSize="14"
                                                       Foreground="{StaticResource ErrBrush}"
                                                       Text="&#xE7BA;"/>
                                        </Button>

                                        <!-- Delete — visible only when
                                             the run has finished. Phase 53 —
                                             trash/delete icon (Segoe Fluent
                                             E74D). Marked danger red. -->
                                        <Button Style="{StaticResource RowActionDanger}"
                                                ToolTip="Delete this run from history"
                                                Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolToVis}}"
                                                Command="{Binding DataContext.DeleteRunCommand,
                                                          Source={x:Reference PageRoot}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Style="{StaticResource RowActionIcon}"
                                                       FontSize="14"
                                                       Foreground="{StaticResource ErrBrush}"
                                                       Text="&#xE74D;"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Pagination footer.
             Note on bindings inside <Run>: WPF's Run.Text is a CLR
             property, not a DependencyProperty, so a plain binding
             on it never propagates. The page-indicator therefore
             goes through a TextBlock with two side-by-side TextBlocks
             instead. Same look, no silent binding failure. -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Padding="12,10" Margin="0,8,0,0"
                Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource MutedText}" Text="Page  "/>
                    <TextBlock FontFamily="{StaticResource FontMono}" FontSize="13"
                               Foreground="{StaticResource Text}"
                               Text="{Binding CurrentPage, Mode=OneWay}"/>
                    <TextBlock Style="{StaticResource MutedText}" Text="  /  "/>
                    <TextBlock FontFamily="{StaticResource FontMono}" FontSize="13"
                               Foreground="{StaticResource TextMuted}"
                               Text="{Binding TotalPages, Mode=OneWay}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Bigger arrow buttons, centered glyph. The default
                         Button content alignment respects the style; we
                         pin width/height so the four buttons line up
                         perfectly even with different glyph widths. -->
                    <Button Command="{Binding FirstPageCommand}" Margin="0,0,4,0"
                            Width="32" Height="32" FontSize="16" Padding="0"
                            ToolTip="First page"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center">
                        <TextBlock Text="«" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" FontSize="16"/>
                    </Button>
                    <Button Command="{Binding PrevPageCommand}"  Margin="0,0,4,0"
                            Width="32" Height="32" FontSize="16" Padding="0"
                            ToolTip="Previous page">
                        <TextBlock Text="‹" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" FontSize="16"/>
                    </Button>
                    <Button Command="{Binding NextPageCommand}"  Margin="0,0,4,0"
                            Width="32" Height="32" FontSize="16" Padding="0"
                            ToolTip="Next page">
                        <TextBlock Text="›" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" FontSize="16"/>
                    </Button>
                    <Button Command="{Binding LastPageCommand}"
                            Width="32" Height="32" FontSize="16" Padding="0"
                            ToolTip="Last page">
                        <TextBlock Text="»" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" FontSize="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
