<UserControl x:Class="GhostShell.App.Views.ProxyView"
             x:Name="PageRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
             xmlns:ctrl="clr-namespace:GhostShell.App.Controls"
             d:DataContext="{d:DesignInstance Type=vm:ProxyViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Phase 52 — context menu width fix. User reported menu was too narrow
             and had a "strange line" (the Separator). Set MinWidth="160" to give
             Edit and Delete buttons breathing room. Remove Separator between items
             as they're visually distinct enough on hover. Increase MenuItem padding
             for better breathing room inside menu items. -->
        <ContextMenu x:Key="ProxyRowMenu"
                     DataContext="{Binding DataContext, Source={x:Reference PageRoot}}"
                     MinWidth="160">
            <ContextMenu.Resources>
                <!-- Hide separators globally in this menu — the items are
                     visually distinct on hover, no need for explicit dividers. -->
                <Style TargetType="Separator">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </ContextMenu.Resources>
            <MenuItem Header="Test now"
                      Command="{Binding TestOneCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"
                      Padding="12,6"/>
            <MenuItem Header="Edit…"
                      Command="{Binding EditCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"
                      Padding="12,6"/>
            <Separator/>
            <MenuItem Header="Delete"
                      Command="{Binding DeleteCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"
                      Padding="12,6"/>
        </ContextMenu>
    </UserControl.Resources>

    <!-- IMPORTANT: no outer ScrollViewer.
         An outer ScrollViewer hands the DataGrid an infinite height,
         which silently disables row virtualization — every row's
         visual tree gets materialized, even those off-screen. With
         50+ proxies that turns scrolling into a slideshow. The
         DataGrid sits in a `*`-row Grid instead so it scrolls
         internally and virtualizes correctly. Timeline gets its own
         MaxHeight + ScrollViewer below. -->
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="Auto"/>  <!-- status bar -->
            <RowDefinition Height="*"/>     <!-- table (fills) -->
            <RowDefinition Height="Auto"/>  <!-- timeline (bounded) -->
        </Grid.RowDefinitions>

            <!-- ─── Header + toolbar ─── -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource PageTitle}"
                               Text="Proxies"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Phase 70 — bulk delete. Pass DataGrid.SelectedItems
                             via CommandParameter so the VM can pluck Proxy rows
                             out of the live selection. Ctrl+click / Shift+click
                             on rows to multi-select. -->
                        <Button Content="🗑  Delete selected"
                                Command="{Binding BulkDeleteCommand}"
                                CommandParameter="{Binding ElementName=ProxyGrid, Path=SelectedItems}"
                                Margin="0,0,8,4"
                                ToolTip="Delete every proxy currently highlighted (Ctrl/Shift-click to multi-select)."/>
                        <Button Content="📋  Bulk import"
                                Command="{Binding BulkImportCommand}"
                                Margin="0,0,8,4"/>
                        <Button Content="🧪  Test all"
                                Command="{Binding TestAllCommand}"
                                Margin="0,0,8,4"/>
                        <Button Content="+  Add proxy"
                                Command="{Binding AddCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                MinWidth="120" Margin="0,0,0,4"/>
                    </WrapPanel>
                </Grid>
                <Border Grid.Row="1" Style="{StaticResource Card}"
                        Padding="14,10" Margin="0,12,0,0">
                    <TextBlock Style="{StaticResource PageSubtitle}"
                               TextWrapping="Wrap"
                               Text="Proxy library. Each profile picks one — runtime routes through the assigned proxy. Right-click a row to test or edit."/>
                </Border>
            </Grid>

            <!-- ─── Status bar ─── -->
            <TextBlock Grid.Row="1"
                       Style="{StaticResource MutedText}"
                       Margin="0,0,0,8"
                       Text="{Binding StatusBar}"/>

            <!-- ─── Table / empty state ─── -->
            <Grid Grid.Row="2">
                <Border Style="{StaticResource Card}" Padding="40"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock FontSize="32" HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextDim}" Text="⌖"/>
                        <TextBlock Margin="0,10,0,4" HorizontalAlignment="Center"
                                   Style="{StaticResource PageTitle}" FontSize="14"
                                   Text="No proxies configured"/>
                        <TextBlock HorizontalAlignment="Center" Style="{StaticResource MutedText}"
                                   Margin="0,0,0,16"
                                   Text="Add one manually or bulk-paste from your provider's port list."/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="📋  Bulk import"
                                    Command="{Binding BulkImportCommand}"
                                    Margin="0,0,8,0"
                                    MinWidth="140"/>
                            <Button Content="+  Add proxy"
                                    Command="{Binding AddCommand}"
                                    Style="{StaticResource ButtonPrimary}"
                                    MinWidth="140"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="0"
                        Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVis}}">
                    <DataGrid x:Name="ProxyGrid"
                              ItemsSource="{Binding Items}"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              HeadersVisibility="Column"
                              RowHeight="28"
                              MinRowHeight="26">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow"
                                   BasedOn="{StaticResource {x:Type DataGridRow}}">
                                <Setter Property="ContextMenu" Value="{StaticResource ProxyRowMenu}"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <!-- Phase 70 — checkbox selection column. Bound to
                                 DataGridRow.IsSelected via RelativeSource so the
                                 checkbox + the row's existing selection state
                                 stay in sync (Ctrl/Shift-click on the row also
                                 ticks the box). The Bulk Delete button reads
                                 DataGrid.SelectedItems directly, so any of the
                                 three selection mechanisms — checkbox, row
                                 click, header SelectAll — feeds the same set. -->
                            <DataGridTemplateColumn Header="" Width="32"
                                                    CanUserResize="False"
                                                    CanUserSort="False"
                                                    CanUserReorder="False">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <CheckBox HorizontalAlignment="Center"
                                                  ToolTip="Select all / clear all"
                                                  IsChecked="{Binding RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}, Path=Tag, Mode=TwoWay}"
                                                  Click="OnProxySelectAllClick"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox HorizontalAlignment="Center"
                                                  IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType={x:Type DataGridRow}}, Mode=TwoWay}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="NAME"     Binding="{Binding Name}"        Width="*" IsReadOnly="True"/>
                            <!-- Phase 52 — coloured status pill so user can scan the grid for
                                 failed proxies without reading text. Match the verdict-ellipse
                                 pattern from FingerprintView's external testers. Green=Healthy,
                                 Red=Critical, Orange=Warning, Grey=Unknown. Ellipse precedes
                                 text in a horizontal StackPanel for compact scanning. -->
                            <DataGridTemplateColumn Header="STATUS" Width="80" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{StaticResource TextDim}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Health}" Value="Healthy">
                                                                <Setter Property="Fill" Value="{StaticResource OkBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Health}" Value="Critical">
                                                                <Setter Property="Fill" Value="{StaticResource ErrBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Health}" Value="Warning">
                                                                <Setter Property="Fill" Value="{StaticResource WarnBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding Health}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <!-- Phase 70 — URL / DEFAULT / ROTATE removed. URL was
                                 mostly truncated and not actionable in-grid; Default
                                 and Rotate are toggled via the Edit dialog so a
                                 read-only checkbox column was just visual noise.
                                 The freed pixels go to NAME / GEO / IP TYPE which
                                 the user actually scans by. Right-click row → Edit
                                 surfaces all three hidden fields when needed. -->
                            <DataGridTextColumn Header="GEO"      Binding="{Binding Country}"     Width="140" IsReadOnly="True"/>
                            <DataGridTextColumn Header="IP TYPE"  Binding="{Binding IpType}"      Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="LATENCY"  Binding="{Binding LatencyMs, StringFormat='{}{0} ms'}" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="PROFILES" Binding="{Binding ProfileCount}" Width="70" IsReadOnly="True"/>

                            <DataGridTextColumn Header="CHECKED"
                                                Binding="{Binding LastCheckedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                                Width="120" IsReadOnly="True"/>

                            <!-- Actions column — three icon buttons (Test, Edit,
                                 Delete). Phase 70 — trimmed from 210 to 116px:
                                 the previous slack went to URL/DEFAULT/ROTATE
                                 columns now removed. 32×3 buttons + 6×2 margin
                                 + 4px breathing on each side = 116. CellStyle
                                 still kills DataGridCell padding so the trash
                                 icon doesn't clip at the right edge. -->
                            <DataGridTemplateColumn Header="" MinWidth="116" Width="116" IsReadOnly="True"
                                                    CanUserResize="False" CanUserSort="False"
                                                    CanUserReorder="False">
                                <DataGridTemplateColumn.CellStyle>
                                    <Style TargetType="DataGridCell"
                                           BasedOn="{StaticResource {x:Type DataGridCell}}">
                                        <Setter Property="Padding"         Value="0"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Background"      Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </DataGridTemplateColumn.CellStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <Button Style="{StaticResource RowActionButton}"
                                                    ToolTip="Test now"
                                                    Margin="2,0"
                                                    Command="{Binding DataContext.TestOneCommand,
                                                              Source={x:Reference PageRoot}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Style="{StaticResource RowActionIcon}" FontSize="14"
                                                       Foreground="{StaticResource WarnBrush}"
                                                       Text="&#xE945;"/>
                                            </Button>
                                            <Button Style="{StaticResource RowActionButton}"
                                                    ToolTip="Edit"
                                                    Margin="2,0"
                                                    Command="{Binding DataContext.EditCommand,
                                                              Source={x:Reference PageRoot}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Style="{StaticResource RowActionIcon}" FontSize="14" Text="&#xE70F;"/>
                                            </Button>
                                            <Button Style="{StaticResource RowActionDanger}"
                                                    ToolTip="Delete"
                                                    Margin="2,0"
                                                    Command="{Binding DataContext.DeleteCommand,
                                                              Source={x:Reference PageRoot}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Style="{StaticResource RowActionIcon}" FontSize="14"
                                                       Foreground="{StaticResource ErrBrush}"
                                                       Text="&#xE74D;"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- ─── Proxy Health Timeline ─── -->
            <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,16,0,0"
                    Padding="16,14"
                    MaxHeight="320"
                    Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVis}}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Foreground="{StaticResource Text}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Text="📅  PROXY HEALTH TIMELINE"/>
                        <TextBlock Grid.Column="1" Margin="12,2,0,0"
                                   Style="{StaticResource MutedText}"
                                   VerticalAlignment="Center"
                                   Text="last 7 days · rotations / captchas / burn events"/>
                    </Grid>

                    <!-- Legend -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,8">
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource InfoBrush}"
                                     VerticalAlignment="Center"/>
                            <TextBlock Margin="6,0,0,0" Style="{StaticResource MutedText}"
                                       Text="rotation"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource ErrBrush}"
                                     VerticalAlignment="Center"/>
                            <TextBlock Margin="6,0,0,0" Style="{StaticResource MutedText}"
                                       Text="captcha"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource WarnBrush}"
                                     VerticalAlignment="Center"/>
                            <TextBlock Margin="6,0,0,0" Style="{StaticResource MutedText}"
                                       Text="burned"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource OkBrush}"
                                     VerticalAlignment="Center"/>
                            <TextBlock Margin="6,0,0,0" Style="{StaticResource MutedText}"
                                       Text="first seen"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Empty state — clean message instead of dozens of "Untested" rows. -->
                    <Border Padding="20,28"
                            Visibility="{Binding IsTimelineEmpty, Converter={StaticResource BoolToVis}}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock FontSize="22" HorizontalAlignment="Center"
                                       Foreground="{StaticResource TextDim}" Text="◌"/>
                            <TextBlock Margin="0,8,0,2" HorizontalAlignment="Center"
                                       Style="{StaticResource MutedText}"
                                       Text="No timeline events yet"/>
                            <TextBlock HorizontalAlignment="Center"
                                       Style="{StaticResource DimText}"
                                       TextAlignment="Center"
                                       Text="Run 'Test all' or wait for the first rotation / captcha — events will plot here as they happen."/>
                        </StackPanel>
                    </Border>

                    <!-- Per-proxy lanes — rendered only for proxies that
                         actually have events in the time window. Wrapped
                         in a ScrollViewer with virtualization so even
                         500+ lanes don't tank the frame rate. -->
                    <ScrollViewer MaxHeight="220"
                                  VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="True"
                                  Visibility="{Binding IsTimelineEmpty, Converter={StaticResource InverseBoolToVis}}">
                        <ItemsControl ItemsSource="{Binding TimelineRows}"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.CanContentScroll="True">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2" MinHeight="28">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayLine}"
                                                   FontFamily="{StaticResource FontMono}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource Text}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Style="{StaticResource DimText}"
                                                   Text="{Binding SubLine}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <ctrl:ProxyTimelineLane Grid.Column="1"
                                                            Events="{Binding Events}"
                                                            RangeStart="{Binding DataContext.TimelineRangeStart,
                                                                          Source={x:Reference PageRoot}}"
                                                            RangeEnd="{Binding DataContext.TimelineRangeEnd,
                                                                        Source={x:Reference PageRoot}}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>
</UserControl>
