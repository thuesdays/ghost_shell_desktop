  Phase 34 — Competitors page. KPI tiles, volume trend chart, and four
  tabs: leaderboard, by-domain, by-query, recent ads.
-->
<UserControl x:Class="GhostShell.App.Views.CompetitorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:CompetitorsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BgBase}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="Auto"/>  <!-- toolbar -->
            <RowDefinition Height="Auto"/>  <!-- KPI tiles -->
            <RowDefinition Height="Auto"/>  <!-- chart -->
            <!-- Phase 70 fix — tabs row now takes the rest of the page
                 (Height="*"). Was Auto, which made every child of the
                 inner Grid that used Height="*" collapse to 0 height —
                 specifically the DataGrid that holds the leaderboard rows.
                 The page showed the tab buttons + the "3 competitor(s)"
                 footer (both Auto) but the grid itself was invisible.
                 Removed the trailing filler row since this row now
                 grows to fill the remaining space. -->
            <RowDefinition Height="*"/>     <!-- tabs + content -->
        </Grid.RowDefinitions>

        <!-- ─── Header ─── -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Style="{StaticResource PageTitle}"
                       Text="Competitors"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
            <Border Grid.Row="1" Style="{StaticResource Card}"
                    Padding="14,10" Margin="0,12,0,0">
                <TextBlock Style="{StaticResource PageSubtitle}"
                           TextWrapping="Wrap"
                           Text="Advertisers observed across all monitored queries. Expand a row for per-ad detail, or use inline actions to push a domain into your Domains lists."/>
            </Border>
        </Grid>

        <!-- ─── Toolbar ─── -->
        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search TextBox -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="10,6" Margin="0,0,12,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🔍" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <Grid Grid.Column="1">
                        <!-- Watermark — WPF's TextBox has no native
                             Placeholder property, so we overlay a
                             dim TextBlock that hides whenever the
                             user has typed anything. -->
                        <TextBlock Text="Search domain or ad title…"
                                   Foreground="{StaticResource TextDim}"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Margin="2,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Period Switcher -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                <ToggleButton x:Name="Btn24h"
                              Command="{Binding SetPeriodCommand}"
                              CommandParameter="24h"
                              IsChecked="{Binding Days, Converter={StaticResource StringEqualsBool}, ConverterParameter=1}"
                              Padding="12,6" Margin="0,0,6,0"
                              Content="24h"/>
                <ToggleButton x:Name="Btn7d"
                              Command="{Binding SetPeriodCommand}"
                              CommandParameter="7d"
                              IsChecked="{Binding Days, Converter={StaticResource StringEqualsBool}, ConverterParameter=7}"
                              Padding="12,6" Margin="0,0,6,0"
                              Content="7d"/>
                <ToggleButton x:Name="Btn30d"
                              Command="{Binding SetPeriodCommand}"
                              CommandParameter="30d"
                              IsChecked="{Binding Days, Converter={StaticResource StringEqualsBool}, ConverterParameter=30}"
                              Padding="12,6" Margin="0,0,6,0"
                              Content="30d"/>
                <ToggleButton x:Name="BtnAll"
                              Command="{Binding SetPeriodCommand}"
                              CommandParameter="all"
                              IsChecked="{Binding Days, Converter={StaticResource StringEqualsBool}, ConverterParameter=0}"
                              Padding="12,6"
                              Content="All"/>
            </StackPanel>

            <!-- Export Buttons -->
            <Button Grid.Column="2"
                    Command="{Binding ExportCsvCommand}"
                    Style="{StaticResource ButtonGhost}"
                    Padding="10,6" Margin="0,0,6,0"
                    Content="CSV"/>
            <Button Grid.Column="3"
                    Command="{Binding ExportJsonCommand}"
                    Style="{StaticResource ButtonGhost}"
                    Padding="10,6"
                    Content="JSON"/>
        </Grid>

        <!-- ─── KPI Tiles ─── -->
        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Records -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="RECORDS · last Nd" Style="{StaticResource MutedText}" FontSize="10"/>
                    <TextBlock Text="{Binding RecordsCount}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource Accent}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Unique Domains -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="UNIQUE DOMAINS · all time" Style="{StaticResource MutedText}" FontSize="10"/>
                    <TextBlock Text="{Binding UniqueDomainsCount}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- New Domains -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="NEW · 7d" Style="{StaticResource MutedText}" FontSize="10"/>
                    <TextBlock Text="{Binding NewDomainsCount}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource HueGreen}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Active Domains -->
            <Border Grid.Column="3" Style="{StaticResource Card}" Padding="14,12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="ACTIVE · 3d" Style="{StaticResource MutedText}" FontSize="10"/>
                    <TextBlock Text="{Binding ActiveDomainCount}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource HueOrange}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Quieting Domains -->
            <Border Grid.Column="4" Style="{StaticResource Card}" Padding="14,12">
                <StackPanel>
                    <TextBlock Text="QUIETING · >14d" Style="{StaticResource MutedText}" FontSize="10"/>
                    <TextBlock Text="{Binding QuietingDomainsCount}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{StaticResource HueAmber}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ─── Volume Trend Chart ─── -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="14,12,14,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="📈  Volume trend · top competitors by mentions"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource Text}"/>
                    <Button Grid.Column="1"
                            Command="{Binding ToggleChartKindCommand}"
                            Style="{StaticResource ButtonGhost}"
                            Padding="10,4" FontSize="11"
                            Content="{Binding ChartKind, StringFormat='{}{0}'}"/>
                </Grid>
                <Canvas Grid.Row="1" x:Name="ChartCanvas"
                        Height="200"
                        Margin="0,0,0,14"
                        Background="Transparent"/>
            </Grid>
        </Border>

        <!-- ─── Tab Rail ─── -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab Buttons -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,0">
                <ToggleButton x:Name="TabLeaderboard"
                              IsChecked="{Binding LeaderboardSelected}"
                              Click="TabLeaderboard_Click"
                              Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Leaderboard"/>
                        <Border Background="{StaticResource BgDeep}" Padding="4,0" Margin="8,0,0,0" CornerRadius="2">
                            <TextBlock Text="{Binding LeaderboardRows.Count}" FontSize="10"/>
                        </Border>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton x:Name="TabByDomain"
                              IsChecked="{Binding ByDomainSelected}"
                              Click="TabByDomain_Click"
                              Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="By domain"/>
                        <Border Background="{StaticResource BgDeep}" Padding="4,0" Margin="8,0,0,0" CornerRadius="2">
                            <TextBlock Text="{Binding LeaderboardRows.Count}" FontSize="10"/>
                        </Border>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton x:Name="TabByQuery"
                              IsChecked="{Binding ByQuerySelected}"
                              Click="TabByQuery_Click"
                              Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="By query"/>
                        <Border Background="{StaticResource BgDeep}" Padding="4,0" Margin="8,0,0,0" CornerRadius="2">
                            <TextBlock Text="{Binding ByQueryRows.Count}" FontSize="10"/>
                        </Border>
                    </StackPanel>
                </ToggleButton>

                <ToggleButton x:Name="TabRecentAds"
                              IsChecked="{Binding RecentAdsSelected}"
                              Click="TabRecentAds_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Recent ads"/>
                        <Border Background="{StaticResource BgDeep}" Padding="4,0" Margin="8,0,0,0" CornerRadius="2">
                            <TextBlock Text="{Binding RecentAds.Count}" FontSize="10"/>
                        </Border>
                    </StackPanel>
                </ToggleButton>
            </StackPanel>

            <!-- Separator -->
            <Border Grid.Row="1" Height="1" Background="{StaticResource Border}" Margin="0,8,0,8"/>

            <!-- Tab Content -->
            <Grid Grid.Row="2">
                <!-- Leaderboard Tab -->
                <Border Visibility="{Binding LeaderboardSelected, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Empty state -->
                        <TextBlock Grid.Row="0"
                                   Visibility="{Binding LeaderboardRows.Count, Converter={StaticResource StringEqualsVis}, ConverterParameter=0}"
                                   Style="{StaticResource MutedText}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Text="No competitor records yet — run a script to populate."/>

                        <!-- Leaderboard DataGrid -->
                        <DataGrid Grid.Row="0"
                                  ItemsSource="{Binding LeaderboardRows}"
                                  Visibility="{Binding LeaderboardRows.Count, Converter={StaticResource NonEmptyToVisibleConverter}}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  HeadersVisibility="Column"
                                  SelectionMode="Single"
                                  Margin="0,0,0,12">
                            <DataGrid.Columns>
                                <!-- Phase 70 — drop the broken "#" column.
                                     It was binding the entire row through
                                     a StringEqualsConverter (a Visibility
                                     converter), producing garbage. Domain
                                     is the natural primary key here and
                                     numbering provides no insight. -->
                                <DataGridTextColumn Header="Domain" Width="*" Binding="{Binding Domain}"/>
                                <!-- Classification badge — drives row colour
                                     by the row's ClassificationBadge value:
                                       mine       → soft-red  (own ad — should never see this)
                                       target     → soft-green (paid target)
                                       blocked    → muted     (in block list)
                                       not_target → soft-amber (genuine new competitor)
                                     The amber "not_target" badge calls out
                                     domains the user hasn't decided about yet
                                     so they can hit Target / Block to triage. -->
                                <DataGridTemplateColumn Header="Status" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Padding="6,2" CornerRadius="3"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background"  Value="{StaticResource BgRaised}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ClassificationBadge}" Value="not_target">
                                                                <Setter Property="Background"  Value="{StaticResource WarnSoftBrush}"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource WarnBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ClassificationBadge}" Value="target">
                                                                <Setter Property="Background"  Value="{StaticResource OkSoftBrush}"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource OkBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ClassificationBadge}" Value="blocked">
                                                                <Setter Property="Background"  Value="{StaticResource BgDeep}"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource TextDim}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ClassificationBadge}" Value="mine">
                                                                <Setter Property="Background"  Value="{StaticResource ErrSoftBrush}"/>
                                                                <Setter Property="BorderBrush" Value="{StaticResource ErrBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding ClassificationBadge}"
                                                           FontFamily="{StaticResource FontMono}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource Text}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Mentions" Width="100" Binding="{Binding Mentions}"/>
                                <DataGridTextColumn Header="Prev" Width="80" Binding="{Binding MentionsPrev}"/>
                                <DataGridTextColumn Header="Queries" Width="80" Binding="{Binding QueriesCount}"/>
                                <DataGridTextColumn Header="Clicks" Width="80" Binding="{Binding ClicksCount}"/>
                                <DataGridTextColumn Header="Last Seen" Width="140" Binding="{Binding LastSeen, StringFormat='{}{0:g}'}"/>
                                <DataGridTemplateColumn Header="Actions" Width="180">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="4,0">
                                                <!-- Phase 70 — disable Target / Block buttons when the
                                                     domain is already in that list. AddToTargetAsync
                                                     dedupes server-side too (returns "Already in list"),
                                                     but pre-disabling makes the state visible without
                                                     having to click. -->
                                                <Button Command="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=DataContext.AddToTargetCommand}"
                                                        CommandParameter="{Binding .}"
                                                        Style="{StaticResource ButtonGhost}"
                                                        Padding="8,4" FontSize="10"
                                                        Content="Target"
                                                        IsEnabled="{Binding IsInTarget, Converter={StaticResource InverseBoolConverter}}"
                                                        ToolTip="Add this domain to the global Target list (no duplicates)."/>
                                                <Button Command="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=DataContext.AddToBlockCommand}"
                                                        CommandParameter="{Binding .}"
                                                        Style="{StaticResource ButtonGhost}"
                                                        Padding="8,4" FontSize="10" Margin="6,0,0,0"
                                                        Content="Block"
                                                        IsEnabled="{Binding IsInBlock, Converter={StaticResource InverseBoolConverter}}"
                                                        ToolTip="Add this domain to the global Block list (no duplicates)."/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Footer -->
                        <TextBlock Grid.Row="1" Style="{StaticResource MutedText}" FontSize="10"
                                   Text="{Binding LeaderboardRows.Count, StringFormat='{}{0} competitor(s)'}"/>
                    </Grid>
                </Border>

                <!-- By Domain Tab -->
                <Border Visibility="{Binding ByDomainSelected, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Empty state -->
                        <TextBlock Grid.Row="0"
                                   Visibility="{Binding LeaderboardRows.Count, Converter={StaticResource StringEqualsVis}, ConverterParameter=0}"
                                   Style="{StaticResource MutedText}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Text="No competitor records yet — run a script to populate."/>

                        <!-- Data (reuse leaderboard grouped) -->
                        <DataGrid Grid.Row="0"
                                  ItemsSource="{Binding LeaderboardRows}"
                                  Visibility="{Binding LeaderboardRows.Count, Converter={StaticResource NonEmptyToVisibleConverter}}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  HeadersVisibility="Column"
                                  SelectionMode="Single"
                                  Margin="0,0,0,12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Domain" Width="*" Binding="{Binding Domain}"/>
                                <DataGridTextColumn Header="Mentions" Width="140" Binding="{Binding Mentions}"/>
                                <DataGridTextColumn Header="Queries" Width="100" Binding="{Binding QueriesCount}"/>
                                <DataGridTextColumn Header="Last Seen" Width="140" Binding="{Binding LastSeen, StringFormat='{}{0:g}'}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Footer -->
                        <TextBlock Grid.Row="1" Style="{StaticResource MutedText}" FontSize="10"
                                   Text="{Binding LeaderboardRows.Count, StringFormat='{}{0} domain(s)'}"/>
                    </Grid>
                </Border>

                <!-- By Query Tab -->
                <Border Visibility="{Binding ByQuerySelected, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Empty state -->
                        <TextBlock Grid.Row="0"
                                   Visibility="{Binding ByQueryRows.Count, Converter={StaticResource StringEqualsVis}, ConverterParameter=0}"
                                   Style="{StaticResource MutedText}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Text="No competitor records yet — run a script to populate."/>

                        <!-- Data -->
                        <DataGrid Grid.Row="0"
                                  ItemsSource="{Binding ByQueryRows}"
                                  Visibility="{Binding ByQueryRows.Count, Converter={StaticResource NonEmptyToVisibleConverter}}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  HeadersVisibility="Column"
                                  SelectionMode="Single"
                                  Margin="0,0,0,12">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Query" Width="*" Binding="{Binding Query}"/>
                                <DataGridTextColumn Header="Ad Count" Width="100" Binding="{Binding AdCount}"/>
                                <DataGridTextColumn Header="Unique Domains" Width="130" Binding="{Binding UniqueDomains}"/>
                                <DataGridTextColumn Header="Last Seen" Width="140" Binding="{Binding LastSeen, StringFormat='{}{0:g}'}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Footer -->
                        <TextBlock Grid.Row="1" Style="{StaticResource MutedText}" FontSize="10"
                                   Text="{Binding ByQueryRows.Count, StringFormat='{}{0} query(ies)'}"/>
                    </Grid>
                </Border>

                <!-- Recent Ads Tab -->
                <Border Visibility="{Binding RecentAdsSelected, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Empty state -->
                        <TextBlock Grid.Row="0"
                                   Visibility="{Binding RecentAds.Count, Converter={StaticResource StringEqualsVis}, ConverterParameter=0}"
                                   Style="{StaticResource MutedText}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Text="No competitor records yet — run a script to populate."/>

                        <!-- Recent ads list -->
                        <ItemsControl Grid.Row="0"
                                      ItemsSource="{Binding RecentAds}"
                                      Visibility="{Binding RecentAds.Count, Converter={StaticResource NonEmptyToVisibleConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}" Padding="12,10" Margin="0,0,0,8"
                                            Background="{StaticResource BgRaised}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="{Binding AdTitle}"
                                                       FontWeight="SemiBold" Margin="0,0,0,4"/>
                                            <TextBlock Grid.Row="1" Text="{Binding DisplayUrl}"
                                                       FontFamily="Consolas,Courier New,monospace"
                                                       Foreground="{StaticResource TextDim}"
                                                       FontSize="10" Margin="0,0,0,6"/>
                                            <StackPanel Grid.Row="2" Orientation="Horizontal">
                                                <Border Padding="6,2" CornerRadius="2"
                                                        Background="{StaticResource Accent}" Opacity="0.2">
                                                    <TextBlock Text="{Binding Domain}" FontSize="9"/>
                                                </Border>
                                                <TextBlock Text="{Binding CapturedAt, StringFormat='{}{0:g}'}"
                                                           Style="{StaticResource MutedText}" FontSize="9"
                                                           Margin="12,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Footer -->
                        <TextBlock Grid.Row="1" Style="{StaticResource MutedText}" FontSize="10"
                                   Text="{Binding RecentAds.Count, StringFormat='{}{0} ad(s)'}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
    </ScrollViewer>
</UserControl>
