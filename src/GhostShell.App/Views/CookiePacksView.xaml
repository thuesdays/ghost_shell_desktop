<UserControl x:Class="GhostShell.App.Views.CookiePacksView"
             x:Name="PageRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:CookiePacksViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <ContextMenu x:Key="PackRowMenu"
                     DataContext="{Binding DataContext, Source={x:Reference PageRoot}}">
            <MenuItem Header="Apply to running profile"
                      Command="{Binding ApplyCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
            <MenuItem Header="Export to file…"
                      Command="{Binding ExportToFileCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
            <Separator/>
            <MenuItem Header="Delete"
                      Command="{Binding DeleteCookiePackCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
        </ContextMenu>
    </UserControl.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title + buttons row 0; subtitle full-width on row 1 so it
             wraps cleanly at narrow window sizes. -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource PageTitle}"
                           Text="Cookie packs"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⬇  Import…"
                            Command="{Binding ImportFromFileCommand}"
                            Style="{StaticResource ButtonPrimary}"
                            MinWidth="120"/>
                </WrapPanel>
            </Grid>
            <Border Grid.Row="1" Style="{StaticResource Card}"
                    Padding="14,10" Margin="0,12,0,0">
                <TextBlock Style="{StaticResource PageSubtitle}"
                           TextWrapping="Wrap"
                           Text="Portable cookie + localStorage bundles. Import a pack from disk to get a head-start on a fresh profile."/>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Border Style="{StaticResource Card}" Padding="40"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock FontSize="48" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextDim}" Text="∅"/>
                    <TextBlock Margin="0,14,0,6" HorizontalAlignment="Center"
                               Style="{StaticResource PageTitle}" FontSize="16"
                               Text="No cookie packs yet"/>
                    <TextBlock HorizontalAlignment="Center" Style="{StaticResource MutedText}"
                               Text="Click Import to load a pack from disk. Packs are gzipped JSON files exported from any Ghost Shell profile."/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Padding="0"
                    Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVis}}">
                <DataGrid ItemsSource="{Binding Items}" SelectionMode="Single">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow"
                               BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="ContextMenu" Value="{StaticResource PackRowMenu}"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="LABEL"   Binding="{Binding Label}"        Width="*"   IsReadOnly="True"/>
                        <DataGridTextColumn Header="SLUG"    Binding="{Binding Slug}"         Width="200" IsReadOnly="True"/>
                        <DataGridTextColumn Header="COOKIES" Binding="{Binding CookiesCount}" Width="80"  IsReadOnly="True"/>
                        <DataGridTextColumn Header="STORAGE" Binding="{Binding StorageCount}" Width="80"  IsReadOnly="True"/>
                        <DataGridTextColumn Header="AGE"     Binding="{Binding AgeDays, StringFormat='{}{0}d'}" Width="60" IsReadOnly="True"/>
                        <DataGridTextColumn Header="CAPTCHA" Binding="{Binding CaptchaRate, StringFormat='{}{0:P1}'}" Width="80" IsReadOnly="True"/>
                        <DataGridTextColumn Header="UPDATED" Binding="{Binding UpdatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140" IsReadOnly="True"/>

                        <!-- Per-row action column with delete button.
                             Uses trash/delete icon (Segoe Fluent E74D) in danger red.
                             Mirrors RunsView pattern: single RowActionDanger button. -->
                        <DataGridTemplateColumn Header="" Width="100" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <!-- Delete button — marked danger red (ErrBrush).
                                             Calls DeleteCookiePackAsync on the VM with
                                             the row's CookiePack as CommandParameter. -->
                                        <Button Style="{StaticResource RowActionDanger}"
                                                ToolTip="Delete this pack"
                                                Command="{Binding DataContext.DeleteCookiePackCommand,
                                                          Source={x:Reference PageRoot}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Style="{StaticResource RowActionIcon}"
                                                       FontSize="14"
                                                       Foreground="{StaticResource ErrBrush}"
                                                       Text="&#xE74D;"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
