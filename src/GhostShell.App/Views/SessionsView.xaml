<UserControl x:Class="GhostShell.App.Views.SessionsView"
             x:Name="PageRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:SessionsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>

        <!-- Snapshot row context menu — same actions as the legacy
             Sessions page but moved into the Snapshots tab. -->
        <ContextMenu x:Key="SnapshotRowMenu"
                     DataContext="{Binding DataContext, Source={x:Reference PageRoot}}">
            <MenuItem Header="Open detail (cookies + storage)"
                      Command="{Binding OpenSnapshotCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
            <Separator/>
            <MenuItem Header="Restore (promote to top)"
                      Command="{Binding RestoreSnapshotCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
            <Separator/>
            <MenuItem Header="Delete"
                      Command="{Binding DeleteSnapshotCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
        </ContextMenu>

        <!-- Preset card layout. Single-selected card gets the
             preset's own accent colour (driven by AccentBrush from the
             VM) as both the left stripe and the selected-state border.
             Clicking anywhere on a card invokes the parent's
             SelectPreset command. -->
        <Style x:Key="PresetCardStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width"  Value="280"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment"   Value="Stretch"/>
            <Setter Property="Background" Value="{StaticResource BgRaised}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True"
                                ClipToBounds="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <!-- Left accent stripe — pinned to
                                         the preset's hue so the grid
                                         reads as a colour map. -->
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="Stripe"
                                        Grid.Column="0"
                                        Background="{Binding AccentBrush}"/>
                                <ContentPresenter Grid.Column="1"
                                                  Margin="14,12,12,12"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{StaticResource BorderStrong}"/>
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource BgHover}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{Binding AccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Profile sidebar row -->
        <Style x:Key="ProfileRowStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin"  Value="0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource BgActive}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Numeric "X SITES" pill on each preset card -->
        <Style x:Key="SitePill" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgDeep}"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="6,2"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ════════════════════════════════════════════════════════════
             LEFT: profile sidebar
             ════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
            <DockPanel LastChildFill="True">
                <!-- Header -->
                <Grid DockPanel.Dock="Top" Margin="14,12,12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="PROFILES"
                               Style="{StaticResource CardHeader}"
                               Margin="0"/>
                    <TextBlock Grid.Column="1"
                               Foreground="{StaticResource TextDim}"
                               FontSize="9.5"
                               Text="{Binding ProfileRows.Count}"/>
                </Grid>

                <Border DockPanel.Dock="Top" Height="1"
                        Background="{StaticResource Border}"/>

                <!-- Bulk-action strip — appears only when at least one
                     row is ticked. Mirrors the Profiles page's accent
                     strip. The "× clear" link inside untics every row;
                     the "Run warmup" button below the page is what
                     actually fires the batch. -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource AccentSoft}"
                        BorderBrush="{StaticResource Accent}"
                        BorderThickness="0,0,0,1"
                        Padding="14,8"
                        Visibility="{Binding HasChecked, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding BulkSelectionLabel}"
                                   Foreground="{StaticResource Accent}"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="× clear"
                                Command="{Binding ClearCheckedCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource Accent}"
                                FontSize="10.5"
                                Padding="4,0"
                                Cursor="Hand"/>
                    </Grid>
                </Border>

                <!-- List -->
                <ListBox ItemsSource="{Binding ProfileRows}"
                         SelectedItem="{Binding SelectedProfileRow, Mode=TwoWay}"
                         ItemContainerStyle="{StaticResource ProfileRowStyle}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="6,6,6,8"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Per-row checkbox: drives the batch
                                     warmup target set. Decoupled from
                                     ListBox.SelectedItem (that's the
                                     "focused" profile for stats). -->
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0"/>

                                <!-- Liveness dot — green when running;
                                     transparent when idle so the row
                                     metrics stay aligned. -->
                                <Ellipse Grid.Column="1"
                                         Width="6" Height="6"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"
                                         Fill="{StaticResource OkBrush}"
                                         Visibility="{Binding IsLive,
                                                              Converter={StaticResource BoolToVis}}"/>
                                <Ellipse Grid.Column="1"
                                         Width="6" Height="6"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"
                                         Fill="Transparent"
                                         Visibility="{Binding IsLive,
                                                              Converter={StaticResource InverseBoolToVis}}"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Name}"
                                           Foreground="{StaticResource Text}"
                                           VerticalAlignment="Center"
                                           FontSize="12"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ════════════════════════════════════════════════════════════
             RIGHT: header + stats + tab content
             ════════════════════════════════════════════════════════════ -->
        <DockPanel Grid.Column="1" Margin="16,0,0,0" LastChildFill="True">

            <!-- ─── Page header ─── -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Style="{StaticResource PageTitle}"
                               Text="🍪  Session &amp; cookies"/>
                    <TextBlock Style="{StaticResource PageSubtitle}"
                               Text="Warmup robot, cookie pool, Chrome import — everything that shapes the profile's identity to websites lives here."/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Content="↻  Reload" Command="{Binding ReloadCommand}"/>
                </StackPanel>
            </Grid>

            <!-- ─── Stat row (4 cards) ───
                 LAST WARMUP / WARMUP STATUS / COOKIE SNAPSHOTS / POOL COOKIES
                 Same shape as the legacy web dashboard top cards. -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LAST WARMUP -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="LAST WARMUP"/>
                        <TextBlock Style="{StaticResource CardValue}"
                                   Text="{Binding LastWarmupValue}"/>
                        <TextBlock Style="{StaticResource CardSubvalue}"
                                   Text="{Binding LastWarmupSubtitle}"/>
                    </StackPanel>
                </Border>

                <!-- WARMUP STATUS -->
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="WARMUP STATUS"/>
                        <TextBlock Style="{StaticResource CardValue}"
                                   Text="{Binding WarmupStatusValue}"
                                   Foreground="{Binding WarmupStatusBrush}"/>
                        <TextBlock Style="{StaticResource CardSubvalue}" Text="—"/>
                    </StackPanel>
                </Border>

                <!-- COOKIE SNAPSHOTS -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="COOKIE SNAPSHOTS"/>
                        <TextBlock Style="{StaticResource CardValue}"
                                   Text="{Binding CookieSnapshotsCount}"/>
                        <TextBlock Style="{StaticResource CardSubvalue}" Text="—"/>
                    </StackPanel>
                </Border>

                <!-- POOL COOKIES -->
                <Border Grid.Column="3" Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="POOL COOKIES"/>
                        <TextBlock Style="{StaticResource CardValue}"
                                   Text="{Binding PoolCookiesCount}"/>
                        <TextBlock Style="{StaticResource CardSubvalue}" Text="—"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ─── Tabs ─── -->
            <TabControl SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0">

                <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                     TAB 1 — Warmup robot
                     ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
                <TabItem Header="🔥  Warmup robot">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="2,12,2,2">

                            <!-- Run-warmup card -->
                            <Border Style="{StaticResource Card}" Padding="16">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Run warmup"
                                                       Foreground="{StaticResource Text}"
                                                       FontSize="14" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource MutedText}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   Text="Launches Chromium with this profile, visits realistic sites, accepts cookie banners, dwells. Takes ~2–5 minutes."/>
                                    </Grid>

                                    <!-- Preset cards — WrapPanel so we
                                         flow into 2 / 3 / 4 columns
                                         depending on available width.
                                         No horizontal scroll: the user
                                         should always see every preset. -->
                                    <TextBlock Style="{StaticResource MutedText}"
                                               Margin="0,14,0,8" Text="Preset"/>
                                    <ItemsControl ItemsSource="{Binding Presets}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource PresetCardStyle}"
                                                        Command="{Binding DataContext.SelectPresetCommand,
                                                                          Source={x:Reference PageRoot}}"
                                                        CommandParameter="{Binding}">
                                                    <StackPanel>
                                                        <!-- Header row: emoji icon + label + sites pill -->
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0"
                                                                       Text="{Binding Icon}"
                                                                       FontSize="18"
                                                                       VerticalAlignment="Top"
                                                                       Margin="0,0,8,0"/>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Label}"
                                                                       Foreground="{StaticResource Text}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="12.5"
                                                                       TextWrapping="Wrap"
                                                                       VerticalAlignment="Center"/>
                                                            <Border Grid.Column="2"
                                                                    Style="{StaticResource SitePill}"
                                                                    VerticalAlignment="Top"
                                                                    Margin="6,2,0,0">
                                                                <TextBlock>
                                                                    <Run Text="{Binding SiteCount, Mode=OneWay}"
                                                                         FontFamily="{StaticResource FontMono}"
                                                                         FontSize="10"
                                                                         Foreground="{Binding AccentBrush}"
                                                                         FontWeight="SemiBold"/>
                                                                    <Run Text=" SITES"
                                                                         FontSize="9"
                                                                         Foreground="{StaticResource TextDim}"/>
                                                                </TextBlock>
                                                            </Border>
                                                        </Grid>
                                                        <!-- Description — clamped to ~3 lines via
                                                             MaxHeight + TextTrimming so cards stay
                                                             a uniform height. -->
                                                        <TextBlock Text="{Binding Description}"
                                                                   Foreground="{StaticResource TextMuted}"
                                                                   FontSize="11"
                                                                   Margin="0,8,0,0"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="WordEllipsis"
                                                                   MaxHeight="68"
                                                                   LineHeight="16"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Site-count + Run button row -->
                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Style="{StaticResource MutedText}"
                                                       Text="Site count"/>
                                            <TextBox Text="{Binding SiteCount, Mode=TwoWay,
                                                                   UpdateSourceTrigger=PropertyChanged}"
                                                     Width="80" Margin="0,4,0,0"
                                                     HorizontalContentAlignment="Center"
                                                     FontFamily="{StaticResource FontMono}"
                                                     FontSize="13"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Bottom"
                                                    Margin="14,0,0,0">
                                            <TextBlock Style="{StaticResource MutedText}"
                                                       FontSize="11" Margin="0,0,0,6"
                                                       Text="How many sites from the preset to visit."/>
                                        </StackPanel>
                                        <!-- IsEnabled state is implicit via the
                                             RunWarmupCommand's CanExecute, which we
                                             keep wide-open and instead branch inside
                                             the handler (running profile → warning
                                             dialog; mid-warmup → cancel toggle). The
                                             button is NEVER hidden so the user
                                             always knows where the action lives. -->
                                        <Button Grid.Column="3"
                                                Content="{Binding RunButtonLabel}"
                                                Command="{Binding RunWarmupCommand}"
                                                MinWidth="180"
                                                Padding="14,8"
                                                Background="{StaticResource Accent}"
                                                Foreground="White"
                                                FontWeight="SemiBold"
                                                BorderBrush="{StaticResource Accent}"
                                                VerticalAlignment="Bottom"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Warmup history -->
                            <Border Style="{StaticResource Card}" Padding="0" Margin="0,14,0,0">
                                <DockPanel LastChildFill="True">
                                    <Grid DockPanel.Dock="Top" Margin="14,12,14,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Foreground="{StaticResource Text}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Text="Warmup history"/>
                                            <TextBlock Style="{StaticResource MutedText}"
                                                       FontSize="11" Margin="0,2,0,0"
                                                       Text="Every past warmup for this profile. Click a row to see per-site details."/>
                                        </StackPanel>
                                    </Grid>

                                    <DataGrid ItemsSource="{Binding WarmupHistory}"
                                              SelectionMode="Single"
                                              AutoGenerateColumns="False"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="None"
                                              RowHeaderWidth="0"
                                              Background="Transparent"
                                              BorderThickness="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="STARTED"
                                                                Binding="{Binding StartedAt,
                                                                                  StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                                                Width="160"
                                                                IsReadOnly="True"/>
                                            <DataGridTextColumn Header="PRESET"
                                                                Binding="{Binding PresetId}"
                                                                Width="140" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="TRIGGER"
                                                                Binding="{Binding Trigger}"
                                                                Width="110" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="SITES"
                                                                Binding="{Binding Sites}"
                                                                Width="80" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="DURATION"
                                                                Binding="{Binding Duration}"
                                                                Width="90" IsReadOnly="True"/>
                                            <DataGridTemplateColumn Header="STATUS" Width="100" IsReadOnly="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Status}"
                                                                   Foreground="{Binding StatusBrush}"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="NOTES"
                                                                Binding="{Binding Notes}"
                                                                Width="*" IsReadOnly="True"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                     TAB 2 — Cookies (per-domain inspector)
                     ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                     Source: latest snapshot for the focused profile.
                     Filter is contains-match across (domain, name).
                     Live CDP read while a profile is running is a
                     Phase 8 candidate — until then this snapshot view
                     covers ≥95% of the actual debugging needs. -->
                <TabItem Header="🍪  Cookies">
                    <Border Style="{StaticResource Card}" Margin="0,12,0,0" Padding="0">
                        <DockPanel LastChildFill="True">
                            <!-- Header row: source label + filter + actions -->
                            <Grid DockPanel.Dock="Top" Margin="14,12,14,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Foreground="{StaticResource Text}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Text="Cookies"/>
                                    <TextBlock Style="{StaticResource MutedText}"
                                               FontSize="11" Margin="0,2,0,0"
                                               Text="{Binding CookiesSourceLabel}"/>
                                </StackPanel>
                                <TextBox Grid.Column="1"
                                         Text="{Binding CookieFilter, Mode=TwoWay,
                                                        UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Filter by domain or name"
                                         VerticalAlignment="Center"
                                         Margin="14,0"/>
                                <Button Grid.Column="2"
                                        Content="⤓  Export JSON"
                                        Command="{Binding ExportCookiesJsonCommand}"
                                        VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Empty state -->
                            <Border Style="{StaticResource Card}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="40"
                                    Visibility="{Binding IsCookiesEmpty,
                                                         Converter={StaticResource BoolToVis}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock FontSize="38" HorizontalAlignment="Center"
                                               Foreground="{StaticResource TextDim}"
                                               Text="🥠"/>
                                    <TextBlock Margin="0,12,0,4" HorizontalAlignment="Center"
                                               Style="{StaticResource PageTitle}" FontSize="15"
                                               Text="No cookies in the latest snapshot"/>
                                    <TextBlock HorizontalAlignment="Center" TextAlignment="Center"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap" MaxWidth="500"
                                               Text="Run a warmup or import from a real Chrome profile to populate this view."/>
                                </StackPanel>
                            </Border>

                            <!-- Grid -->
                            <DataGrid ItemsSource="{Binding CookieRows}"
                                      SelectionMode="Single"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="None"
                                      RowHeaderWidth="0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Visibility="{Binding IsCookiesEmpty,
                                                           Converter={StaticResource InverseBoolToVis}}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="DOMAIN"   Binding="{Binding Domain}"        Width="220" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="NAME"     Binding="{Binding Name}"          Width="170" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="VALUE"    Binding="{Binding ValueDisplay}"  Width="*"   IsReadOnly="True"/>
                                    <DataGridTextColumn Header="PATH"     Binding="{Binding Path}"          Width="80"  IsReadOnly="True"/>
                                    <DataGridCheckBoxColumn Header="🔒"   Binding="{Binding Secure}"        Width="40"  IsReadOnly="True"/>
                                    <DataGridCheckBoxColumn Header="HTTP" Binding="{Binding HttpOnly}"      Width="50"  IsReadOnly="True"/>
                                    <DataGridTextColumn Header="EXPIRES"  Binding="{Binding ExpiryDisplay}" Width="110" IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </TabItem>

                <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                     TAB 3 — Snapshots (port of original SessionsView grid)
                     ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -->
                <TabItem Header="💾  Snapshots">
                    <Grid Margin="0,12,0,0">
                        <Border Style="{StaticResource Card}" Padding="40"
                                Visibility="{Binding IsSnapshotsEmpty,
                                                     Converter={StaticResource BoolToVis}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock FontSize="48" HorizontalAlignment="Center"
                                           Foreground="{StaticResource TextDim}" Text="∅"/>
                                <TextBlock Margin="0,14,0,6" HorizontalAlignment="Center"
                                           Style="{StaticResource PageTitle}" FontSize="16"
                                           Text="No snapshots yet"/>
                                <TextBlock HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           MaxWidth="520"
                                           Text="Run a warmup or let a profile finish a clean run — cookies get auto-saved as a snapshot here."/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Padding="0"
                                Visibility="{Binding IsSnapshotsEmpty,
                                                     Converter={StaticResource InverseBoolToVis}}">
                            <DataGrid ItemsSource="{Binding Snapshots}" SelectionMode="Single">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow"
                                           BasedOn="{StaticResource {x:Type DataGridRow}}">
                                        <Setter Property="ContextMenu" Value="{StaticResource SnapshotRowMenu}"/>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#"        Binding="{Binding Id}"          Width="60"  IsReadOnly="True"/>
                                    <DataGridTextColumn Header="WHEN"     Binding="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="160" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="TRIGGER"  Binding="{Binding Trigger}"     Width="120" IsReadOnly="True"/>
                                    <DataGridTextColumn Header="COOKIES"  Binding="{Binding CookieCount}" Width="80"  IsReadOnly="True"/>
                                    <DataGridTextColumn Header="DOMAINS"  Binding="{Binding DomainCount}" Width="80"  IsReadOnly="True"/>
                                    <DataGridTextColumn Header="BYTES"    Binding="{Binding Bytes}"       Width="80"  IsReadOnly="True"/>
                                    <DataGridTextColumn Header="REASON"   Binding="{Binding Reason}"      Width="*"   IsReadOnly="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                     TAB 4 — Chrome import
                     ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                     Stub: layout is final, action is gated until Phase 7
                     when DPAPI decryption + sensitive-domain filter ship. -->
                <TabItem Header="🌐  Chrome import">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Border Style="{StaticResource Card}" Margin="0,12,0,0" Padding="20">
                            <StackPanel MaxWidth="720">
                                <TextBlock FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource Text}"
                                           Text="Import from a real Chrome / Chromium profile"/>
                                <TextBlock Style="{StaticResource MutedText}"
                                           Margin="0,4,0,16"
                                           TextWrapping="Wrap"
                                           Text="Auto-detects Chrome / Edge / Brave / Chromium / Opera / Vivaldi / Yandex User Data dirs on this machine, decrypts cookies via DPAPI, and saves them as a snapshot for the focused Ghost Shell profile. Sensitive domains (banks, medical, social-auth, mail, password managers) are filtered out by default."/>

                                <!-- Source dropdown -->
                                <TextBlock Style="{StaticResource MutedText}" Text="Source"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding ChromeSources}"
                                              SelectedItem="{Binding SelectedChromeSource, Mode=TwoWay}"
                                              DisplayMemberPath="Display"
                                              ToolTip="Auto-detected Chromium-based browser profiles"/>
                                    <Button Grid.Column="1"
                                            Content="↻  Detect"
                                            Command="{Binding DiscoverChromeSourcesCommand}"
                                            Margin="8,0,0,0"
                                            ToolTip="Re-scan the machine"/>
                                </Grid>
                                <TextBlock Style="{StaticResource DimText}" Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           Text="If the source browser is currently running we copy its DBs to a temp dir before reading. For best results, close the source browser first so cookies aren't rotating mid-read."/>

                                <!-- Options -->
                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource MutedText}"
                                                   Text="History window (days)"/>
                                        <TextBox Text="{Binding ChromeHistoryDays, Mode=TwoWay,
                                                                UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,4,0,0"
                                                 ToolTip="Read URLs visited in the last N days. 0 = no history."/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource MutedText}"
                                                   Text="Max URLs"/>
                                        <TextBox Text="{Binding ChromeMaxUrls, Mode=TwoWay,
                                                                UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,4,0,0"
                                                 ToolTip="Cap on the number of history rows. Internal hard cap 10000."/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,16,0,0">
                                    <CheckBox Content="Import cookies (DPAPI-decrypt)"
                                              IsChecked="{Binding ChromeImportCookies, Mode=TwoWay}"
                                              Margin="0,0,0,6"/>
                                    <CheckBox Content="Skip sensitive domains (banking / medical / social-auth / mail / password managers)"
                                              IsChecked="{Binding ChromeSkipSensitive, Mode=TwoWay}"/>
                                </StackPanel>

                                <!-- Action row -->
                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding ChromeImportStatus}"
                                               Foreground="{StaticResource TextMuted}"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"/>
                                    <Button Grid.Column="1"
                                            Content="▶  Run import"
                                            Command="{Binding RunChromeImportCommand}"
                                            IsEnabled="{Binding CanRunChromeImport}"
                                            Padding="14,8"
                                            MinWidth="160"
                                            Background="{StaticResource Accent}"
                                            Foreground="White"
                                            BorderBrush="{StaticResource Accent}"
                                            FontWeight="SemiBold"/>
                                </Grid>

                                <Border Background="{StaticResource InfoSoftBrush}"
                                        BorderBrush="{StaticResource InfoBrush}"
                                        BorderThickness="1" CornerRadius="4"
                                        Padding="10" Margin="0,18,0,0">
                                    <TextBlock Foreground="{StaticResource InfoBrush}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Text="The import writes a snapshot — you'll see it appear under the Snapshots tab. Cookies auto-restore on the focused profile's NEXT launch. History rows are recorded informationally (replay is a Phase 8 candidate)."/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </DockPanel>
    </Grid>
</UserControl>
