  Phase 27 — Extensions library page. Lists installed extensions with
  enable toggle, source badge, version, and uninstall action. Toolbar
  has a "+ Install" button that opens the four-tab install dialog.
-->
<UserControl x:Class="GhostShell.App.Views.ExtensionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
             d:DataContext="{d:DesignInstance vm:ExtensionsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BgBase}">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="Auto"/>  <!-- search -->
            <RowDefinition Height="*"/>     <!-- list -->
        </Grid.RowDefinitions>

        <!-- ─── Header ─── -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource PageTitle}"
                           Text="🧩  Extensions"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="+  Install"
                            Command="{Binding InstallCommand}"
                            Style="{StaticResource ButtonPrimary}"
                            MinWidth="120"/>
                </WrapPanel>
            </Grid>
            <Border Grid.Row="1" Style="{StaticResource Card}"
                    Padding="14,10" Margin="0,12,0,0">
                <TextBlock Style="{StaticResource PageSubtitle}"
                           TextWrapping="Wrap"
                           Text="Chrome extensions loaded into every profile by default. Toggle the global default with the row switch, or override per-profile from the profile editor's Extensions tab."/>
            </Border>
        </Grid>

        <!-- ─── Search ─── -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14,10" Margin="0,0,0,8">
            <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Filter by name, description, or author"/>
        </Border>

        <!-- ─── List ─── -->
        <Grid Grid.Row="2">
            <!-- Empty state -->
            <Border Style="{StaticResource Card}" Padding="40"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock FontSize="44" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextDim}" Text="🧩"/>
                    <TextBlock Margin="0,10,0,6" HorizontalAlignment="Center"
                               Style="{StaticResource PageTitle}" FontSize="16"
                               Text="No extensions yet"/>
                    <TextBlock HorizontalAlignment="Center"
                               Style="{StaticResource MutedText}"
                               Margin="0,0,0,16"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               MaxWidth="420"
                               Text="Install from a .zip / .crx file, an unpacked folder, or pick from the curated store catalog."/>
                    <Button Content="+  Install first extension"
                            Command="{Binding InstallCommand}"
                            Style="{StaticResource ButtonPrimary}"
                            MinWidth="220"
                            HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding Items}"
                          Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVis}}">
                <ItemsControl.Template>
                    <ControlTemplate TargetType="ItemsControl">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </ControlTemplate>
                </ItemsControl.Template>
                <!-- Tile layout: WrapPanel so cards reflow to the next
                     row at narrow widths. Each card is a fixed 380px so
                     the wrap is predictable; height auto-fits the
                     description. -->
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Card with a 4-px coloured stripe on the left.
                             AccentBrushKey hashes the extension id to one
                             of 8 theme hues so the wall reads as a colour
                             map and each extension keeps a stable colour. -->
                        <Border Width="380" Margin="0,0,12,12"
                                Background="{StaticResource BgRaised}"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>   <!-- accent stripe -->
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Background="{Binding AccentBrushKey, Converter={StaticResource ResourceKeyToBrush}}"
                                        CornerRadius="6,0,0,6"/>
                                <Grid Grid.Column="1" Margin="14,12,14,12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/> <!-- icon + name + toggle -->
                                        <RowDefinition Height="Auto"/> <!-- meta strip -->
                                        <RowDefinition Height="Auto"/> <!-- description -->
                                        <RowDefinition Height="Auto"/> <!-- actions -->
                                    </Grid.RowDefinitions>

                                    <!-- Row 0: icon + name + toggle -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Real icon if present, else 🧩 fallback -->
                                        <Border Grid.Column="0"
                                                Width="36" Height="36"
                                                Background="{StaticResource BgDeep}"
                                                CornerRadius="6"
                                                Margin="0,0,10,0">
                                            <Grid>
                                                <TextBlock Text="🧩" FontSize="20"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Visibility="{Binding HasIcon, Converter={StaticResource InverseBoolToVis}}"/>
                                                <Image Source="{Binding IconPath}"
                                                       Width="24" Height="24"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding HasIcon, Converter={StaticResource BoolToVis}}"
                                                       Stretch="Uniform"/>
                                            </Grid>
                                        </Border>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Text}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <CheckBox Grid.Column="2"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  IsChecked="{Binding Enabled, Mode=OneWay}"
                                                  Command="{Binding DataContext.ToggleEnabledCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"
                                                  ToolTip="Flip the global default for this extension. Per-profile overrides live in the profile editor."
                                                  VerticalAlignment="Center"/>
                                    </Grid>

                                    <!-- Row 1: version + source -->
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding Version}"
                                                   FontFamily="{StaticResource FontMono}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextMuted}"
                                                   VerticalAlignment="Center"/>
                                        <Border Margin="8,0,0,0"
                                                Padding="6,1"
                                                CornerRadius="3"
                                                Background="{StaticResource BgDeep}"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SourceLabel}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextMuted}"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Row 2: description -->
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding Description}"
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"
                                               MaxHeight="60"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- Row 3: trash button -->
                                    <StackPanel Grid.Row="3" Orientation="Horizontal"
                                                HorizontalAlignment="Right" Margin="0,10,0,0">
                                        <Button Content="🗑  Remove"
                                                Command="{Binding DataContext.UninstallCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="Uninstall + remove unpacked dir."/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
