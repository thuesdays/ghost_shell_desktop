<UserControl x:Class="GhostShell.App.Views.ProfilesView"
             x:Name="PageRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
             xmlns:common="clr-namespace:GhostShell.App.Common"
             d:DataContext="{d:DesignInstance Type=vm:ProfilesViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Row context menu — shared between cards and table.
             ContextMenu lives in a separate visual tree so plain
             bindings see the row's DataContext (a ProfileRowVm)
             rather than the page VM. We pin DataContext to PageRoot
             via x:Reference, then grab the row via
             PlacementTarget.DataContext for CommandParameter. -->
        <ContextMenu x:Key="ProfileRowMenu"
                     DataContext="{Binding DataContext, Source={x:Reference PageRoot}}">
            <MenuItem Header="Start"
                      Command="{Binding StartCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
            <MenuItem Header="Stop"
                      Command="{Binding StopCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
            <Separator/>
            <MenuItem Header="Edit…"
                      Command="{Binding EditCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
            <MenuItem Header="Delete"
                      Command="{Binding DeleteCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
        </ContextMenu>

        <!-- ════════════════════════════════════════════════════════
             CARD TEMPLATE — used by the cards-mode ItemsControl.
             Mirrors the legacy web's .profile-card layout: top-left
             checkbox, top-right status pill, header (icon+name),
             meta (template+last-run), 2-up stats, action strip.
             ════════════════════════════════════════════════════════ -->
        <DataTemplate x:Key="ProfileCardTemplate" DataType="{x:Type vm:ProfileRowVm}">
            <!-- Outer wrapper carries the colored left-stripe; the
                 inner Border holds the actual card chrome. The stripe
                 hue comes from AccentBrushKey (per-template / per-name
                 hash) so the cards read as a colour map at a glance. -->
            <!-- Phase 71f — compact card redesign. User asked to drop the
                 FP-regenerate button + PROXY tile, and to make cards
                 denser. Card height shrinks from ~170 to ~110, the
                 2-up stats grid collapses into an inline meta row,
                 and the action strip becomes a single full-width
                 Start with a small ✎ Edit on the right.
                 MinWidth removed — UniformGrid drives sizing so all
                 cards in a row land at the same width regardless of
                 profile-name length. -->
            <Grid Margin="0,0,10,10" MinHeight="112" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left accent stripe — slimmer (3px) and full-height -->
                <Border Grid.Column="0"
                        CornerRadius="8,0,0,8"
                        Background="{Binding AccentBrushKey,
                                             Converter={StaticResource ResourceKeyToBrush}}"/>

                <Border Grid.Column="1"
                        Background="{StaticResource BgRaised}"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1"
                        CornerRadius="0,8,8,0"
                        Padding="12,10,12,10"
                        ContextMenu="{StaticResource ProfileRowMenu}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{StaticResource BgRaised}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource OkBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header row: checkbox + name + status pill -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0"
                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   Foreground="{StaticResource Text}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- Phase 71w — proper status chip.
                             Old design rendered a single em-dash ("—")
                             centred in a 21-px pill, which read as
                             "stretched icon" rather than "status".
                             New design = Ellipse dot + text, padded
                             to a comfortable 9,4 inside an 11-radius
                             pill. Colour palette flips by status:
                                 idle      → muted gray (no pulse)
                                 ready     → info blue
                                 starting  → accent
                                 running   → ok green
                                 not-ready → warn amber
                             so the chip is the visual focal point of
                             the card's top row. -->
                        <Border Grid.Column="2" VerticalAlignment="Center"
                                Padding="9,4"
                                CornerRadius="11" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background"  Value="{StaticResource BgRaised}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Background"  Value="{StaticResource OkSoftBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource OkBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsStarting}" Value="True">
                                            <Setter Property="Background"  Value="{StaticResource AccentSoft}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsReady}" Value="True">
                                            <Setter Property="Background"  Value="{StaticResource InfoSoftBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource InfoBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsNotReady}" Value="True">
                                            <Setter Property="Background"  Value="{StaticResource WarnSoftBrush}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource WarnBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Status dot — colour flips with the
                                     same DataTriggers as the pill. -->
                                <Ellipse Width="7" Height="7"
                                         Margin="0,0,6,0"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource TextDim}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource OkBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsStarting}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource Accent}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsReady}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource InfoBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsNotReady}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource WarnBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding StatusText}"
                                           VerticalAlignment="Center"
                                           FontSize="10"
                                           FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource OkBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsStarting}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsReady}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource InfoBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsNotReady}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource WarnBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Phase 71f — single compact meta line replacing the
                         old "template + last-run" row + 2-up stats grid.
                         Layout: [⏱ N runs]  [📅 last 2h ago]  [⚙ template].
                         Margin top=10 gives the name some breathing room
                         (user feedback: "отступ от имени профиля
                         небольшой"). All segments share FontSize=11 +
                         identical Segoe MDL2 icon size so the icons line
                         up vertically across cards in the same row. -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource MutedText}" FontSize="11">
                            <Run FontFamily="Segoe MDL2 Assets" FontSize="11" BaselineAlignment="Center" Text="&#xE916;"/>
                            <Run Text="  "/>
                            <Run Text="{Binding RunCount, Mode=OneWay}"
                                 Foreground="{StaticResource Text}"
                                 FontFamily="{StaticResource FontMono}"/>
                            <Run Text=" runs"/>
                        </TextBlock>
                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource MutedText}" FontSize="11"
                                   Margin="14,0,0,0">
                            <Run FontFamily="Segoe MDL2 Assets" FontSize="11" BaselineAlignment="Center" Text="&#xE787;"/>
                            <Run Text="  "/>
                            <Run Text="{Binding LastRunHuman, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock VerticalAlignment="Center"
                                   Style="{StaticResource MutedText}" FontSize="11"
                                   Margin="14,0,0,0"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding TemplateId}">
                            <Run FontFamily="Segoe MDL2 Assets" FontSize="11" BaselineAlignment="Center" Text="&#xE713;"/>
                            <Run Text="  "/>
                            <Run Text="{Binding TemplateId, Mode=OneWay, FallbackValue='auto'}"
                                 FontFamily="{StaticResource FontMono}"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Spacer row 2 — empty; keeps the action strip
                         pinned to the bottom while the card grows. -->

                    <!-- Phase 71s — slimmer action strip.
                         User feedback: Start was too wide (full row).
                         Now: spacer (*) absorbs slack, then Auto-sized
                         Start (lime green, ~92 px) and Edit (36 px
                         icon) sit flush right. Visually punchier:
                         green = "go" CTA, low-key edit beside it. -->
                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Start (idle) — lime green ButtonOk -->
                        <Button Grid.Column="1" Margin="0,0,6,0"
                                Style="{StaticResource ButtonOk}"
                                MinWidth="92"
                                Padding="12,6"
                                Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolToVis}}"
                                Command="{Binding DataContext.StartCommand,
                                          Source={x:Reference PageRoot}}"
                                CommandParameter="{Binding}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Text="&#xE768;" Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Start" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- Stop (running) — same column slot, red danger -->
                        <Button Grid.Column="1" Margin="0,0,6,0"
                                Style="{StaticResource ButtonDanger}"
                                MinWidth="92"
                                Padding="12,6"
                                Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"
                                Command="{Binding DataContext.StopCommand,
                                          Source={x:Reference PageRoot}}"
                                CommandParameter="{Binding}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11"
                                           Text="&#xE71A;" Margin="0,0,6,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="Stop" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- Edit — icon-only on a 36-px compact button -->
                        <Button Grid.Column="2"
                                Command="{Binding DataContext.EditCommand,
                                          Source={x:Reference PageRoot}}"
                                CommandParameter="{Binding}"
                                ToolTip="Edit profile"
                                MinWidth="36" Padding="8,0">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Text="&#xE70F;" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <!-- Phase 71s — busy overlay is now hosted by MainWindow at the
         window level so the blur covers the sidebar too. The page
         only owns its own content tree. -->
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header     -->
            <RowDefinition Height="Auto"/>  <!-- bulk strip -->
            <RowDefinition Height="*"/>     <!-- content    -->
        </Grid.RowDefinitions>

        <!-- Header + toolbar — title/buttons on row 0, subtitle wraps
             full width on row 1 so the description stays readable at
             narrow window sizes. -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource PageTitle}"
                           Text="Profiles"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Cards / Table segmented toggle. Active state uses
                     the Accent background tint so it reads clearly. -->
                <Border Background="{StaticResource BgDeep}"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding SetViewModeCardsCommand}"
                                Padding="10,4" BorderThickness="0"
                                MinWidth="78"
                                ToolTip="Cards view">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCardsMode}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentSoft}"/>
                                            <Setter Property="Foreground" Value="{StaticResource Text}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▦" Margin="0,0,5,0"/>
                                <TextBlock Text="Cards"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SetViewModeTableCommand}"
                                Padding="10,4" BorderThickness="0"
                                MinWidth="78"
                                ToolTip="Table view">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTableMode}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentSoft}"/>
                                            <Setter Property="Foreground" Value="{StaticResource Text}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="☰" Margin="0,0,5,0"/>
                                <TextBlock Text="Table"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Button Content="⚡  Bulk create"
                        Command="{Binding BulkAddCommand}"
                        Margin="0,0,8,0"
                        MinWidth="120"/>
                <Button Content="+  Add profile"
                        Command="{Binding AddCommand}"
                        Style="{StaticResource ButtonPrimary}"
                        MinWidth="120"/>
            </StackPanel>
            </Grid>
            <Border Grid.Row="1" Style="{StaticResource Card}"
                    Padding="14,10" Margin="0,12,0,0">
                <TextBlock Style="{StaticResource PageSubtitle}"
                           TextWrapping="Wrap"
                           Text="Browser identities — create, start, inspect, manage. Tick rows to start or delete in bulk."/>
            </Border>
        </Grid>

        <!-- Bulk-action strip — visible only when at least one row is checked.
             Mirrors the web's "selection bar" that appears once you tick a row. -->
        <Border Grid.Row="1" Margin="0,0,0,8" Padding="14,8" CornerRadius="6"
                Background="{StaticResource AccentSoft}"
                BorderBrush="{StaticResource Accent}"
                BorderThickness="1"
                Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="{StaticResource Text}" FontWeight="SemiBold">
                        <Run Text="{Binding SelectedCount, Mode=OneWay}"/>
                        <Run Text=" selected"/>
                    </TextBlock>
                    <Button Content="Select all"
                            Command="{Binding SelectAllCommand}"
                            Style="{StaticResource ButtonGhost}"
                            Margin="14,0,0,0"/>
                    <Button Content="Clear"
                            Command="{Binding ClearSelectionCommand}"
                            Style="{StaticResource ButtonGhost}"
                            Margin="6,0,0,0"/>
                </StackPanel>
                <!-- Phase 71t — trimmed bulk strip: only Delete + Start.
                     Test-proxies and Self-check moved off the strip
                     (still available from the row context menu) so the
                     primary path is just "select rows → start" or
                     "select rows → delete". Delete uses the muted-red
                     ButtonDangerSoft so the user doesn't reflexively
                     click it; Start (lime) is the visual CTA. -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="🗑  Delete"
                            Command="{Binding BulkDeleteCommand}"
                            Style="{StaticResource ButtonDangerSoft}"
                            Margin="0,0,8,0"
                            ToolTip="Permanently delete the selected profiles (with confirmation)"/>
                    <Button Content="▶  Start (staggered)"
                            Command="{Binding BulkStartCommand}"
                            Style="{StaticResource ButtonOk}"
                            ToolTip="Phase 64 — pick stagger seconds + concurrency cap, then enqueue to the run queue"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2">
            <!-- Empty-state -->
            <Border Style="{StaticResource Card}" Padding="40"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock FontSize="32" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextDim}" Text="∅"/>
                    <TextBlock Margin="0,10,0,4" HorizontalAlignment="Center"
                               Style="{StaticResource PageTitle}" FontSize="14"
                               Text="No profiles yet"/>
                    <TextBlock HorizontalAlignment="Center" Style="{StaticResource MutedText}"
                               Margin="0,0,0,16"
                               Text="Create one or generate many at once with Bulk create."/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="⚡  Bulk create"
                                Command="{Binding BulkAddCommand}"
                                Margin="0,0,8,0"
                                MinWidth="140"/>
                        <Button Content="+  Add profile"
                                Command="{Binding AddCommand}"
                                Style="{StaticResource ButtonPrimary}"
                                MinWidth="140"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ─── Cards mode ─── -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsCardsMode}" Value="True"/>
                                    <Condition Binding="{Binding IsEmpty}"     Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding Items}"
                              ItemTemplate="{StaticResource ProfileCardTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- Phase 71f — UniformGrid with fixed 3
                                 columns instead of WrapPanel. The old
                                 WrapPanel sized each card to its
                                 content, so a long email pushed the
                                 card wider than its neighbours and the
                                 grid looked ragged. UniformGrid gives
                                 each cell the same width so all cards
                                 in a row are aligned + cards stretch
                                 to fill the available row width. -->
                            <UniformGrid Columns="3"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <!-- Phase 71f — stretch each card container to its
                         UniformGrid cell. Without this each ContentPresenter
                         hugs its content's MinWidth and leaves gaps. -->
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </ScrollViewer>

            <!-- ─── Table mode ─── -->
            <!-- Note on Style: WPF refuses to set the same DP twice in
                 one element, so the inline `Style="{StaticResource Card}"`
                 attribute can't coexist with a `<Border.Style>` child
                 block. We move the BasedOn into the inline block and
                 drop the attribute. -->
            <Border Padding="0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource Card}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsTableMode}" Value="True"/>
                                    <Condition Binding="{Binding IsEmpty}"     Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DataGrid ItemsSource="{Binding Items}"
                          SelectionMode="Single">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow"
                               BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="ContextMenu" Value="{StaticResource ProfileRowMenu}"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <!-- Bulk-select checkbox column. Template column
                             instead of DataGridCheckBoxColumn so a single
                             click toggles (no enter-edit-mode tap).
                             Phase 71t — header now hosts a tri-state
                             "select all / none" checkbox bound to
                             VM.IsAllSelected (mirrors the Vault grid
                             pattern). Lifted up to 44 px so the bigger
                             header doesn't crowd the checkbox. -->
                        <DataGridTemplateColumn Width="44" IsReadOnly="True"
                                                CanUserSort="False" CanUserReorder="False">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding DataContext.IsAllSelected,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid},
                                                          Mode=TwoWay}"
                                              IsThreeState="True"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ToolTip="Select all / none"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay,
                                                          UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Status pulse: small green dot when the profile
                             is currently running. -->
                        <DataGridTemplateColumn Header="" Width="22" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Ellipse Width="8" Height="8"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Fill="{StaticResource OkBrush}"
                                             Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="NAME"     Binding="{Binding Name}"       Width="*"   IsReadOnly="True"/>
                        <DataGridTextColumn Header="GROUP"    Binding="{Binding GroupName}"  Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="TEMPLATE" Binding="{Binding TemplateId}" Width="160" IsReadOnly="True"/>
                        <DataGridTextColumn Header="PROXY"    Binding="{Binding ProxySlug}"  Width="140" IsReadOnly="True"/>
                        <DataGridTextColumn Header="RUNS"     Binding="{Binding RunCount}"   Width="60"  IsReadOnly="True"/>
                        <DataGridTextColumn Header="LAST RUN"
                                            Binding="{Binding LastRunAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                            Width="140" IsReadOnly="True"/>

                        <!-- Actions: Start / Starting / Stop / Edit / Delete -->
                        <DataGridTemplateColumn Header="" Width="180" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <Button ToolTip="Start profile"
                                                CommandParameter="{Binding}"
                                                Command="{Binding DataContext.StartCommand,
                                                          Source={x:Reference PageRoot}}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource RowActionButton}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsStarting}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Style="{StaticResource RowActionIcon}"
                                                       FontSize="15"
                                                       Foreground="{StaticResource OkBrush}"
                                                       Text="&#xE768;"/>
                                        </Button>

                                        <Border Padding="6,4"
                                                CornerRadius="4"
                                                Margin="2,0"
                                                Background="{StaticResource AccentSoft}"
                                                Visibility="{Binding IsStarting, Converter={StaticResource BoolToVis}}">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Control Style="{StaticResource Spinner}"
                                                         Foreground="{StaticResource Accent}"/>
                                                <TextBlock Text="Starting…"
                                                           Foreground="{StaticResource Accent}"
                                                           VerticalAlignment="Center"
                                                           Margin="6,0,2,0"
                                                           FontSize="11"/>
                                            </StackPanel>
                                        </Border>

                                        <Button Style="{StaticResource RowActionDanger}"
                                                ToolTip="Stop profile"
                                                Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding DataContext.StopCommand,
                                                          Source={x:Reference PageRoot}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Style="{StaticResource RowActionIcon}"
                                                       FontSize="15"
                                                       Foreground="{StaticResource ErrBrush}"
                                                       Text="&#xE71A;"/>
                                        </Button>
                                        <Button Style="{StaticResource RowActionButton}"
                                                ToolTip="Edit"
                                                Command="{Binding DataContext.EditCommand,
                                                          Source={x:Reference PageRoot}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Style="{StaticResource RowActionIcon}" FontSize="14" Text="&#xE70F;"/>
                                        </Button>
                                        <Button Style="{StaticResource RowActionDanger}"
                                                ToolTip="Delete"
                                                Command="{Binding DataContext.DeleteCommand,
                                                          Source={x:Reference PageRoot}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Style="{StaticResource RowActionIcon}" FontSize="14" Text="&#xE74D;"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
