<UserControl x:Class="GhostShell.App.Views.SchedulerView"
             x:Name="PageRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:SchedulerViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <ContextMenu x:Key="ScheduleRowMenu"
                     DataContext="{Binding DataContext, Source={x:Reference PageRoot}}">
            <MenuItem Header="Run now"
                      Command="{Binding RunNowCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
            <MenuItem Header="Toggle enabled / paused"
                      Command="{Binding ToggleEnabledCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
            <Separator/>
            <MenuItem Header="Edit…"
                      Command="{Binding EditCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
            <MenuItem Header="Delete"
                      Command="{Binding DeleteCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
        </ContextMenu>
    </UserControl.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header — title/buttons share row 0, subtitle wraps full
             width on row 1 so it stays readable at narrow window sizes. -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource PageTitle}"
                           Text="Scheduler"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="+  New schedule"
                            Command="{Binding AddCommand}"
                            Style="{StaticResource ButtonPrimary}"
                            MinWidth="140"/>
                </WrapPanel>
            </Grid>
            <Border Grid.Row="1" Style="{StaticResource Card}"
                    Padding="14,10" Margin="0,12,0,0">
                <TextBlock Style="{StaticResource PageSubtitle}"
                           TextWrapping="Wrap"
                           Text="Cron / interval triggers fire profile or group runs automatically. The runner enforces the parallelism cap; paused rows are skipped."/>
            </Border>
        </Grid>

        <!-- Stats strip -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14,10" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Margin="0,0,22,0">
                    <TextBlock FontFamily="{StaticResource FontMono}" FontSize="16"
                               Foreground="{StaticResource Text}"
                               Text="{Binding Items.Count, Mode=OneWay}"/>
                    <TextBlock Margin="6,0,0,0" Style="{StaticResource MutedText}"
                               VerticalAlignment="Center" Text="total"/>
                </StackPanel>
                <TextBlock Foreground="{StaticResource TextDim}" Text="·" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,22,0">
                    <TextBlock FontFamily="{StaticResource FontMono}" FontSize="16"
                               Foreground="{StaticResource OkBrush}"
                               Text="{Binding EnabledCount, Mode=OneWay}"/>
                    <TextBlock Margin="6,0,0,0" Style="{StaticResource MutedText}"
                               VerticalAlignment="Center" Text="enabled"/>
                </StackPanel>
                <TextBlock Foreground="{StaticResource TextDim}" Text="·" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource FontMono}" FontSize="16"
                               Foreground="{StaticResource WarnBrush}"
                               Text="{Binding DisabledCount, Mode=OneWay}"/>
                    <TextBlock Margin="6,0,0,0" Style="{StaticResource MutedText}"
                               VerticalAlignment="Center" Text="paused"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2">
            <Border Style="{StaticResource Card}" Padding="40"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock FontSize="48" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextDim}" Text="🕰"/>
                    <TextBlock Margin="0,14,0,6" HorizontalAlignment="Center"
                               Style="{StaticResource PageTitle}" FontSize="16"
                               Text="No schedules yet"/>
                    <TextBlock HorizontalAlignment="Center" Style="{StaticResource MutedText}"
                               Margin="0,0,0,16"
                               Text="Create your first schedule to fire a profile or group on a cron / interval trigger."/>
                    <Button Content="+  New schedule"
                            Command="{Binding AddCommand}"
                            Style="{StaticResource ButtonPrimary}"
                            HorizontalAlignment="Center"
                            MinWidth="160"/>
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVis}}">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ScheduleRowVm}">
                            <Border Margin="0,0,12,12"
                                    Background="{StaticResource BgRaised}"
                                    BorderBrush="{StaticResource Border}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16"
                                    MinWidth="340"
                                    MinHeight="200"
                                    ContextMenu="{StaticResource ScheduleRowMenu}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"  Value="{StaticResource BgRaised}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Enabled}" Value="False">
                                                <Setter Property="Opacity" Value="0.62"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header: name + status pill -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="🕰"
                                                       FontSize="16"
                                                       Foreground="{StaticResource HueAmber}"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource Text}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Padding="8,2"
                                                CornerRadius="10" BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background"  Value="{StaticResource WarnSoftBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource WarnBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                            <Setter Property="Background"  Value="{StaticResource OkSoftBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource OkBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding EnabledLabel}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource PillText}">
                                                        <Setter Property="Foreground" Value="{StaticResource WarnBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Enabled}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource OkBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>

                                    <!-- Target line -->
                                    <TextBlock Grid.Row="1" Margin="0,8,0,0"
                                               Style="{StaticResource MutedText}"
                                               FontFamily="{StaticResource FontMono}"
                                               FontSize="12"
                                               Text="{Binding TargetLabel}"
                                               TextTrimming="CharacterEllipsis"/>

                                    <!-- Trigger summary -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Foreground="{StaticResource Accent}"
                                                   FontFamily="{StaticResource FontMono}"
                                                   FontSize="12"
                                                   Text="{Binding TriggerSummary}"/>
                                    </StackPanel>

                                    <!-- Active window -->
                                    <TextBlock Grid.Row="3" Margin="0,4,0,0"
                                               Style="{StaticResource MutedText}"
                                               FontSize="11"
                                               Text="{Binding ActiveSummary}"/>

                                    <!-- Stats row -->
                                    <Grid Grid.Row="4" Margin="0,12,0,0" VerticalAlignment="Bottom">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="{StaticResource BgDeep}"
                                                CornerRadius="6" Padding="8,6" Margin="0,0,4,0">
                                            <StackPanel>
                                                <TextBlock Text="NEXT FIRE" Style="{StaticResource MutedText}" FontSize="9"/>
                                                <TextBlock Text="{Binding Countdown}"
                                                           Foreground="{StaticResource Text}"
                                                           FontFamily="{StaticResource FontMono}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Background="{StaticResource BgDeep}"
                                                CornerRadius="6" Padding="8,6" Margin="2,0,2,0">
                                            <StackPanel>
                                                <TextBlock Text="LAST FIRED" Style="{StaticResource MutedText}" FontSize="9"/>
                                                <TextBlock Text="{Binding LastFiredHuman}"
                                                           Foreground="{StaticResource Text}"
                                                           FontFamily="{StaticResource FontMono}"
                                                           FontSize="13"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="2" Background="{StaticResource BgDeep}"
                                                CornerRadius="6" Padding="8,6" Margin="4,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="FIRES / FAILS" Style="{StaticResource MutedText}" FontSize="9"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding FireCount}"
                                                               Foreground="{StaticResource OkBrush}"
                                                               FontFamily="{StaticResource FontMono}"
                                                               FontSize="13" FontWeight="SemiBold"/>
                                                    <TextBlock Text=" / "
                                                               Style="{StaticResource MutedText}"
                                                               FontFamily="{StaticResource FontMono}" FontSize="13"/>
                                                    <TextBlock Text="{Binding FailCount}"
                                                               Foreground="{StaticResource ErrBrush}"
                                                               FontFamily="{StaticResource FontMono}"
                                                               FontSize="13" FontWeight="SemiBold"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Actions -->
                                    <Grid Grid.Row="5" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Margin="0,0,4,0"
                                                Style="{StaticResource ButtonPrimary}"
                                                Command="{Binding DataContext.RunNowCommand,
                                                          Source={x:Reference PageRoot}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                           Text="&#xE768;" Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="Run now" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Margin="2,0,2,0"
                                                Style="{StaticResource RowActionButton}"
                                                ToolTip="Toggle enabled / paused"
                                                Command="{Binding DataContext.ToggleEnabledCommand,
                                                          Source={x:Reference PageRoot}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Style="{StaticResource RowActionIcon}" FontSize="14"
                                                       Text="&#xE769;"/>
                                        </Button>
                                        <Button Grid.Column="2" Margin="2,0,2,0"
                                                Style="{StaticResource RowActionButton}"
                                                ToolTip="Edit"
                                                Command="{Binding DataContext.EditCommand,
                                                          Source={x:Reference PageRoot}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Style="{StaticResource RowActionIcon}" FontSize="14"
                                                       Text="&#xE70F;"/>
                                        </Button>
                                        <Button Grid.Column="3"
                                                Style="{StaticResource RowActionDanger}"
                                                ToolTip="Delete"
                                                Command="{Binding DataContext.DeleteCommand,
                                                          Source={x:Reference PageRoot}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Style="{StaticResource RowActionIcon}" FontSize="14"
                                                       Foreground="{StaticResource ErrBrush}"
                                                       Text="&#xE74D;"/>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
