<UserControl x:Class="GhostShell.App.Views.LogsView"
             x:Name="PageRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
             xmlns:m="clr-namespace:GhostShell.Core.Models;assembly=GhostShell.Core"
             d:DataContext="{d:DesignInstance Type=vm:LogsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header        -->
            <RowDefinition Height="Auto"/>  <!-- run context   -->
            <RowDefinition Height="Auto"/>  <!-- filter row    -->
            <RowDefinition Height="Auto"/>  <!-- chips strip   -->
            <RowDefinition Height="*"/>     <!-- log list      -->
            <RowDefinition Height="Auto"/>  <!-- footer        -->
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <!-- Title flips to "Logs for run #N" when the page is
                     pinned to a run via Runs → View logs. Subtitle
                     follows. Triggers live in the Style block — the
                     attribute-form Text="…" can't coexist with a
                     Style.Triggers child. -->
                <TextBlock Style="{StaticResource PageTitle}"
                           Text="{Binding PageTitle}"/>
                <TextBlock Style="{StaticResource PageSubtitle}"
                           Text="{Binding PageSubtitle}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <!-- Pause/Resume toggle. We expose it as two distinct
                     buttons swapped via visibility so the icon + label
                     read clearly at a glance. -->
                <Button Command="{Binding TogglePauseCommand}"
                        Margin="0,0,4,0"
                        ToolTip="Pause / resume tail"
                        Visibility="{Binding IsPaused, Converter={StaticResource InverseBoolToVis}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Text="&#xE769;" Margin="0,0,6,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Pause" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding TogglePauseCommand}"
                        Margin="0,0,4,0"
                        ToolTip="Resume tail"
                        Style="{StaticResource ButtonPrimary}"
                        Visibility="{Binding IsPaused, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Text="&#xE768;" Margin="0,0,6,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="Resume" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Content="📋  Copy"     Command="{Binding CopyCommand}"     Margin="0,0,4,0"
                        ToolTip="Copy visible entries to clipboard"/>
                <Button Content="⬇  Download" Command="{Binding DownloadCommand}" Margin="0,0,4,0"
                        ToolTip="Save the filtered view to a file you pick"/>
                <Button Content="✕  Clear"   Command="{Binding ClearCommand}"
                        ToolTip="Clear the on-screen buffer (raw log file is untouched)"/>
            </StackPanel>
        </Grid>

        <!-- Run-context banner — visible only when the page was
             opened from a Runs row's "View logs" action. Mirrors the
             web's "Logs for run #5 — Switch to live" header strip:
             a single accent-coloured pill explains the scope and
             provides a one-click escape back to the unfiltered tail. -->
        <Border Grid.Row="1" Style="{StaticResource InfoBannerAccent}" Margin="0,0,0,8"
                Visibility="{Binding HasRunContext, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Style="{StaticResource InfoBannerTitle}">
                        <Run Text="Showing logs for "/>
                        <Run Text="run #" Foreground="{StaticResource TextMuted}"/>
                        <Run Text="{Binding RunContextId, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text="  ·  "/>
                        <Run Text="{Binding RunContextProfile, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource InfoBannerBody}">
                        <Run Text="Started "/>
                        <Run Text="{Binding RunContextStartedAt, Mode=OneWay, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"/>
                    </TextBlock>
                </StackPanel>
                <Button Grid.Column="1" VerticalAlignment="Center"
                        Command="{Binding ClearRunContextCommand}"
                        Style="{StaticResource ButtonGhost}"
                        ToolTip="Switch back to the full live tail">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✕" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Switch to live tail" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Filter row. Compact (Padding=6,4) so the toolbar feels
             tight instead of taking up a third of the page. Each
             control reuses the global TextBox / ComboBox theme;
             the regex-error indicator below uses BasedOn so it
             doesn't replace the global style with the white default. -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="6,4" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- level    -->
                    <ColumnDefinition Width="Auto"/>  <!-- time     -->
                    <ColumnDefinition Width="Auto"/>  <!-- source   -->
                    <ColumnDefinition Width="Auto"/>  <!-- profile  -->
                    <ColumnDefinition Width="*"/>     <!-- search   -->
                    <ColumnDefinition Width="Auto"/>  <!-- regex    -->
                    <ColumnDefinition Width="Auto"/>  <!-- autoscr. -->
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0" Margin="0,0,6,0" MinWidth="110" Height="26"
                          ItemsSource="{Binding LevelOptions}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Value"
                          SelectedValue="{Binding LevelFilter, Mode=TwoWay}"
                          ToolTip="Minimum level"/>

                <ComboBox Grid.Column="1" Margin="0,0,6,0" MinWidth="100" Height="26"
                          ItemsSource="{Binding TimeRangeOptions}"
                          DisplayMemberPath="Label"
                          SelectedValuePath="Range"
                          SelectedValue="{Binding TimeRange, Mode=TwoWay}"
                          ToolTip="Time range"/>

                <TextBox  Grid.Column="2" Margin="0,0,6,0" MinWidth="130" Height="26"
                          Text="{Binding SourceFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ToolTip="Filter by source (e.g. 'Browser', 'Proxy')"/>

                <TextBox  Grid.Column="3" Margin="0,0,6,0" MinWidth="130" Height="26"
                          Text="{Binding ProfileFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ToolTip="Filter by profile name (matched in message body)"/>

                <!-- Search field — needs a per-instance style for the
                     red-border-on-invalid-regex indicator. The inline
                     <Style TargetType="TextBox"> WITHOUT BasedOn
                     would replace the global theme entirely (and
                     render the textbox with the Windows-default white
                     background). BasedOn pulls the dark-theme style
                     in as the parent so only the BorderBrush trigger
                     overrides. -->
                <TextBox Grid.Column="4" Margin="0,0,6,0" Height="26"
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Search in message text. Toggle 'regex' for pattern matching.">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasInvalidRegex}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource ErrBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <CheckBox Grid.Column="5" Content=".* regex"
                          IsChecked="{Binding UseRegex, Mode=TwoWay}"
                          VerticalAlignment="Center" Margin="0,0,8,0"
                          ToolTip="Treat search text as a regular expression"/>

                <CheckBox Grid.Column="6" Content="Auto-scroll"
                          IsChecked="{Binding AutoScroll, Mode=TwoWay}"
                          VerticalAlignment="Center"
                          ToolTip="Stick to the latest entry as new lines arrive"/>
            </Grid>
        </Border>

        <!-- Active-filter chips strip -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="6,4" Margin="0,0,0,6"
                Visibility="{Binding IsFiltered, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource MutedText}" VerticalAlignment="Center"
                           Text="Active filters:" Margin="0,0,8,0"/>

                <!-- One chip per active filter — each shows the value
                     and a × button that calls ClearFilter("name").
                     Visibility binding hides chips when their value is
                     null/empty. -->
                <Button Command="{Binding ClearFilterCommand}" CommandParameter="level"
                        Style="{StaticResource ButtonGhost}" Padding="8,2" Margin="0,0,6,0"
                        Visibility="{Binding LevelFilter, Converter={StaticResource NullToCollapsedConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="≥ " VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding LevelFilter}" VerticalAlignment="Center"/>
                        <TextBlock Text="  ×" Margin="6,0,0,0" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding ClearFilterCommand}" CommandParameter="time"
                        Style="{StaticResource ButtonGhost}" Padding="8,2" Margin="0,0,6,0"
                        Visibility="{Binding TimeRange, Converter={StaticResource NullToCollapsedConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="last " VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TimeRange}" VerticalAlignment="Center"/>
                        <TextBlock Text="  ×" Margin="6,0,0,0" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding ClearFilterCommand}" CommandParameter="source"
                        Style="{StaticResource ButtonGhost}" Padding="8,2" Margin="0,0,6,0"
                        Visibility="{Binding SourceFilter, Converter={StaticResource NonEmptyToVisibleConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="source: " VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SourceFilter}" VerticalAlignment="Center"/>
                        <TextBlock Text="  ×" Margin="6,0,0,0" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding ClearFilterCommand}" CommandParameter="profile"
                        Style="{StaticResource ButtonGhost}" Padding="8,2" Margin="0,0,6,0"
                        Visibility="{Binding ProfileFilter, Converter={StaticResource NonEmptyToVisibleConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="profile: " VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ProfileFilter}" VerticalAlignment="Center"/>
                        <TextBlock Text="  ×" Margin="6,0,0,0" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding ClearFilterCommand}" CommandParameter="search"
                        Style="{StaticResource ButtonGhost}" Padding="8,2" Margin="0,0,6,0"
                        Visibility="{Binding SearchText, Converter={StaticResource NonEmptyToVisibleConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="search: " VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SearchText}" VerticalAlignment="Center"/>
                        <TextBlock Text="  ×" Margin="6,0,0,0" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Button>

                <Button Content="Reset all"
                        Command="{Binding ResetFiltersCommand}"
                        Style="{StaticResource ButtonGhost}"
                        Margin="6,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Log list -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <!-- Empty state — two variants. The "buffer is empty"
                     case nudges the user to start a profile; the
                     "filtered to zero" case nudges them to widen the
                     filter. -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                    <TextBlock FontSize="48" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextDim}" Text="∅"/>
                    <!-- Style attribute on TextBlock conflicts with
                         a TextBlock.Style child block (XAML refuses
                         the same DP set twice). When we need a
                         DataTrigger AND BasedOn, the BasedOn lives
                         entirely inside the explicit Style block. -->
                    <TextBlock Margin="0,14,0,6" HorizontalAlignment="Center"
                               FontSize="16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource PageTitle}">
                                <Setter Property="Text" Value="No log entries yet"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BufferHasHidden}" Value="True">
                                        <Setter Property="Text" Value="No entries match the current filters"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
                                <Setter Property="Text" Value="The tail starts when the page opens. Run a profile to see traffic."/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BufferHasHidden}" Value="True">
                                        <Setter Property="Text" Value="Try widening the level / time range or clearing one of the search fields."/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- List of entries. Virtualized for 2000-line buffers
                     under fire-hose load; recycling mode keeps row
                     containers warm on rapid scrolls.

                     Row template — ported from the legacy web's
                     .log-line: a single inline TextBlock so the
                     timestamp / level / source / message all flow
                     as one paragraph and wrap naturally when the
                     message is long or contains folded RAW
                     continuations. The previous Grid-of-columns
                     layout looked broken on multi-line rows because
                     the head columns were vertically centred against
                     a tall Message column; an inline flow has no
                     column to misalign and matches the terminal-
                     style readout the web version uses. -->
                <ListBox x:Name="LogList"
                         Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVis}}"
                         ItemsSource="{Binding Items}"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="10,6"
                         FontFamily="{StaticResource FontMono}"
                         FontSize="12"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <!-- Strip ListBoxItem chrome (the default selection
                         tint and the focus border) so a stuck-on
                         "selected" highlight doesn't draw attention
                         away from the log content. The row is still
                         hit-testable for context-menu use. -->
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem"
                               BasedOn="{StaticResource {x:Type ListBoxItem}}">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin"  Value="0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background"      Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type m:LogEntry}">
                            <!-- Fixed-width column layout. Earlier we
                                 had a single inline TextBlock with
                                 Runs flowing freely — that produced
                                 a misaligned message column because
                                 source names vary wildly in width
                                 (Bootstrap vs DatabaseConnection vs
                                 ProfileGroupService).

                                 Grid columns now pin every cell:
                                   ts:      105px  HH:mm:ss.fff
                                   LVL:      36px  INF/WAR/ERR (3 chars)
                                   source:  170px  ellipsised on overflow
                                   ":":      14px  spacer
                                   message:   *    wraps to row height
                                 All header cells anchor Top so when the
                                 message wraps to multiple lines they
                                 stay at the top — no drifting baseline. -->
                            <Grid Margin="0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="105"/>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Timestamp, StringFormat='HH:mm:ss.fff', Mode=OneWay}"
                                           Foreground="{StaticResource TextDim}"
                                           VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Level, Mode=OneWay}"
                                           Foreground="{Binding Level, Converter={StaticResource LogLevelChipBrush}}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding ShortSource, Mode=OneWay}"
                                           Foreground="{StaticResource Accent}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding ShortSource, Mode=OneWay}"
                                           VerticalAlignment="Top"/>
                                <TextBlock Grid.Column="3"
                                           Text=":"
                                           Foreground="{StaticResource TextDim}"
                                           VerticalAlignment="Top"
                                           Margin="0,0,4,0"/>
                                <TextBlock Grid.Column="4"
                                           Text="{Binding Message, Mode=OneWay}"
                                           Foreground="{Binding Level, Converter={StaticResource LogLevelMsgBrush}}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Top"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Footer with counters + regex error surface -->
        <Border Grid.Row="5" Style="{StaticResource Card}" Padding="10,6" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Style="{StaticResource MutedText}">
                        <Run Text="Buffer "/>
                        <Run Text="{Binding BufferCount, Mode=OneWay}"/>
                        <Run Text=" · shown "/>
                        <Run Text="{Binding Shown, Mode=OneWay}"/>
                        <Run Text=" · dropped "/>
                        <Run Text="{Binding Dropped, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="12,0,0,0" Foreground="{StaticResource ErrBrush}"
                               Visibility="{Binding HasInvalidRegex, Converter={StaticResource BoolToVis}}">
                        <Run Text="regex error: "/>
                        <Run Text="{Binding RegexError, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Style="{StaticResource MutedText}" VerticalAlignment="Center"
                               Visibility="{Binding IsPaused, Converter={StaticResource BoolToVis}}"
                               Foreground="{StaticResource WarnBrush}"
                               Text="● PAUSED"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
