<UserControl x:Class="GhostShell.App.Views.GroupsView"
             x:Name="PageRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
             xmlns:common="clr-namespace:GhostShell.App.Common"
             d:DataContext="{d:DesignInstance Type=vm:GroupsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Row context menu — Edit / Delete -->
        <ContextMenu x:Key="GroupRowMenu"
                     DataContext="{Binding DataContext, Source={x:Reference PageRoot}}">
            <MenuItem Header="Edit…"
                      Command="{Binding EditCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
            <Separator/>
            <MenuItem Header="Delete"
                      Command="{Binding DeleteCommand}"
                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu},
                                                  Path=PlacementTarget.DataContext}"/>
        </ContextMenu>
    </UserControl.Resources>

    <!-- Phase 71s — busy overlay moved to MainWindow (window-level
         blur + spinner so the sidebar gets dimmed too). -->
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="Auto"/>  <!-- search -->
            <RowDefinition Height="*"/>     <!-- content -->
        </Grid.RowDefinitions>

        <!-- Header + toolbar — title/buttons share row 0, subtitle gets
             full width on row 1 so it doesn't wrap awkwardly next to
             the buttons at narrow window sizes. -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource PageTitle}"
                           Text="Profile groups"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="+  Create group"
                            Command="{Binding AddCommand}"
                            Style="{StaticResource ButtonPrimary}"
                            MinWidth="140"/>
                </WrapPanel>
            </Grid>
            <Border Grid.Row="1" Style="{StaticResource Card}"
                    Padding="14,10" Margin="0,12,0,0">
                <TextBlock Style="{StaticResource PageSubtitle}"
                           TextWrapping="Wrap"
                           Text="Batch-run many profiles at once. Each member runs in its own Chrome with its own proxy."/>
            </Border>
        </Grid>

        <!-- Search row -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="10,8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Filter by group name or description"/>
                <TextBlock Grid.Column="1" Margin="14,0,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource MutedText}">
                    <Run Text="{Binding Items.Count, Mode=OneWay}"/>
                    <Run Text=" group(s)"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="2">
            <!-- Empty state -->
            <Border Style="{StaticResource Card}" Padding="40"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock FontSize="48" HorizontalAlignment="Center"
                               Foreground="{StaticResource TextDim}" Text="∅"/>
                    <TextBlock Margin="0,14,0,6" HorizontalAlignment="Center"
                               Style="{StaticResource PageTitle}" FontSize="16"
                               Text="No groups yet"/>
                    <TextBlock HorizontalAlignment="Center" Style="{StaticResource MutedText}"
                               Margin="0,0,0,16"
                               Text="Create your first group to batch-run multiple profiles with one click."/>
                    <Button Content="+  Create group"
                            Command="{Binding AddCommand}"
                            Style="{StaticResource ButtonPrimary}"
                            HorizontalAlignment="Center"
                            MinWidth="160"/>
                </StackPanel>
            </Border>

            <!-- Group cards grid -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVis}}">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:GroupRowVm}">
                            <!-- Compact group card. 2px accent stripe on the
                                 left echoes the sidebar treatment, smaller
                                 padding (12 instead of 16) and tighter
                                 MinHeight (124 instead of 160) so the cards
                                 read as quick-access tiles, not panels. -->
                            <Border Margin="0,0,12,12"
                                    Background="{StaticResource BgRaised}"
                                    BorderBrush="{StaticResource HueIndigo}"
                                    BorderThickness="2,1,1,1"
                                    CornerRadius="8"
                                    Padding="12"
                                    MinWidth="300"
                                    MinHeight="124"
                                    ContextMenu="{StaticResource GroupRowMenu}">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black"
                                                      BlurRadius="10"
                                                      ShadowDepth="1"
                                                      Opacity="0.35"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header: name + running chip -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="📁"
                                                       FontSize="16"
                                                       Foreground="{StaticResource HueIndigo}"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource Text}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" Padding="8,2"
                                                CornerRadius="10" BorderThickness="1"
                                                Background="{StaticResource OkSoftBrush}"
                                                BorderBrush="{StaticResource OkBrush}"
                                                Visibility="{Binding HasRunning, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Style="{StaticResource PillText}"
                                                       Foreground="{StaticResource OkBrush}"
                                                       Text="{Binding RunningLabel}"/>
                                        </Border>
                                    </Grid>

                                    <!-- Meta: members + cap -->
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Foreground="{StaticResource Accent}"
                                                   FontFamily="{StaticResource FontMono}"
                                                   FontSize="12">
                                            <Run Text="{Binding MemberCount, Mode=OneWay}"/>
                                            <Run Text=" member(s)"/>
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource MutedText}" FontSize="11"
                                                   Margin="10,0,0,0" VerticalAlignment="Center"
                                                   Text="·"/>
                                        <TextBlock Style="{StaticResource MutedText}" FontSize="11"
                                                   Margin="10,0,0,0" VerticalAlignment="Center"
                                                   Text="{Binding CapLabel}"/>
                                    </StackPanel>

                                    <!-- Description -->
                                    <TextBlock Grid.Row="2"
                                               Style="{StaticResource MutedText}"
                                               Margin="0,12,0,0"
                                               TextWrapping="Wrap"
                                               Text="{Binding Description, FallbackValue='—'}"/>

                                    <!-- Actions -->
                                    <Grid Grid.Row="3" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Margin="0,0,4,0"
                                                Style="{StaticResource ButtonPrimary}"
                                                Command="{Binding DataContext.StartGroupCommand,
                                                          Source={x:Reference PageRoot}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                           Text="&#xE768;" Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="Start group" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="1" Margin="4,0,4,0"
                                                Style="{StaticResource ButtonDanger}"
                                                IsEnabled="{Binding HasRunning}"
                                                Command="{Binding DataContext.StopGroupCommand,
                                                          Source={x:Reference PageRoot}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                           Text="&#xE71A;" Margin="0,0,6,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock VerticalAlignment="Center">
                                                    <Run Text="Stop "/>
                                                    <Run Text="{Binding RunningCount, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Button>
                                        <Button Grid.Column="2" Margin="4,0,2,0"
                                                Style="{StaticResource RowActionButton}"
                                                ToolTip="Edit group"
                                                Command="{Binding DataContext.EditCommand,
                                                          Source={x:Reference PageRoot}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Style="{StaticResource RowActionIcon}" FontSize="14"
                                                       Text="&#xE70F;"/>
                                        </Button>
                                        <Button Grid.Column="3"
                                                Style="{StaticResource RowActionDanger}"
                                                ToolTip="Delete group"
                                                Command="{Binding DataContext.DeleteCommand,
                                                          Source={x:Reference PageRoot}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Style="{StaticResource RowActionIcon}" FontSize="14"
                                                       Foreground="{StaticResource ErrBrush}"
                                                       Text="&#xE74D;"/>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
