<UserControl x:Class="GhostShell.App.Views.FingerprintView"
             x:Name="PageRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:FingerprintViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="20">

            <!-- ─── HEADER ROW ──────────────────────────────────────
                 Title + subtitle on the left. The PROFILE PICKER on
                 the right is the "what am I scoring?" affordance —
                 the user reported it was easy to miss before, so it
                 lives in a green-bordered pill that reads as a chip
                 of metadata about the page-wide context. -->
            <StackPanel Margin="0,0,0,14">
                <TextBlock Style="{StaticResource PageTitle}" Text="🧬  Fingerprint"/>
                <Border Style="{StaticResource Card}" Padding="14,10" Margin="0,12,0,0">
                    <TextBlock Style="{StaticResource PageSubtitle}"
                               TextWrapping="Wrap"
                               Text="Coherence validator — checks that UA / GPU / fonts / timezone tell the same story. A score below 75 means the profile is lying to itself and detection systems will notice."/>
                </Border>
            </StackPanel>

            <!-- ─── PROMINENT PROFILE PICKER ────────────────────────
                 Big chip-style row: "Profile" label + dropdown + the
                 currently-selected profile name as a colored pill on
                 the right. Hard to miss now. -->
            <Border CornerRadius="6"
                    Background="{StaticResource BgRaised}"
                    BorderBrush="{StaticResource HueGreen}"
                    BorderThickness="1"
                    Padding="14,10"
                    Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🧬"
                                   FontSize="18"
                                   Foreground="{StaticResource HueGreen}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="Scoring profile"
                                   Foreground="{StaticResource TextDim}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding ProfileNames}"
                              SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                              MinHeight="34"
                              Margin="14,0,14,0"
                              VerticalAlignment="Center"
                              FontSize="14"
                              FontWeight="SemiBold"/>

                    <Border Grid.Column="2"
                            CornerRadius="14"
                            Padding="12,4"
                            Background="{StaticResource OkSoftBrush}"
                            BorderBrush="{StaticResource OkBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <TextBlock Foreground="{StaticResource OkBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center">
                            <Run Text="ACTIVE: "/>
                            <Run Text="{Binding SelectedProfile, FallbackValue='—'}"
                                 FontFamily="{StaticResource FontMono}"/>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>

            <!-- ─── SCORE CARD ──────────────────────────────────── -->
            <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderBrush="{Binding ScoreBrush}"
                            BorderThickness="2"
                            CornerRadius="6"
                            Padding="20,12"
                            Background="{StaticResource BgDeep}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding OverallScore}"
                                       FontFamily="{StaticResource FontMono}"
                                       FontSize="42" FontWeight="Bold"
                                       Foreground="{Binding ScoreBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ScoreLabel}"
                                       Foreground="{Binding ScoreBrush}"
                                       FontSize="10" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SummaryLine}"
                                   Foreground="{StaticResource Text}"
                                   FontSize="13" FontWeight="SemiBold"/>
                        <WrapPanel Margin="0,10,0,0">
                            <Border Background="{StaticResource BgDeep}" CornerRadius="14"
                                    Padding="10,4" Margin="0,0,8,4"
                                    BorderBrush="{StaticResource OkBrush}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🪪 Identity " Foreground="{StaticResource Text}"
                                               FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding IdentityScore}" FontWeight="SemiBold"
                                               FontFamily="{StaticResource FontMono}"
                                               FontSize="11"
                                               Foreground="{StaticResource OkBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{StaticResource BgDeep}" CornerRadius="14"
                                    Padding="10,4" Margin="0,0,8,4"
                                    BorderBrush="{StaticResource HueIndigo}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🖥 Hardware " Foreground="{StaticResource Text}"
                                               FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding HardwareScore}" FontWeight="SemiBold"
                                               FontFamily="{StaticResource FontMono}"
                                               FontSize="11"
                                               Foreground="{StaticResource HueIndigo}"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{StaticResource BgDeep}" CornerRadius="14"
                                    Padding="10,4" Margin="0,0,8,4"
                                    BorderBrush="{StaticResource HueTeal}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🌐 Network " Foreground="{StaticResource Text}"
                                               FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding NetworkScore}" FontWeight="SemiBold"
                                               FontFamily="{StaticResource FontMono}"
                                               FontSize="11"
                                               Foreground="{StaticResource HueTeal}"/>
                                </StackPanel>
                            </Border>
                            <Border Background="{StaticResource BgDeep}" CornerRadius="14"
                                    Padding="10,4" Margin="0,0,8,4"
                                    BorderBrush="{StaticResource HuePink}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🤖 Automation " Foreground="{StaticResource Text}"
                                               FontSize="11" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding AutomationScore}" FontWeight="SemiBold"
                                               FontFamily="{StaticResource FontMono}"
                                               FontSize="11"
                                               Foreground="{StaticResource HuePink}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="↻  Regenerate (full)"
                                Command="{Binding RegenerateCommand}"
                                Background="{StaticResource Accent}"
                                Foreground="White"
                                BorderBrush="{StaticResource Accent}"
                                FontWeight="SemiBold"
                                Padding="12,8"
                                Margin="0,0,8,0"/>
                        <Button Content="🎲  Reshuffle"
                                Command="{Binding ReshuffleCommand}"
                                Padding="12,8"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ─── DEVICE TEMPLATES PANEL ─────────────────────────
                 Mirror of the legacy web's left rail. Click a row to
                 switch the profile's template + re-score. Filter chips
                 cycle (All / Desktop / Laptop / Phone). -->
            <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,14">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="14,12,14,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Foreground="{StaticResource Text}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Text="🧰  Device templates"/>
                            <TextBlock Style="{StaticResource MutedText}"
                                       FontSize="11" Margin="0,2,0,0">
                                <Run Text="{Binding Templates.Count, Mode=OneWay}"/>
                                <Run Text=" templates · click to switch the focused profile"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton Content="All"     GroupName="TplFilter"
                                         IsChecked="{Binding TemplateFilter, Converter={StaticResource StringEqualsConverter}, ConverterParameter=all, Mode=TwoWay}"
                                         Margin="0,0,8,0"/>
                            <RadioButton Content="Desktop" GroupName="TplFilter"
                                         IsChecked="{Binding TemplateFilter, Converter={StaticResource StringEqualsConverter}, ConverterParameter=desktop, Mode=TwoWay}"
                                         Margin="0,0,8,0"/>
                            <RadioButton Content="Laptop"  GroupName="TplFilter"
                                         IsChecked="{Binding TemplateFilter, Converter={StaticResource StringEqualsConverter}, ConverterParameter=laptop, Mode=TwoWay}"
                                         Margin="0,0,8,0"/>
                            <RadioButton Content="Phone"   GroupName="TplFilter"
                                         IsChecked="{Binding TemplateFilter, Converter={StaticResource StringEqualsConverter}, ConverterParameter=phone, Mode=TwoWay}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Phase 52 — device templates panel converted to 3-column card grid
                         for compact scanning. Each card is a compact Border with left-edge
                         accent stripe (blue=laptop, teal=desktop, violet=mobile). Top row:
                         template ID (monospace, right-aligned) + form-factor chip. Middle:
                         specs (single-line, muted). Bottom: weight percent (dim, monospace).
                         UniformGrid distributes columns evenly; cards stay clickable via
                         InputBindings on the Border. MaxHeight + ScrollViewer keeps the
                         whole panel bounded on tall template libraries. -->
                    <ItemsControl ItemsSource="{Binding Templates}"
                                  Margin="0,4,0,12"
                                  MaxHeight="280">
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Phase 52 — card template for device template. Border with
                                     left-edge accent stripe (BorderThickness 3,0,0,0) colored per
                                     FormFactor: laptop→blue, desktop→teal, mobile→violet.
                                     Clickable via MouseBinding instead of Button so the card
                                     appearance stays a simple bordered box. Wire the existing
                                     SelectTemplateCommand via InputBindings. -->
                                <Border Padding="10,7"
                                        Margin="3"
                                        CornerRadius="3"
                                        Background="{StaticResource BgRaised}"
                                        BorderThickness="3,0,0,0"
                                        Cursor="Hand">
                                    <!-- DataTriggers on Border.Style to color the left stripe
                                         per FormFactor. Default is TextDim; overridden by matches. -->
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{StaticResource TextDim}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FormFactor}" Value="laptop">
                                                    <Setter Property="BorderBrush" Value="{StaticResource HueBlue}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding FormFactor}" Value="desktop">
                                                    <Setter Property="BorderBrush" Value="{StaticResource HueTeal}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding FormFactor}" Value="mobile">
                                                    <Setter Property="BorderBrush" Value="{StaticResource HueViolet}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.SelectTemplateCommand,
                                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <!-- Top row: template ID (monospace, right-aligned) and
                                             form-factor chip (small rounded border). -->
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Id}"
                                                       FontFamily="{StaticResource FontMono}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource Text}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <!-- Form-factor chip: small rounded border with
                                                 text showing "laptop"/"desktop"/"phone". Color-coded
                                                 to match the stripe. -->
                                            <Border Grid.Column="1"
                                                    Padding="5,2"
                                                    Margin="4,0,0,0"
                                                    CornerRadius="2"
                                                    Background="{StaticResource BgDeep}">
                                                <TextBlock Text="{Binding FormFactor}"
                                                           FontSize="8"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextMuted}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FormFactor}" Value="laptop">
                                                                    <Setter Property="Foreground" Value="{StaticResource HueBlue}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding FormFactor}" Value="desktop">
                                                                    <Setter Property="Foreground" Value="{StaticResource HueTeal}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding FormFactor}" Value="mobile">
                                                                    <Setter Property="Foreground" Value="{StaticResource HueViolet}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                        <!-- Middle row: specs (single-line, ellipsis-trimmed,
                                             muted text). Content comes from Label binding. -->
                                        <TextBlock Text="{Binding Label}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextMuted}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,0,4"/>
                                        <!-- Bottom-right: weight percent badge with dynamic
                                             colors based on WeightTier. WPF DataTrigger only
                                             does EXACT-equality match (no >=, <), so we bind to
                                             a pre-computed tier string ("top"/"med"/"low")
                                             instead of trying numeric ranges directly.
                                             Phase 54 fix: previous Value="5" / Value="4" only
                                             matched the literal floats 5.0 and 4.0 — almost
                                             never true → no card was ever amber/teal. -->
                                        <Border CornerRadius="2"
                                                Padding="6,2"
                                                HorizontalAlignment="Right"
                                                BorderThickness="0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource BgDeep}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding WeightTier}" Value="top">
                                                            <Setter Property="Background" Value="{StaticResource HueAmber}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding WeightTier}" Value="med">
                                                            <Setter Property="Background" Value="{StaticResource HueTeal}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding WeightPct}"
                                                       FontFamily="{StaticResource FontMono}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Right">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding WeightTier}" Value="top">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding WeightTier}" Value="med">
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- ─── COHERENCE CHECKS ──────────────────────────────── -->
            <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,14">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="14,12,14,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Foreground="{StaticResource Text}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Text="🔬  Coherence checks"/>
                            <TextBlock Style="{StaticResource MutedText}"
                                       FontSize="11" Margin="0,2,0,0">
                                <Run Text="{Binding PassCount, Mode=OneWay}" Foreground="{StaticResource OkBrush}"/>
                                <Run Text=" pass · "/>
                                <Run Text="{Binding WarnCount, Mode=OneWay}" Foreground="{StaticResource WarnBrush}"/>
                                <Run Text=" warn · "/>
                                <Run Text="{Binding FailCount, Mode=OneWay}" Foreground="{StaticResource ErrBrush}"/>
                                <Run Text=" fail · "/>
                                <Run Text="{Binding SkipCount, Mode=OneWay}"/>
                                <Run Text=" skipped"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Checks}" Margin="0,4,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="14,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0"
                                             Width="8" Height="8"
                                             VerticalAlignment="Center"
                                             Margin="0,0,12,0"
                                             Fill="{Binding StatusBrush}"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{StaticResource Text}"
                                                   FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Detail}"
                                                   Style="{StaticResource MutedText}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding StatusText}"
                                               Foreground="{Binding StatusBrush}"
                                               FontFamily="{StaticResource FontMono}"
                                               FontSize="10" FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               Margin="14,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- ─── RUNTIME SELF-CHECK ─────────────────────────────
                 Comprehensive per-probe test results covering ~25 probes:
                 navigator, screen, timezone, WebGL, canvas, audio,
                 plugins, network (exit IP, WebRTC), and automation.
                 Each test renders as a card with expected vs actual
                 values and pass/warn/fail/skip status. -->
            <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,14">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="14,12,14,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Foreground="{StaticResource Text}"
                                       FontSize="14" FontWeight="SemiBold">
                                <Run Text="🛰  RUNTIME SELF-CHECK · "/>
                                <Run Text="{Binding SelfCheckScoreSummary, Mode=OneWay}"
                                     Foreground="{StaticResource TextDim}"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource MutedText}"
                                       FontSize="11" Margin="0,2,0,0">
                                <Run Text="~25 per-probe tests: navigator, screen, timezone, WebGL, canvas, audio, network"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <!-- Per-probe test cards — compact grid layout.
                         Each card is fixed-width (~210px) and wraps so
                         the page reflows for narrow / wide windows.
                         Card top-border accent uses the test's status
                         colour for at-a-glance scanning of which checks
                         passed / failed. Hover shows the full
                         expected → actual diff in the tooltip — keeps
                         the card itself uncluttered. -->
                    <ItemsControl ItemsSource="{Binding SelfCheckTests}"
                                  Margin="14,4,14,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Phase 35 — self-check cards are now clickable.
                                     MouseLeftButtonUp opens the detail dialog via
                                     ShowSelfCheckDetailCommand. The cursor changes
                                     to Hand on hover to signal interactivity. -->
                                <!-- Tooltip on the OUTER border so the
                                     whole card is hover-target. The tip
                                     spells out expected → actual + the
                                     detail (failure reason) so the
                                     compact card body can stay clean. -->
                                <!-- No border — the status-coloured
                                     background tint + matching badge
                                     text already convey the result.
                                     A border would double-encode and
                                     visually clutter the grid. -->
                                <Border Width="210" Margin="3"
                                        Background="{Binding StatusBgBrush}"
                                        BorderThickness="0"
                                        CornerRadius="4"
                                        Padding="9,7,9,8"
                                        ToolTip="{Binding TooltipText}"
                                        Cursor="Hand">
                                    <!-- Phase 35 — wire click event to ShowSelfCheckDetailCommand.
                                         Pass the card VM as parameter so the handler can access
                                         all properties (expected, actual, status, etc.). -->
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.ShowSelfCheckDetailCommand,
                                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <StackPanel>
                                        <!-- Top row: status dot + category
                                             icon + label. Label trims with
                                             ellipsis if it's too long for
                                             the 210px card width. -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0"
                                                     Width="8" Height="8"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,6,0"
                                                     Fill="{Binding StatusColour}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding CategoryIcon}"
                                                       FontSize="11"
                                                       Margin="0,0,5,0"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.7"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Label}"
                                                       Foreground="{StaticResource Text}"
                                                       FontSize="11.5"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                        <!-- Bottom row: short status badge
                                             ("PASS" / "FAIL X" / "skip" /
                                             "warn"). Coloured to match
                                             the top border so the card
                                             reads as one unit even when
                                             scanning fast. -->
                                        <TextBlock Text="{Binding StatusBadge}"
                                                   Foreground="{Binding StatusColour}"
                                                   FontFamily="{StaticResource FontMono}"
                                                   FontSize="9.5"
                                                   FontWeight="Bold"
                                                   Margin="14,3,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state — only visible when there are no
                         test cards. Bound to a converter-free count
                         comparison via DataTrigger; otherwise this
                         border would always show under the cards. -->
                    <Border Background="{StaticResource BgDeep}"
                            CornerRadius="6"
                            Padding="20"
                            Margin="14,0,14,12"
                            DockPanel.Dock="Bottom">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelfCheckTests.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Foreground="{StaticResource TextMuted}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="No self-check data yet. Launch the profile once to populate per-probe test results."/>
                    </Border>
                </DockPanel>
            </Border>

            <!-- ─── EXTERNAL FINGERPRINT TESTERS ──────────────────── -->
            <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,0,8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚀  EXTERNAL FINGERPRINT TESTERS"
                                   Foreground="{StaticResource Text}"
                                   FontSize="13" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock Style="{StaticResource MutedText}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   Text="— proactive checks against real bot-detection engines"/>
                    </StackPanel>
                    <Border Background="{StaticResource Border}"
                            Height="1" Margin="0,8,0,0"/>
                    <TextBlock Style="{StaticResource MutedText}"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               FontSize="11"
                               Text="These public testers grade the same signals (canvas, audio, fonts, UA-CH, WebGL, WebRTC) that bot-detect services use commercially. Untick any tester you don't want to open. Click Probe in profile below — we launch the patched browser and copy the chosen URLs to your clipboard so you can paste them as new tabs."/>

                    <!-- 6 tester cards in a WrapPanel — they flow into
                         3 / 4 / 5 columns depending on window width. -->
                    <ItemsControl ItemsSource="{Binding ExternalTesters}" Margin="0,14,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="240" Margin="0,0,10,10"
                                        Padding="12"
                                        CornerRadius="6"
                                        Background="{StaticResource BgDeep}"
                                        BorderBrush="{StaticResource Border}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        ToolTip="Click for full probe details (after running Probe in profile)">
                                    <!-- Click-to-open-details. The MouseBinding fires on the
                                         WHOLE card so the user doesn't have to aim at a tiny
                                         "more" link. Command params it with the row VM so the
                                         parent VM can pull .Result. -->
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.ShowTesterDetailsCommand,
                                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"  Value="{StaticResource BgDeep}"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding VerdictKey}" Value="excellent">
                                                    <Setter Property="BorderBrush" Value="{StaticResource OkBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding VerdictKey}" Value="ok">
                                                    <Setter Property="BorderBrush" Value="{StaticResource OkBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding VerdictKey}" Value="weak">
                                                    <Setter Property="BorderBrush" Value="{StaticResource WarnBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding VerdictKey}" Value="flagged">
                                                    <Setter Property="BorderBrush" Value="{StaticResource ErrBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Stop the checkbox click from bubbling to the
                                                 outer card MouseBinding, otherwise toggling
                                                 selection would also pop the detail dialog. -->
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,8,0"
                                                      ClickMode="Press"/>
                                            <TextBlock Grid.Column="1"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Text}"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding Icon, Mode=OneTime}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding Name, Mode=OneTime}"/>
                                            </TextBlock>
                                        </Grid>
                                        <TextBlock Text="{Binding Description, Mode=OneTime}"
                                                   Style="{StaticResource MutedText}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0"/>

                                        <!-- Live status (during probing): "queued", "navigating…",
                                             "running (Ns)…", "✓ {summary}", "✗ {error}". Visible
                                             only while Status has a value. -->
                                        <Border Margin="0,8,0,0" Padding="8,5"
                                                CornerRadius="4"
                                                Background="{StaticResource BgRaised}"
                                                Visibility="{Binding Status, Converter={StaticResource NonEmptyToVisibleConverter}}">
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="10"
                                                       FontFamily="{StaticResource FontMono}"
                                                       TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding VerdictKey}" Value="excellent">
                                                                <Setter Property="Foreground" Value="{StaticResource OkBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding VerdictKey}" Value="ok">
                                                                <Setter Property="Foreground" Value="{StaticResource OkBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding VerdictKey}" Value="weak">
                                                                <Setter Property="Foreground" Value="{StaticResource WarnBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding VerdictKey}" Value="flagged">
                                                                <Setter Property="Foreground" Value="{StaticResource ErrBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <!-- "click for details" hint — only when a result
                                             is available. -->
                                        <TextBlock Text="↗  click for details"
                                                   Style="{StaticResource DimText}"
                                                   FontSize="9"
                                                   Margin="0,4,0,0"
                                                   Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding ResultText}"
                                                   Style="{StaticResource DimText}"
                                                   FontSize="10"
                                                   Margin="0,4,0,0"
                                                   Visibility="{Binding HasResult, Converter={StaticResource InverseBoolToVis}}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="🚀  Probe in profile"
                            Command="{Binding ProbeInProfileCommand}"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0"
                            Padding="14,8"
                            Background="{StaticResource Accent}"
                            Foreground="White"
                            BorderBrush="{StaticResource Accent}"
                            FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
