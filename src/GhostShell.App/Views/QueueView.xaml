  Phase 64 — Run Queue page. Lists pending + running + recently-
  finished jobs from IRunQueueService. Auto-refreshes via
  QueueChanged event. Lets the user cancel pending jobs.
-->
<UserControl x:Class="GhostShell.App.Views.QueueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance vm:QueueViewModel}"
             Background="{DynamicResource BgBase}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Run Queue"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="Pending profile launches with stagger gap. Auto-fires when queued time arrives + concurrency cap allows."
                           FontSize="11.5" Foreground="{DynamicResource TextDim}"
                           TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="↻  Refresh"
                    Command="{Binding RefreshNowCommand}"
                    VerticalAlignment="Center"
                    Padding="10,6"/>
        </Grid>

        <Border Grid.Row="1" Margin="0,16,0,12"
                Background="{DynamicResource BgRaised}"
                CornerRadius="6" Padding="14,10">
            <TextBlock Text="{Binding SummaryLine}"
                       FontFamily="Cascadia Code, Consolas"
                       Foreground="{DynamicResource TextDim}"/>
        </Border>

        <!-- Empty state -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🕒"
                           FontSize="48"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextDim}"
                           Margin="0,0,0,12"/>
                <TextBlock Text="Queue is empty"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="Bulk-start profiles from the Profiles page to populate the queue."
                           FontSize="11.5"
                           Foreground="{DynamicResource TextDim}"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Queue list -->
        <ListBox Grid.Row="2"
                 Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVis}}"
                 ItemsSource="{Binding Rows}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.IsVirtualizing="True">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource BgRaised}"
                            BorderBrush="{DynamicResource Border}" BorderThickness="1"
                            CornerRadius="6"
                            Padding="14,10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>    <!-- status pill -->
                                <ColumnDefinition Width="*"/>      <!-- profile + meta -->
                                <ColumnDefinition Width="160"/>    <!-- timing -->
                                <ColumnDefinition Width="Auto"/>   <!-- cancel btn -->
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    CornerRadius="3"
                                    Background="{Binding StatusBrush}"
                                    HorizontalAlignment="Left"
                                    Padding="8,2">
                                <TextBlock Text="{Binding StatusText}"
                                           FontWeight="Bold"
                                           FontSize="10.5"
                                           Foreground="White"/>
                            </Border>

                            <StackPanel Grid.Column="1" Margin="14,0">
                                <TextBlock Text="{Binding ProfileName}"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontWeight="SemiBold"/>
                                <TextBlock Foreground="{DynamicResource TextDim}"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis">
                                    <Run Text="source:"/>
                                    <Run Text="{Binding Source}"/>
                                    <Run Text="·"/>
                                    <Run Text="{Binding ErrorText}" Foreground="#FFEF4444"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding ScheduledText}"
                                           FontFamily="Cascadia Code, Consolas"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="11.5"/>
                                <TextBlock Text="{Binding DurationText}"
                                           FontFamily="Cascadia Code, Consolas"
                                           Foreground="{DynamicResource TextDim}"
                                           FontSize="10.5"/>
                            </StackPanel>

                            <Button Grid.Column="3"
                                    Content="✗ Cancel"
                                    Padding="10,4"
                                    Command="{Binding DataContext.CancelCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Visibility="{Binding CanCancel, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
