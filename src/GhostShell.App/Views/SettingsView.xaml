<UserControl x:Class="GhostShell.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20" MaxWidth="900" HorizontalAlignment="Stretch">
            <TextBlock Style="{StaticResource PageTitle}" Text="Settings"/>
            <TextBlock Style="{StaticResource PageSubtitle}"
                       Margin="0,2,0,16"
                       Text="Application paths, version, and integration."/>

            <!-- ─── STORAGE ─── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource CardHeader}" Text="STORAGE"/>
                        <Button Grid.Column="1" Content="Open data folder"
                                Command="{Binding OpenDataFolderCommand}"
                                Margin="0,0,0,4"/>
                    </Grid>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource MutedText}" Text="Data directory" Grid.Row="0" Grid.Column="0" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MonoText}" Text="{Binding DataDirectory}"
                                   TextWrapping="Wrap" Grid.Row="0" Grid.Column="1" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MutedText}" Text="Database" Grid.Row="1" Grid.Column="0" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MonoText}" Text="{Binding DatabasePath}"
                                   TextWrapping="Wrap" Grid.Row="1" Grid.Column="1" Margin="0,4,0,4"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ─── LOGS ─── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource CardHeader}" Text="LOGS"/>
                        <Button Grid.Column="1" Content="Open logs folder"
                                Command="{Binding OpenLogsFolderCommand}"
                                Margin="0,0,0,4"/>
                    </Grid>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource MutedText}" Text="Logs directory" Grid.Row="0" Grid.Column="0" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MonoText}" Text="{Binding LogsDirectory}"
                                   TextWrapping="Wrap" Grid.Row="0" Grid.Column="1" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MutedText}" Text="Today's log" Grid.Row="1" Grid.Column="0" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MonoText}" Text="{Binding CurrentLogFile}"
                                   TextWrapping="Wrap" Grid.Row="1" Grid.Column="1" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MutedText}" Text="Retention" Grid.Row="2" Grid.Column="0" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MonoText}" Text="14 days, 50 MB / file (rolls daily + on cap)"
                                   Grid.Row="2" Grid.Column="1" Margin="0,4,0,4"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ─── BROWSER ENGINE (patched Chromium status) ─── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource CardHeader}" Text="BROWSER ENGINE"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Probe again"
                                    Command="{Binding ProbeChromiumCommand}"
                                    Margin="0,0,8,0"/>
                            <Button Content="Open folder"
                                    Command="{Binding OpenChromiumFolderCommand}"
                                    IsEnabled="{Binding ChromiumFound}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Status banner — success when located, error otherwise -->
                    <Border Margin="0,8,0,12"
                            Style="{StaticResource InfoBannerSuccess}"
                            Visibility="{Binding ChromiumFound, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="{StaticResource OkBrush}"
                                       Text="&#xE73E;"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Style="{StaticResource InfoBannerTitle}"
                                           Text="{Binding ChromiumStatusMessage}"/>
                                <TextBlock Style="{StaticResource InfoBannerBody}"
                                           Text="Profile launches will use this Chromium build."/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Margin="0,8,0,12"
                            Style="{StaticResource InfoBannerError}"
                            Visibility="{Binding ChromiumFound, Converter={StaticResource InverseBoolToVis}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="{StaticResource ErrBrush}"
                                       Text="&#xE783;"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Style="{StaticResource InfoBannerTitle}"
                                           Text="Patched Chromium not found"/>
                                <TextBlock Style="{StaticResource InfoBannerBody}"
                                           Text="{Binding ChromiumStatusMessage}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource MutedText}" Text="Chrome binary"
                                   Grid.Row="0" Grid.Column="0" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MonoText}" Text="{Binding ChromiumPath}"
                                   TextWrapping="Wrap"
                                   Grid.Row="0" Grid.Column="1" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MutedText}" Text="ChromeDriver"
                                   Grid.Row="1" Grid.Column="0" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MonoText}" Text="{Binding ChromedriverPath}"
                                   TextWrapping="Wrap"
                                   Grid.Row="1" Grid.Column="1" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MutedText}" Text="Version"
                                   Grid.Row="2" Grid.Column="0" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MonoText}" Text="{Binding ChromiumVersion}"
                                   Grid.Row="2" Grid.Column="1" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MutedText}" Text="Source"
                                   Grid.Row="3" Grid.Column="0" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MonoText}" Text="{Binding ChromiumProbedFrom}"
                                   Grid.Row="3" Grid.Column="1" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MutedText}" Text="Override env"
                                   Grid.Row="4" Grid.Column="0" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MonoText}"
                                   Text="GHOSTSHELL_CHROMIUM_DIR"
                                   Grid.Row="4" Grid.Column="1" Margin="0,4,0,4"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ─── ABOUT ─── -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource CardHeader}" Text="ABOUT"/>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Style="{StaticResource MutedText}" Text="App version" Grid.Row="0" Grid.Column="0" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MonoText}" Text="{Binding AppVersion}" Grid.Row="0" Grid.Column="1" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MutedText}" Text="Phase" Grid.Row="1" Grid.Column="0" Margin="0,4,0,4"/>
                        <TextBlock Style="{StaticResource MonoText}" Text="2 — CRUD + logging" Grid.Row="1" Grid.Column="1" Margin="0,4,0,4"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
