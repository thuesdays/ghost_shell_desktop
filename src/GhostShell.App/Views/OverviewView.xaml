  Phase 31 — Overview dashboard. Five hero stat cards across the top,
  quick-actions strip, two-column body (live runs / vault & traffic
  panels) and a recent-activity table at the bottom. Auto-refreshes
  every 10 s while visible.
-->
<UserControl x:Class="GhostShell.App.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:OverviewViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <!-- Phase 54 — TRUE full-width layout. Phase 53 set Margin="0,20"
             but kept MaxWidth=1320 which capped content on wider monitors,
             leaving a dark gap on the right (visible at 1920+ resolutions).
             Removed MaxWidth entirely; HorizontalAlignment="Stretch" makes
             the StackPanel fill the ScrollViewer's full client area.
             Vertical Margin=20 stays for breathing room from title bar. -->
        <!-- Phase 71o — horizontal padding so the content cards
             don't sit flush against the (collapsed) sidebar. Other
             pages already set Margin="24,20" on their root grid;
             OverviewView was the only one missing horizontal
             breathing room. -->
        <StackPanel Margin="20,20,20,20" HorizontalAlignment="Stretch">

            <!-- ─── Page header ─── -->
            <StackPanel Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource PageTitle}"
                               Text="{Binding Greeting, StringFormat='{}{0}, Nick.'}"/>
                    <Button Grid.Column="1" Content="⚙" Padding="8,4" FontSize="14"
                            Command="{Binding ConfigureLayoutCommand}"
                            ToolTip="Configure widgets"/>
                </Grid>
                <Border Style="{StaticResource Card}" Padding="14,10" Margin="0,12,0,0">
                    <TextBlock Style="{StaticResource PageSubtitle}"
                               TextWrapping="Wrap"
                               Text="At-a-glance operational status — runs, profiles, vault, traffic, recent activity."/>
                </Border>
            </StackPanel>

            <!-- ─── Stat tiles ─── -->
            <!-- Phase 71u — hero tile redesign.
                 Each tile is a layered Border:
                   1) Outer  HeroTile style (rounded 8, faint border,
                      hover lift via drop-shadow).
                   2) Top accent bar (3 px) tinted by category hue —
                      the visual cue that ties tile to its sidebar
                      colour.
                   3) Soft tinted background fill (Hue*Soft, ~8% alpha)
                      so each tile reads as "the green / amber / blue
                      one" without going neon.
                   4) Big MDL2 glyph in the top-right corner at low
                      opacity — extra visual identity, doesn't fight
                      the number.
                   5) Header (uppercase 10 px), big number, sublabel.
                 Padding tightened from 16,14 → 14,12 so cards are a
                 touch shorter; height now naturally caps around
                 ~108 px vs the ~120 of the previous design. -->
            <Border Visibility="{Binding ShowHeroStats, Converter={StaticResource BoolToVis}}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Runs — accent blue -->
                <Border Grid.Column="0" Style="{StaticResource HeroTile}" Margin="0,0,6,0" Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding GoRunsCommand}"/>
                    </Border.InputBindings>
                    <Grid>
                        <Border CornerRadius="8" Background="{StaticResource AccentSoft}"/>
                        <Border CornerRadius="8,8,0,0" Height="3" VerticalAlignment="Top"
                                Background="{StaticResource Accent}"/>
                        <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="44" Opacity="0.10"
                                   Foreground="{StaticResource Accent}"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,8,2"/>
                        <StackPanel Margin="14,12,14,12">
                            <TextBlock Text="🚀  TOTAL RUNS" Style="{StaticResource MutedText}" FontSize="10"/>
                            <TextBlock Text="{Binding TotalRuns}"
                                       FontSize="26" FontWeight="SemiBold"
                                       Foreground="{StaticResource Accent}"
                                       Margin="0,4,0,0"/>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding SuccessfulRuns}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource OkBrush}"/>
                                    <TextBlock Text="ok" Style="{StaticResource MutedText}" FontSize="10"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding FailedRuns}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource ErrBrush}"/>
                                    <TextBlock Text="fail" Style="{StaticResource MutedText}" FontSize="10"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding RunningRuns}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource Accent}"/>
                                    <TextBlock Text="run" Style="{StaticResource MutedText}" FontSize="10"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Success rate — orange -->
                <Border Grid.Column="1" Style="{StaticResource HeroTile}" Margin="3,0,3,0">
                    <Grid>
                        <Border CornerRadius="8" Background="{StaticResource HueOrangeSoft}"/>
                        <Border CornerRadius="8,8,0,0" Height="3" VerticalAlignment="Top"
                                Background="{StaticResource HueOrange}"/>
                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="44" Opacity="0.10"
                                   Foreground="{StaticResource HueOrange}"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,8,2"/>
                        <StackPanel Margin="14,12,14,12">
                            <TextBlock Text="✅  SUCCESS RATE" Style="{StaticResource MutedText}" FontSize="10"/>
                            <TextBlock Text="{Binding SuccessRateLabel}"
                                       FontSize="26" FontWeight="SemiBold"
                                       Foreground="{Binding SuccessRateBrushKey, Converter={StaticResource ResourceKeyToBrush}}"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="last completed runs"
                                       Style="{StaticResource MutedText}" FontSize="10" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Profiles — green -->
                <Border Grid.Column="2" Style="{StaticResource HeroTile}" Margin="3,0,3,0" Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding GoProfilesCommand}"/>
                    </Border.InputBindings>
                    <Grid>
                        <Border CornerRadius="8" Background="{StaticResource HueGreenSoft}"/>
                        <Border CornerRadius="8,8,0,0" Height="3" VerticalAlignment="Top"
                                Background="{StaticResource HueGreen}"/>
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="44" Opacity="0.10"
                                   Foreground="{StaticResource HueGreen}"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,8,2"/>
                        <StackPanel Margin="14,12,14,12">
                            <TextBlock Text="👤  PROFILES" Style="{StaticResource MutedText}" FontSize="10"/>
                            <TextBlock Text="{Binding ProfileCount}"
                                       FontSize="26" FontWeight="SemiBold"
                                       Foreground="{StaticResource HueGreen}"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="installed identities"
                                       Style="{StaticResource MutedText}" FontSize="10" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Vault — amber -->
                <Border Grid.Column="3" Style="{StaticResource HeroTile}" Margin="3,0,3,0" Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding GoVaultCommand}"/>
                    </Border.InputBindings>
                    <Grid>
                        <Border CornerRadius="8" Background="{StaticResource HueAmberSoft}"/>
                        <Border CornerRadius="8,8,0,0" Height="3" VerticalAlignment="Top"
                                Background="{StaticResource HueAmber}"/>
                        <TextBlock Text="&#xE192;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="44" Opacity="0.10"
                                   Foreground="{StaticResource HueAmber}"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,8,2"/>
                        <StackPanel Margin="14,12,14,12">
                            <TextBlock Text="🔐  VAULT" Style="{StaticResource MutedText}" FontSize="10"/>
                            <TextBlock Text="{Binding VaultStatusText}"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{Binding VaultStatusBrushKey, Converter={StaticResource ResourceKeyToBrush}}"
                                       Margin="0,6,0,0"/>
                            <TextBlock Text="encrypted credentials"
                                       Style="{StaticResource MutedText}" FontSize="10" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Traffic 24h — violet -->
                <Border Grid.Column="4" Style="{StaticResource HeroTile}" Margin="6,0,0,0" Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding GoTrafficCommand}"/>
                    </Border.InputBindings>
                    <Grid>
                        <Border CornerRadius="8" Background="{StaticResource HueVioletSoft}"/>
                        <Border CornerRadius="8,8,0,0" Height="3" VerticalAlignment="Top"
                                Background="{StaticResource HueViolet}"/>
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="44" Opacity="0.10"
                                   Foreground="{StaticResource HueViolet}"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,8,2"/>
                        <StackPanel Margin="14,12,14,12">
                            <TextBlock Text="📈  TRAFFIC · 24H" Style="{StaticResource MutedText}" FontSize="10"/>
                            <TextBlock Text="{Binding Traffic24hText}"
                                       FontSize="22" FontWeight="SemiBold"
                                       Foreground="{StaticResource HueViolet}"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding TrafficRequestsText, StringFormat='{}{0} requests'}"
                                       Style="{StaticResource MutedText}" FontSize="10" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
            </Border>

            <!-- ─── Live runs (only when active) ─── -->
            <Border Style="{StaticResource Card}" Padding="14,12" Margin="0,0,0,16"
                    BorderBrush="{StaticResource Accent}" BorderThickness="1"
                    Visibility="{Binding HasActiveRuns, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="🟢  LIVE RUNS" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>
                    <ItemsControl ItemsSource="{Binding ActiveProfiles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10,6" Margin="0,0,8,8"
                                        Background="{StaticResource AccentSoft}"
                                        CornerRadius="4">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8"
                                                 Fill="{StaticResource Accent}"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding}"
                                                   FontFamily="{StaticResource FontMono}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource Text}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ─── Recent activity ─── -->
            <Border Visibility="{Binding ShowRecentRuns, Converter={StaticResource BoolToVis}}" Margin="0,0,0,16">
            <Border Style="{StaticResource Card}" Padding="0">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="14,12,14,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🕒  RECENT ACTIVITY"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text}"/>
                        <Button Grid.Column="1" Content="View all runs"
                                Command="{Binding GoRunsCommand}"
                                Padding="10,4"
                                ToolTip="Open the Runs history grid"/>
                    </Grid>
                    <!-- ─── Compact run rows ─────────────────────────
                         Each run is a single-line card with a coloured
                         left-edge accent stripe (status colour). Hover
                         lifts the bg slightly for a clickable feel.
                         Padding tightened from 14,10 → 10,5 — twice as
                         many runs visible without scrolling. -->
                    <Border DockPanel.Dock="Bottom"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="0,1,0,0"
                            Padding="10,8,10,8">
                        <ItemsControl ItemsSource="{Binding RecentRuns}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,3"
                                            CornerRadius="3"
                                            Background="{StaticResource BgRaised}"
                                            BorderBrush="{Binding StatusBrushKey, Converter={StaticResource ResourceKeyToBrush}}"
                                            BorderThickness="3,0,0,0"
                                            Padding="10,5,10,5">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource BgRaised}"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <!-- Fixed widths on the right two
                                                 columns so status / duration /
                                                 relative-time text lines up
                                                 vertically across rows.
                                                 Auto-width was the old design
                                                 but produced a ragged jagged
                                                 right edge because each row's
                                                 text length differs ("OK · 18
                                                 sec" vs "exit 130 · 11 hr 6
                                                 min 39 sec"). Pixel-fixed
                                                 columns + TextAlignment=Right
                                                 inside each gives a clean
                                                 newspaper-column feel. -->
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>  <!-- status icon -->
                                                <ColumnDefinition Width="*"/>     <!-- Run #N · profile (fills) -->
                                                <ColumnDefinition Width="190"/>   <!-- status · duration (fixed) -->
                                                <ColumnDefinition Width="140"/>   <!-- relative time (fixed) -->
                                            </Grid.ColumnDefinitions>

                                            <!-- Status icon — coloured by
                                                 status (✓ green / ✗ red /
                                                 ⏵ accent). Sized down from
                                                 14px to 12px to match the
                                                 tighter row height. -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding StatusIcon}"
                                                       FontSize="12" FontWeight="Bold"
                                                       Foreground="{Binding StatusBrushKey, Converter={StaticResource ResourceKeyToBrush}}"
                                                       VerticalAlignment="Center"
                                                       Margin="2,0,10,0"/>

                                            <!-- Run #N · profile_X — single
                                                 inline line, no second row.
                                                 Stays readable at the
                                                 reduced 5px vertical padding. -->
                                            <TextBlock Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis">
                                                <Run Text="Run #" Foreground="{StaticResource TextMuted}"/>
                                                <Run Text="{Binding Id, Mode=OneWay}"
                                                     FontWeight="SemiBold"
                                                     Foreground="{StaticResource Text}"/>
                                                <Run Text="  ·  " Foreground="{StaticResource TextDim}"/>
                                                <Run Text="{Binding ProfileName, Mode=OneWay}"
                                                     Foreground="{StaticResource Text}"/>
                                            </TextBlock>

                                            <!-- Phase 71kk — split into 3
                                                 sub-columns so the exit code
                                                 itself aligns vertically.
                                                 Pre-71kk this was ONE
                                                 right-aligned TextBlock with
                                                 "Status · Duration", which
                                                 right-aligned the COMBINED
                                                 string — so "OK" and "exit
                                                 130" started at different
                                                 x-positions because their
                                                 trailing duration parts had
                                                 different widths. The user
                                                 wanted the exit codes
                                                 themselves to line up.
                                                   • Code col (90px,
                                                     right-aligned) — the
                                                     RIGHT edge of "OK" /
                                                     "exit 130" sits at the
                                                     same X across all rows.
                                                   • Middle-dot (Auto, 10px
                                                     of breathing room).
                                                   • Duration col (fills
                                                     remainder, left-aligned)
                                                     — durations all start
                                                     at the same X. -->
                                            <Grid Grid.Column="2" Margin="10,0,16,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Status, Mode=OneWay}"
                                                           Foreground="{Binding StatusBrushKey, Converter={StaticResource ResourceKeyToBrush}}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Right"
                                                           TextAlignment="Right"
                                                           FontFamily="{StaticResource FontMono}"
                                                           FontSize="10.5"/>
                                                <TextBlock Grid.Column="1"
                                                           Text=" · "
                                                           Foreground="{StaticResource TextDim}"
                                                           VerticalAlignment="Center"
                                                           FontFamily="{StaticResource FontMono}"
                                                           FontSize="10.5"
                                                           Margin="6,0"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding DurationLabel, Mode=OneWay}"
                                                           Foreground="{StaticResource TextMuted}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Left"
                                                           TextAlignment="Left"
                                                           FontFamily="{StaticResource FontMono}"
                                                           FontSize="10.5"/>
                                            </Grid>

                                            <!-- Relative time — right-edge of
                                                 its fixed-width column. Same
                                                 right-align trick keeps the
                                                 last "ago" character at the
                                                 row's outer edge regardless
                                                 of whether the time string
                                                 is "18 sec ago" or "11 hr 6
                                                 min 39 sec ago". -->
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Relative}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"
                                                       TextAlignment="Right"
                                                       Foreground="{StaticResource TextDim}"
                                                       FontSize="10.5"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </DockPanel>
            </Border>
            </Border>

            <!-- ─── Footer counters (proxy summary + traffic today) ───
                 Phase 71u — same hero treatment as the top stat row,
                 just shorter (no body row, single big value). Keeps
                 visual consistency: every "tile" on the page reads
                 the same way (top accent bar + tinted bg + glyph). -->
            <Border Visibility="{Binding ShowProxySummary, Converter={StaticResource BoolToVis}}" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource HeroTile}" Margin="0,0,6,0" Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding GoProxyCommand}"/>
                    </Border.InputBindings>
                    <Grid>
                        <Border CornerRadius="8" Background="{StaticResource HueTealSoft}"/>
                        <Border CornerRadius="8,8,0,0" Height="3" VerticalAlignment="Top"
                                Background="{StaticResource HueTeal}"/>
                        <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="40" Opacity="0.10"
                                   Foreground="{StaticResource HueTeal}"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,10,4"/>
                        <StackPanel Margin="14,10,14,10">
                            <TextBlock Text="🌐  PROXIES" Style="{StaticResource MutedText}" FontSize="10"/>
                            <TextBlock Text="{Binding ProxyCount}"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource HueTeal}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource HeroTile}" Margin="6,0,0,0"
                        Visibility="{Binding ShowTrafficToday, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Border CornerRadius="8" Background="{StaticResource HueVioletSoft}"/>
                        <Border CornerRadius="8,8,0,0" Height="3" VerticalAlignment="Top"
                                Background="{StaticResource HueViolet}"/>
                        <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="40" Opacity="0.10"
                                   Foreground="{StaticResource HueViolet}"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   Margin="0,0,10,4"/>
                        <StackPanel Margin="14,10,14,10">
                            <TextBlock Text="🌐  UNIQUE DOMAINS · 24H" Style="{StaticResource MutedText}" FontSize="10"/>
                            <TextBlock Text="{Binding TrafficUniqueDomains}"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="{StaticResource HueViolet}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
            </Border>

            <!-- ─── Ad Density Trend ─── -->
            <Border x:Name="AdDensityBorder"
                    Visibility="{Binding ShowAdDensity, Converter={StaticResource BoolToVis}}"
                    Style="{StaticResource Card}" Padding="0" Margin="0,0,0,16"
                    Loaded="OnAdDensityLoaded">
                <DockPanel>
                    <!-- Header with refresh button -->
                    <Grid DockPanel.Dock="Top" Margin="14,12,14,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🪩  Ad density trend — effectiveness of warmup &amp; click algos"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text}"/>
                        <Button Grid.Column="1" Content="⟳" Padding="6,2" FontSize="11"
                                Command="{Binding ReloadCommand}"/>
                    </Grid>

                    <Border DockPanel.Dock="Bottom" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                            Padding="14,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left block: KPI -->
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding AdDensity.AvgAdsPerQuery7d, StringFormat='{}{0:0.00}'}"
                                               FontSize="24" FontWeight="SemiBold"
                                               Foreground="{StaticResource Accent}"/>
                                    <TextBlock Text="ads / query · 7d" FontSize="11" Margin="8,0,0,0"
                                               Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Delta indicator -->
                                <TextBlock Margin="0,6,0,0" FontSize="10"
                                           Text="{Binding AdDensity.DeltaPct7dPrev, StringFormat='↑ {0:0}% vs prev 7d'}"
                                           Foreground="{StaticResource HueGreen}"/>

                                <!-- KPI grid -->
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,8,8">
                                        <TextBlock Text="{Binding AdDensity.AvgAdsPerQuery24h, StringFormat='{}{0:0.00}'}"
                                                   FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
                                        <TextBlock Text="24h avg" Style="{StaticResource MutedText}" FontSize="9"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding AdDensity.TotalRuns7d}"
                                                   FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
                                        <TextBlock Text="runs 7d" Style="{StaticResource MutedText}" FontSize="9"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="0" Grid.Row="1">
                                        <TextBlock Text="{Binding AdDensity.TotalAds7d}"
                                                   FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
                                        <TextBlock Text="ads 7d" Style="{StaticResource MutedText}" FontSize="9"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Grid.Row="1">
                                        <TextBlock FontSize="11">
                                            <Run Text="{Binding AdDensity.Ctr7d, StringFormat='{}{0:P1}', Mode=OneWay}"
                                                 FontWeight="SemiBold" Foreground="{StaticResource Text}"/>
                                            <Run Text=" CTR" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                                        </TextBlock>
                                        <TextBlock Text="proxy" Style="{StaticResource MutedText}" FontSize="9"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- Center block: Top Profiles -->
                            <StackPanel Grid.Column="1" Margin="16,0">
                                <TextBlock Text="Top profiles · 7d" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"
                                           Foreground="{StaticResource Text}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Headers -->
                                    <TextBlock Grid.Column="0" Text="PROFILE" FontSize="8" Style="{StaticResource DimText}" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="RUNS" FontSize="8" Style="{StaticResource DimText}" FontWeight="SemiBold" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="ADS/Q" FontSize="8" Style="{StaticResource DimText}" FontWeight="SemiBold" TextAlignment="Right"/>

                                    <!-- Items -->
                                    <ItemsControl ItemsSource="{Binding AdDensity.PerProfile}" Margin="0,6,0,0"
                                                  Grid.Column="0" Grid.ColumnSpan="3">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="70"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding ProfileName}" FontSize="9"
                                                               Foreground="{StaticResource Text}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Runs}" FontSize="9"
                                                               Foreground="{StaticResource TextMuted}" TextAlignment="Right"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding AdsPerQuery, StringFormat='{}{0:0.00}'}"
                                                               FontSize="9" Foreground="{StaticResource TextMuted}" TextAlignment="Right"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </StackPanel>

                            <!-- Right block: Top IPs -->
                            <StackPanel Grid.Column="2" Margin="16,0,0,0">
                                <TextBlock Text="Top IPs · 7d" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,6"
                                           Foreground="{StaticResource Text}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Headers -->
                                    <TextBlock Grid.Column="0" Text="IP" FontSize="8" Style="{StaticResource DimText}" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="RUNS" FontSize="8" Style="{StaticResource DimText}" FontWeight="SemiBold" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="ADS/Q" FontSize="8" Style="{StaticResource DimText}" FontWeight="SemiBold" TextAlignment="Right"/>

                                    <!-- Empty state or items -->
                                    <ItemsControl ItemsSource="{Binding AdDensity.PerIp}" Margin="0,6,0,0"
                                                  Grid.Column="0" Grid.ColumnSpan="3">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="70"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Ip}" FontSize="9"
                                                               Foreground="{StaticResource Text}"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Runs}" FontSize="9"
                                                               Foreground="{StaticResource TextMuted}" TextAlignment="Right"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding AdsPerQuery, StringFormat='{}{0:0.00}'}"
                                                               FontSize="9" Foreground="{StaticResource TextMuted}" TextAlignment="Right"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Empty state placeholder (shown in code-behind if no IPs) -->
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DockPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
