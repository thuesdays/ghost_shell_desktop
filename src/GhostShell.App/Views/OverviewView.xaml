<UserControl x:Class="GhostShell.App.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GhostShell.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:OverviewViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20" MaxWidth="1280" HorizontalAlignment="Stretch">

            <!-- Page header -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Style="{StaticResource PageTitle}"
                           Text="{Binding Greeting, StringFormat='{}{0}, Nick.'}"/>
                <TextBlock Style="{StaticResource PageSubtitle}"
                           Text="System status at a glance — runs, profiles, proxies."/>
            </StackPanel>

            <!-- Phase-2 status banner. Demonstrates the InfoBannerAccent
                 pattern. Once Phase 3 ships, this will turn into a
                 dismissable "What's new" banner driven by VM. -->
            <Border Style="{StaticResource InfoBannerAccent}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               FontFamily="Segoe MDL2 Assets" FontSize="20"
                               Foreground="{StaticResource Accent}"
                               Text="&#xE946;"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource InfoBannerTitle}"
                                   Text="Phase 2 — CRUD &amp; logging"/>
                        <TextBlock Style="{StaticResource InfoBannerBody}"
                                   Text="Profiles + Proxies are fully editable. Browser launch (Phase 3) and the action runner (Phase 4) are next."/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Stat tiles row -->
            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,16">
                <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="TOTAL RUNS"/>
                        <TextBlock Style="{StaticResource CardValue}" Text="{Binding TotalRuns}"/>
                        <TextBlock Style="{StaticResource CardSubvalue}"
                                   Text="{Binding RunningRuns, StringFormat='{}{0} running now'}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="SUCCESSFUL"/>
                        <TextBlock Style="{StaticResource CardValue}"
                                   Foreground="{StaticResource OkBrush}"
                                   Text="{Binding SuccessfulRuns}"/>
                        <TextBlock Style="{StaticResource CardSubvalue}" Text="exit_code = 0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="FAILED"/>
                        <TextBlock Style="{StaticResource CardValue}"
                                   Foreground="{StaticResource ErrBrush}"
                                   Text="{Binding FailedRuns}"/>
                        <TextBlock Style="{StaticResource CardSubvalue}" Text="non-zero exit code"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="PROFILES"/>
                        <TextBlock Style="{StaticResource CardValue}" Text="{Binding ProfileCount}"/>
                        <TextBlock Style="{StaticResource CardSubvalue}"
                                   Text="{Binding ProxyCount, StringFormat='{}{0} proxies configured'}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Two-column lower row -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource Card}" Grid.Column="0" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="WHAT TO DO NEXT"/>
                        <TextBlock Foreground="{StaticResource Text}" TextWrapping="Wrap"
                                   FontSize="12" LineHeight="20">
                            • Phase 1 done — UI scaffolding visible.<LineBreak/>
                            • Phase 2: bind real data to Profiles + Runs pages.<LineBreak/>
                            • Phase 3: implement BrowserLauncher in GhostShell.Runtime.<LineBreak/>
                            • Phase 4: full action runner with 49 handlers.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Grid.Column="1" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource CardHeader}" Text="BUILD INFO"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Style="{StaticResource MutedText}" Text="App version" Grid.Row="0" Grid.Column="0"/>
                            <TextBlock Style="{StaticResource MonoText}" Text="0.1.0-phase1" Grid.Row="0" Grid.Column="1"/>
                            <TextBlock Style="{StaticResource MutedText}" Text="Stack" Grid.Row="1" Grid.Column="0"/>
                            <TextBlock Style="{StaticResource MonoText}" Text=".NET 8 / WPF" Grid.Row="1" Grid.Column="1"/>
                            <TextBlock Style="{StaticResource MutedText}" Text="DB" Grid.Row="2" Grid.Column="0"/>
                            <TextBlock Style="{StaticResource MonoText}" Text="SQLite (WAL)" Grid.Row="2" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
