<Window x:Class="GhostShell.App.Dialogs.ScriptJsonEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Script editor"
        Width="900" Height="700"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{StaticResource BgBase}">
    <Border BorderBrush="{StaticResource BorderStrong}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                    Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📜" FontSize="16" Margin="0,0,8,0"
                                   Foreground="{StaticResource HueAmber}"
                                   VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock x:Name="TitleText" Text="Edit script"
                                       Foreground="{StaticResource Text}"
                                       FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"
                                       Text="JSON form. Visual drag-drop editor lands in Phase 13."/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource ChromeButton}"
                            Width="28" Height="28" Click="OnCancel" ToolTip="Close">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE8BB;"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Name + description -->
            <StackPanel Grid.Row="1" Margin="22,14,22,0">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource MutedText}" Text="Name *"/>
                        <TextBox x:Name="NameField" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource MutedText}" Text="Description"/>
                        <TextBox x:Name="DescriptionField" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- JSON area -->
            <Border Grid.Row="2" Margin="22,0,22,0" Padding="0"
                    Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1" CornerRadius="4">
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top" Margin="10,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource MutedText}"
                                   FontSize="11"
                                   Text="Steps (JSON array). Each step: {type, params, enabled?, probability?, abort_on_error?, label?, then?, else?, body?, condition?}"/>
                        <TextBlock Grid.Column="1" x:Name="ValidationStatus"
                                   FontFamily="{StaticResource FontMono}"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource OkBrush}"
                                   Text="✓ valid"/>
                    </Grid>
                    <TextBox x:Name="JsonField"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="{StaticResource FontMono}"
                             FontSize="12"
                             Background="Transparent"
                             BorderThickness="0"
                             TextChanged="OnJsonChanged"
                             Padding="10"/>
                </DockPanel>
            </Border>

            <!-- Flags -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="22,12,22,0">
                <CheckBox x:Name="EnabledCheck" Content="Enabled" IsChecked="True"
                          Margin="0,0,18,0"/>
                <CheckBox x:Name="DefaultCheck" Content="Apply as default for new profiles"
                          ToolTip="Newly-created profiles will auto-bind to this script"/>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="4" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                    Padding="18,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Cancel" Click="OnCancel" MinWidth="84" Margin="0,0,8,0"/>
                        <Button x:Name="SaveBtn" Content="Save" Click="OnSave"
                                Style="{StaticResource ButtonPrimary}" MinWidth="120"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
