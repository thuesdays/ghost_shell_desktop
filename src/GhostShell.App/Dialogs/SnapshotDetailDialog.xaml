<Window x:Class="GhostShell.App.Dialogs.SnapshotDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snapshot detail"
        Width="900" Height="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{StaticResource BgBase}">

    <Border BorderBrush="{StaticResource BorderStrong}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                    Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="💾" FontSize="16" Margin="0,0,8,0"
                                   Foreground="{StaticResource HueViolet}"
                                   VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock x:Name="TitleText"
                                       Text="Snapshot detail"
                                       Foreground="{StaticResource Text}"
                                       FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock x:Name="SubtitleText"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Style="{StaticResource ChromeButton}"
                            Width="28" Height="28"
                            Click="OnClose" ToolTip="Close">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Text="&#xE8BB;"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Filter bar -->
            <Border Grid.Row="1" Padding="18,10"
                    Background="{StaticResource BgBase}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔍" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                   Foreground="{StaticResource TextMuted}"/>
                        <TextBox Grid.Column="1" x:Name="FilterField"
                                 TextChanged="OnFilterChanged"
                                 ToolTip="Filter by domain or cookie name"/>
                    </Grid>
                    <TextBlock Grid.Column="1" x:Name="StatsText"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0"
                               Style="{StaticResource MutedText}"/>
                </Grid>
            </Border>

            <!-- Body -->
            <DataGrid Grid.Row="2" x:Name="CookieGrid"
                      AutoGenerateColumns="False"
                      SelectionMode="Single"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      Background="Transparent"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="DOMAIN"   Binding="{Binding Domain}"        Width="220" IsReadOnly="True"/>
                    <DataGridTextColumn Header="NAME"     Binding="{Binding Name}"          Width="160" IsReadOnly="True"/>
                    <DataGridTextColumn Header="VALUE"    Binding="{Binding ValueDisplay}"  Width="*"   IsReadOnly="True"/>
                    <DataGridTextColumn Header="PATH"     Binding="{Binding Path}"          Width="80"  IsReadOnly="True"/>
                    <DataGridCheckBoxColumn Header="SECURE"   Binding="{Binding Secure}"    Width="60"  IsReadOnly="True"/>
                    <DataGridCheckBoxColumn Header="HTTPONLY" Binding="{Binding HttpOnly}"  Width="80"  IsReadOnly="True"/>
                    <DataGridTextColumn Header="EXPIRES"  Binding="{Binding ExpiryDisplay}" Width="120" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Footer -->
            <Border Grid.Row="3" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                    Padding="18,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="StorageStatsText"
                               VerticalAlignment="Center"
                               Style="{StaticResource MutedText}"/>
                    <Button Grid.Column="1" Content="Close" Click="OnClose"
                            MinWidth="84"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
