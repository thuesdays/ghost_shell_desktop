<Window x:Class="GhostShell.App.Dialogs.BulkImportProxiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulk import proxies"
        Width="780" Height="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{StaticResource BgBase}">

    <Border BorderBrush="{StaticResource BorderStrong}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <Border Grid.Row="0" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                    Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Bulk import proxies"
                                   Foreground="{StaticResource Text}"
                                   FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,2,0,0"
                                   Text="Paste a list — one proxy per line. We parse them as you type."/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Style="{StaticResource ChromeButton}"
                            Width="28" Height="28"
                            Click="OnCancel" ToolTip="Close">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Text="&#xE8BB;"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Body: paste pane + preview pane -->
            <Grid Grid.Row="1" Margin="18,16,18,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Left: paste -->
                <StackPanel Grid.Column="0" Grid.Row="0">
                    <TextBlock Style="{StaticResource MutedText}"
                               Text="Paste here" Margin="0,0,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource DimText}"
                                   TextWrapping="Wrap"
                                   Text="Supported: host:port · user:pass@host:port · http://… · socks5://… · host:port:user:pass · #comments"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource MutedText}"
                                       Text="default" Margin="0,0,4,0"
                                       VerticalAlignment="Center"/>
                            <ComboBox x:Name="DefaultSchemeCombo"
                                      Width="100" SelectionChanged="OnInputChanged">
                                <ComboBoxItem Content="http"   IsSelected="True"/>
                                <ComboBoxItem Content="https"/>
                                <ComboBoxItem Content="socks5"/>
                                <ComboBoxItem Content="socks4"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <TextBox Grid.Column="0" Grid.Row="1"
                         x:Name="PasteField"
                         Margin="0,8,0,0"
                         AcceptsReturn="True"
                         AcceptsTab="False"
                         TextWrapping="NoWrap"
                         FontFamily="{StaticResource FontMono}"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextChanged="OnInputChanged"/>

                <!-- Right: preview -->
                <StackPanel Grid.Column="2" Grid.Row="0">
                    <TextBlock Style="{StaticResource MutedText}"
                               Text="Preview" Margin="0,0,0,4"/>
                    <TextBlock x:Name="SummaryText"
                               Style="{StaticResource DimText}"
                               TextWrapping="Wrap"
                               Text="Paste anything to see live parse results here."/>
                </StackPanel>

                <Border Grid.Column="2" Grid.Row="1" Margin="0,8,0,0"
                        Background="{StaticResource BgRaised}"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="PreviewList" Margin="0,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,6"
                                            BorderBrush="{StaticResource Border}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="14"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Status}"
                                                       FontFamily="{StaticResource FontMono}"
                                                       Foreground="{Binding StatusBrush}"
                                                       VerticalAlignment="Top"/>
                                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                <TextBlock Text="{Binding Headline}"
                                                           FontFamily="{StaticResource FontMono}"
                                                           Foreground="{StaticResource Text}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding SubLine}"
                                                           Style="{StaticResource DimText}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                    Padding="18,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="FooterStats"
                               Style="{StaticResource DimText}"
                               VerticalAlignment="Center"
                               Text=""/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Cancel" Click="OnCancel"
                                MinWidth="84" Margin="0,0,8,0"/>
                        <Button x:Name="ImportBtn"
                                Content="Import 0"
                                Click="OnImport"
                                Style="{StaticResource ButtonPrimary}"
                                MinWidth="120"
                                IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
