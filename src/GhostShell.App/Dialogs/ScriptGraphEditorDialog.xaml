  Phase 21 — graph-mode script editor. A Canvas hosts free-positioned
  step nodes connected by bezier edges. Each node has output ports
  (bottom for sequence, "T"/"E" for if-then/else) and an input port
  (top). Drag a port → drop on another node's input port to create an
  edge. Drag the node body to reposition. Save serialises Nodes+Edges
  into the script's NodesJson / EdgesJson columns.
-->
<Window x:Class="GhostShell.App.Dialogs.ScriptGraphEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Graph editor"
        Width="1280" Height="820"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{StaticResource BgBase}"
        KeyDown="OnRootKeyDown">
    <Border BorderBrush="{StaticResource BorderStrong}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- header -->
                <RowDefinition Height="*"/>     <!-- body   -->
                <RowDefinition Height="Auto"/>  <!-- footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                    Padding="20,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="←  Back"
                            Click="OnBack" MinWidth="80" Margin="0,0,16,0"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="TitleText"
                                   Foreground="{StaticResource Text}"
                                   FontSize="14" FontWeight="SemiBold"
                                   Text="Graph editor"/>
                        <TextBlock Style="{StaticResource PageSubtitle}"
                                   Text="Drag nodes to reposition  ·  Drag a port → another port to wire (or use 🔗 Connect tool)  ·  Click an edge to select, Delete to remove  ·  Ctrl+Wheel to zoom"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Phase 22: explicit Connect tool. When
                             checked, clicking a node selects it as
                             the source; clicking another node creates
                             an edge between them. This is the no-drag
                             fallback for users who can't hit the
                             18-px ports reliably. -->
                        <ToggleButton x:Name="ConnectToolToggle"
                                      Content="🔗  Connect tool"
                                      MinWidth="120"
                                      Margin="0,0,8,0"
                                      Padding="12,6"
                                      Checked="OnConnectToolChecked"
                                      Unchecked="OnConnectToolUnchecked"
                                      ToolTip="Click two nodes in turn to wire an edge — no drag needed"/>
                        <Button Content="🔍 Validate"
                                Click="OnValidate"
                                MinWidth="100"
                                Margin="0,0,8,0"
                                ToolTip="Check for orphans, multiple entries, unreachable nodes"/>
                        <Button Content="JSON view"
                                Click="OnJsonView"
                                MinWidth="100"
                                Margin="0,0,8,0"/>
                        <Button x:Name="SaveBtn" Content="💾 Save"
                                Click="OnSave"
                                Style="{StaticResource ButtonPrimary}"
                                MinWidth="120"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body: palette + canvas -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Palette -->
                <Border Grid.Column="0"
                        Background="{StaticResource BgRaised}"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="0,0,1,0">
                    <DockPanel LastChildFill="True">
                        <Border DockPanel.Dock="Top" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="ACTIONS"
                                           Style="{StaticResource CardHeader}"
                                           Margin="0,0,0,8"/>
                                <Border Background="{StaticResource BgDeep}"
                                        BorderBrush="{StaticResource Border}"
                                        BorderThickness="1" CornerRadius="4"
                                        Padding="8,2"
                                        Height="26">
                                    <TextBox x:Name="PaletteFilterField"
                                             TextChanged="OnPaletteFilterChanged"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="0"
                                             FontSize="11.5"
                                             VerticalContentAlignment="Center"
                                             ToolTip="Filter actions"/>
                                </Border>
                                <TextBlock Style="{StaticResource DimText}"
                                           FontSize="10"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Text="Click an action to drop it on the canvas centre. Drag the node body to move it."/>
                            </StackPanel>
                        </Border>
                        <Border DockPanel.Dock="Top" Height="1"
                                Background="{StaticResource Border}"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="PaletteList"
                                          HorizontalContentAlignment="Stretch">
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Tag="{Binding Type}"
                                                MouseLeftButtonUp="OnPaletteItemDrop"
                                                Padding="14,5"
                                                Cursor="Hand"
                                                ToolTip="{Binding Tooltip}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource BgHover}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Icon}"
                                                           FontSize="14"
                                                           Margin="0,0,8,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Label}"
                                                           Foreground="{StaticResource Text}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <!-- Canvas -->
                <Grid Grid.Column="1">
                    <ScrollViewer x:Name="CanvasScroll"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="OnCanvasPreviewMouseWheel"
                                  Background="{StaticResource BgBase}">
                        <!-- Fixed-size canvas; sized large enough for any
                             reasonable graph. Could be made dynamic in a
                             future iteration. -->
                        <Canvas x:Name="GraphCanvas"
                                Width="3000" Height="2000"
                                MouseLeftButtonDown="OnCanvasMouseDown"
                                MouseMove="OnCanvasMouseMove"
                                MouseLeftButtonUp="OnCanvasMouseUp"
                                MouseRightButtonUp="OnCanvasRightUp">
                            <Canvas.LayoutTransform>
                                <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1"/>
                            </Canvas.LayoutTransform>
                            <!-- Background is set as a property element
                                 below so we can attach the dotted-grid
                                 DrawingBrush. The attribute form would
                                 conflict with this. -->
                            <Canvas.Background>
                                <DrawingBrush TileMode="Tile"
                                              Viewport="0,0,40,40"
                                              ViewportUnits="Absolute">
                                    <DrawingBrush.Drawing>
                                        <DrawingGroup>
                                            <GeometryDrawing>
                                                <GeometryDrawing.Brush>
                                                    <SolidColorBrush Color="{StaticResource ColorBgBase}"/>
                                                </GeometryDrawing.Brush>
                                                <GeometryDrawing.Geometry>
                                                    <RectangleGeometry Rect="0,0,40,40"/>
                                                </GeometryDrawing.Geometry>
                                            </GeometryDrawing>
                                            <GeometryDrawing Brush="{StaticResource BorderStrong}">
                                                <GeometryDrawing.Geometry>
                                                    <EllipseGeometry Center="20,20" RadiusX="1" RadiusY="1"/>
                                                </GeometryDrawing.Geometry>
                                            </GeometryDrawing>
                                        </DrawingGroup>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Canvas.Background>
                            <!-- Edges layer (drawn first, sits behind nodes).
                                 Filled programmatically. -->
                            <Canvas x:Name="EdgesLayer"
                                    Width="3000" Height="2000"
                                    IsHitTestVisible="True"/>
                            <!-- Nodes layer. Children added at runtime. -->
                            <Canvas x:Name="NodesLayer"
                                    Width="3000" Height="2000"
                                    IsHitTestVisible="True"/>
                            <!-- Rubber-band line shown while user drags
                                 from a port. Phase 22: brighter +
                                 thicker so it's obvious against the
                                 dark grid. Drop-shadow gives a glow
                                 halo. -->
                            <Path x:Name="RubberBand"
                                  Stroke="#FFFFD400"
                                  StrokeThickness="3"
                                  StrokeDashArray="6,3"
                                  Visibility="Collapsed"
                                  IsHitTestVisible="False">
                                <Path.Effect>
                                    <DropShadowEffect Color="#FFFFD400"
                                                      BlurRadius="10"
                                                      ShadowDepth="0"
                                                      Opacity="0.85"/>
                                </Path.Effect>
                            </Path>
                        </Canvas>
                    </ScrollViewer>

                    <!-- Empty-state hint when there are no nodes yet. -->
                    <Border x:Name="EmptyHint"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Padding="32,24"
                            Background="{StaticResource BgRaised}"
                            BorderBrush="{StaticResource BorderStrong}"
                            BorderThickness="1"
                            CornerRadius="8"
                            IsHitTestVisible="False">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Empty canvas"
                                       Foreground="{StaticResource Text}"
                                       FontSize="16" FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Style="{StaticResource MutedText}"
                                       Margin="0,8,0,0"
                                       HorizontalAlignment="Center"
                                       Text="1. Click an action in the palette to drop a node&#x0a;2. Drag a port (white dot) to another node — or click 🔗 Connect tool, then click 2 nodes&#x0a;3. Ctrl+Wheel zooms · Delete removes the selected edge"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2"
                    Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="0,1,0,0"
                    Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource MutedText}"
                               x:Name="StatusText"
                               VerticalAlignment="Center"
                               Text="0 nodes · 0 edges"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Cancel" Click="OnCancel"
                                MinWidth="84" Margin="0,0,8,0"/>
                        <Button Content="Save" Click="OnSave"
                                Style="{StaticResource ButtonPrimary}" MinWidth="120"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
