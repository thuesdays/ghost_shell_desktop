<Window x:Class="GhostShell.App.Dialogs.ScriptStepParamsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Step params"
        Width="640" Height="460"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{StaticResource BgBase}">
    <Border BorderBrush="{StaticResource BorderStrong}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                    Padding="18,14">
                <StackPanel>
                    <TextBlock x:Name="TitleText" Text="Edit step params"
                               Foreground="{StaticResource Text}"
                               FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Foreground="{StaticResource TextMuted}"
                               FontSize="11" Margin="0,2,0,0"
                               Text="JSON object. Per-action typed forms land in Phase 14."/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Margin="18,12,18,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource MutedText}" FontSize="11"
                           Text="Edit the params JSON below. Save validates that it's a JSON object."/>
                <TextBlock Grid.Column="1" x:Name="ValidationStatus"
                           FontFamily="{StaticResource FontMono}"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource OkBrush}"
                           Text="✓ valid"/>
            </Grid>

            <Border Grid.Row="2" Margin="18,4,18,8"
                    Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1" CornerRadius="4">
                <TextBox x:Name="JsonField"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontFamily="{StaticResource FontMono}"
                         FontSize="12"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="10"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="OnJsonChanged"/>
            </Border>

            <Border Grid.Row="3" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                    Padding="18,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Cancel" Click="OnCancel" MinWidth="84" Margin="0,0,8,0"/>
                        <Button x:Name="SaveBtn" Content="OK" Click="OnSave"
                                Style="{StaticResource ButtonPrimary}" MinWidth="120"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
