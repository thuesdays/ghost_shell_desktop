<Window x:Class="GhostShell.App.Dialogs.ScriptStepParamsTypedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Step params"
        Width="700" Height="560"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{StaticResource BgBase}">
    <Border BorderBrush="{StaticResource BorderStrong}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                    Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TitleText" Text="Edit params"
                                   Foreground="{StaticResource Text}"
                                   FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SubText"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <RadioButton x:Name="ViewTyped" Content="Form"
                                     IsChecked="True" Margin="0,0,8,0"
                                     Checked="OnViewSwitch"/>
                        <RadioButton x:Name="ViewJson"  Content="JSON"
                                     Checked="OnViewSwitch"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="18,12,18,4" Padding="0,0,0,4">
                <TextBlock Style="{StaticResource MutedText}" FontSize="11"
                           x:Name="HelpText"
                           TextWrapping="Wrap"
                           Text="Fill in the action's parameters below."/>
            </Border>

            <Grid Grid.Row="2" Margin="18,0,18,8">
                <!-- Form view -->
                <ScrollViewer x:Name="FormScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="FieldsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Label}"
                                                   Style="{StaticResource MutedText}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Hint}"
                                                   Style="{StaticResource DimText}"
                                                   FontSize="10"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ContentControl Grid.Column="1"
                                                    Content="{Binding Editor}"
                                                    VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- JSON view -->
                <Border x:Name="JsonView"
                        Background="{StaticResource BgDeep}"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1" CornerRadius="4"
                        Visibility="Collapsed">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top"
                                   Style="{StaticResource MutedText}"
                                   FontSize="11"
                                   Margin="10,8"
                                   x:Name="JsonStatus"
                                   Text="✓ valid"/>
                        <TextBox x:Name="JsonField"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 FontFamily="{StaticResource FontMono}"
                                 FontSize="12"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="10"
                                 VerticalScrollBarVisibility="Auto"
                                 TextChanged="OnJsonChanged"/>
                    </DockPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                    Padding="18,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Cancel" Click="OnCancel" MinWidth="84" Margin="0,0,8,0"/>
                        <Button x:Name="OkBtn" Content="OK" Click="OnSave"
                                Style="{StaticResource ButtonPrimary}" MinWidth="120"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
