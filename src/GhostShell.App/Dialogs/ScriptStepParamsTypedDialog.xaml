<Window x:Class="GhostShell.App.Dialogs.ScriptStepParamsTypedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Step params"
        Width="760" Height="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{StaticResource BgBase}">
    <Border BorderBrush="{StaticResource BorderStrong}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                    Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TitleText" Text="Edit params"
                                   Foreground="{StaticResource Text}"
                                   FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SubText"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <RadioButton x:Name="ViewTyped" Content="Form"
                                     IsChecked="True" Margin="0,0,8,0"
                                     Checked="OnViewSwitch"/>
                        <RadioButton x:Name="ViewJson"  Content="JSON"
                                     Checked="OnViewSwitch"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="18,12,18,4" Padding="0,0,0,4">
                <TextBlock Style="{StaticResource MutedText}" FontSize="11"
                           x:Name="HelpText"
                           TextWrapping="Wrap"
                           Text="Fill in the action's parameters below."/>
            </Border>

            <Grid Grid.Row="2" Margin="18,0,18,8">
                <!-- Form view. The DockPanel lets the optional CONDITION
                     section dock at the top for if / while_loop, with
                     the regular params form scrolling beneath it. The
                     ScrollViewer itself wraps the entire form so the
                     condition panel scrolls with the params if the
                     dialog is too short to show everything. -->
                <ScrollViewer x:Name="FormScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- ─── Condition panel (if / while_loop only) ───
                             Visibility set in code-behind based on
                             actionType. The kind combo drives the inner
                             ConditionFieldsList — selecting a new kind
                             rebuilds the field set (e.g. picking
                             url_contains shows a "needle" textbox,
                             ad_is_external shows nothing, random shows
                             a "probability" slider, etc.). -->
                        <Border x:Name="ConditionPanel"
                                Visibility="Collapsed"
                                Margin="0,0,0,12"
                                Padding="12,10"
                                CornerRadius="6"
                                Background="{StaticResource BgRaised}"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="CONDITION"
                                           Style="{StaticResource CardHeader}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Margin="0,0,0,2"/>
                                <TextBlock Text="When this evaluates to true the branch fires. Pick a kind, then fill in its parameters."
                                           Style="{StaticResource DimText}"
                                           FontSize="10"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Kind *"
                                                   Style="{StaticResource MutedText}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="condition kind"
                                                   Style="{StaticResource DimText}"
                                                   FontSize="10"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="1"
                                              x:Name="ConditionKindCombo"
                                              SelectionChanged="OnConditionKindChanged"
                                              VerticalAlignment="Center"/>
                                </Grid>
                                <!-- Per-kind sub-fields. Same row template
                                     as the params form below. -->
                                <ItemsControl x:Name="ConditionFieldsList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="180"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Label}"
                                                               Style="{StaticResource MutedText}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Hint}"
                                                               Style="{StaticResource DimText}"
                                                               FontSize="10"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <ContentControl Grid.Column="1"
                                                                Content="{Binding Editor}"
                                                                VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Compound (and/or/not) hint — when kind
                                     is and/or/not the children tree is
                                     too rich for a typed form, so we
                                     point users at JSON view. -->
                                <TextBlock x:Name="CompoundHint"
                                           Visibility="Collapsed"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource WarnBrush}"
                                           FontSize="10"
                                           TextWrapping="Wrap"
                                           Text="Compound conditions (and/or/not) carry a list of child conditions. Flip to JSON view to edit those — the typed form keeps the kind but won't show child editors."/>
                            </StackPanel>
                        </Border>
                        <!-- Phase 70 — universal Probability slider visible
                             at the top of the params form for every action.
                             Bound to ScriptStep.Probability (0..1). The
                             previous design hid this in a separate "Step
                             Flags" dialog which users couldn't find from
                             the params form. Now it's a first-class field
                             every action surfaces — defaults to 100 (always
                             run), drag down to vary stochastic behaviour. -->
                        <Border x:Name="ProbabilityPanel"
                                Margin="0,0,0,12"
                                Padding="12,10"
                                CornerRadius="6"
                                Background="{StaticResource BgRaised}"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="1">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="PROBABILITY"
                                               Style="{StaticResource CardHeader}"
                                               FontSize="10" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" x:Name="ProbabilityLabel"
                                               FontFamily="{StaticResource FontMono}"
                                               FontSize="12"
                                               Foreground="{StaticResource Accent}"
                                               Text="100%"/>
                                </Grid>
                                <TextBlock
                                    Style="{StaticResource DimText}"
                                    FontSize="10"
                                    TextWrapping="Wrap"
                                    Margin="0,2,0,8"
                                    Text="Chance this step runs each time it's reached. 100% always, 0% never. Useful inside loops to vary per-iteration behaviour."/>
                                <Slider x:Name="ProbabilitySlider"
                                        Minimum="0" Maximum="100"
                                        Value="100"
                                        TickFrequency="10"
                                        IsSnapToTickEnabled="False"
                                        TickPlacement="None"
                                        ValueChanged="OnProbabilityChanged"/>
                            </StackPanel>
                        </Border>
                        <!-- Regular params -->
                        <ItemsControl x:Name="FieldsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Label}"
                                                       Style="{StaticResource MutedText}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Hint}"
                                                       Style="{StaticResource DimText}"
                                                       FontSize="10"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ContentControl Grid.Column="1"
                                                        Content="{Binding Editor}"
                                                        VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- JSON view -->
                <Border x:Name="JsonView"
                        Background="{StaticResource BgDeep}"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1" CornerRadius="4"
                        Visibility="Collapsed">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top"
                                   Style="{StaticResource MutedText}"
                                   FontSize="11"
                                   Margin="10,8"
                                   x:Name="JsonStatus"
                                   Text="✓ valid"/>
                        <TextBox x:Name="JsonField"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 FontFamily="{StaticResource FontMono}"
                                 FontSize="12"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="10"
                                 VerticalScrollBarVisibility="Auto"
                                 TextChanged="OnJsonChanged"/>
                    </DockPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                    Padding="18,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Cancel" Click="OnCancel" MinWidth="84" Margin="0,0,8,0"/>
                        <Button x:Name="OkBtn" Content="OK" Click="OnSave"
                                Style="{StaticResource ButtonPrimary}" MinWidth="120"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
