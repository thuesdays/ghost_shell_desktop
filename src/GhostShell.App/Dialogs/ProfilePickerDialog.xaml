<Window x:Class="GhostShell.App.Dialogs.ProfilePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick profiles"
        Width="500" Height="540"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{StaticResource BgBase}">
    <Border BorderBrush="{StaticResource BorderStrong}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                    Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TitleText" Text="Pick profiles"
                                   Foreground="{StaticResource Text}"
                                   FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SubText"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource ChromeButton}"
                            Width="28" Height="28" Click="OnCancel" ToolTip="Close">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE8BB;"/>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="18,12,18,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="FilterField"
                         TextChanged="OnFilterChanged"
                         ToolTip="Filter by profile name"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                    <Button Content="All"  Click="OnSelectAll"  Margin="0,0,4,0"/>
                    <Button Content="None" Click="OnSelectNone"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Margin="18,0,18,12"
                    Background="{StaticResource BgRaised}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="1" CornerRadius="4">
                <ListBox x:Name="ProfileList"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                      Content="{Binding Name}"
                                      Margin="6,2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Row="3" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                    Padding="18,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="CountText"
                               Style="{StaticResource MutedText}"
                               VerticalAlignment="Center"
                               FontSize="11"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Cancel" Click="OnCancel" MinWidth="84" Margin="0,0,8,0"/>
                        <Button x:Name="OkBtn" Content="Apply" Click="OnOk"
                                Style="{StaticResource ButtonPrimary}" MinWidth="120"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
