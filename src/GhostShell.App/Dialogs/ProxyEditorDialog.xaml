<Window x:Class="GhostShell.App.Dialogs.ProxyEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Proxy editor"
        Width="560" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BgBase}">

    <Border BorderBrush="{StaticResource BorderStrong}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ─── Title bar with × close button ─── -->
            <Border Grid.Row="0" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="0,0,0,1"
                    Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleText"
                               Foreground="{StaticResource Text}"
                               FontSize="15" FontWeight="SemiBold"
                               Text="Add proxy"/>
                    <Button Grid.Column="1"
                            Style="{StaticResource ChromeButton}"
                            Width="28" Height="28"
                            Click="OnCancel"
                            ToolTip="Close">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Text="&#xE8BB;"/>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" MaxHeight="600"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="18,16,18,12">

                    <!-- Name -->
                    <TextBlock Style="{StaticResource MutedText}"
                               Text="Name (optional)" Margin="0,0,0,4"/>
                    <TextBox x:Name="NameField" Margin="0,0,0,12"
                             ToolTip="Friendly label, e.g. 'Residential UA-1'"/>

                    <!-- Proxy URL -->
                    <TextBlock Style="{StaticResource MutedText}"
                               Text="Proxy URL *" Margin="0,0,0,4"/>
                    <TextBox x:Name="UrlField"
                             FontFamily="{StaticResource FontMono}"
                             Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource DimText}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"
                               Text="Accepts bare host:port, user:pass@host:port, or full URL with scheme (http://, socks5://)."/>

                    <!-- Rotation toggle -->
                    <CheckBox x:Name="IsRotatingField"
                              Margin="0,0,0,8"
                              Checked="OnRotationToggled"
                              Unchecked="OnRotationToggled"
                              Content="This proxy supports rotation (rotation API)"/>

                    <!-- Rotation fields (collapsed unless checkbox is on) -->
                    <Border x:Name="RotationFields"
                            Visibility="Collapsed"
                            Background="#0A6366F1"
                            BorderBrush="{StaticResource Border}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="12,10"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Style="{StaticResource MutedText}"
                                       Text="Rotation API URL" Margin="0,0,0,4"/>
                            <TextBox x:Name="RotationUrlField"
                                     FontFamily="{StaticResource FontMono}"
                                     Margin="0,0,0,12"
                                     TextChanged="OnRotationUrlChanged"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Style="{StaticResource MutedText}"
                                           Text="Provider" Margin="0,0,0,4"/>
                                <ComboBox Grid.Row="1" Grid.Column="0"
                                          x:Name="ProviderCombo">
                                    <ComboBoxItem Content="generic (no auth)" Tag="none"/>
                                    <ComboBoxItem Content="asocks" Tag="asocks"/>
                                    <ComboBoxItem Content="brightdata" Tag="brightdata"/>
                                    <ComboBoxItem Content="generic with key" Tag="generic"/>
                                </ComboBox>

                                <TextBlock Grid.Row="0" Grid.Column="2"
                                           Style="{StaticResource MutedText}"
                                           Text="API key (optional)" Margin="0,0,0,4"/>
                                <TextBox Grid.Row="1" Grid.Column="2"
                                         x:Name="RotationKeyField"/>
                            </Grid>

                            <!-- Rotate IP now — appears only in Edit mode AND
                                 only when the rotation URL is non-empty.
                                 Visibility is toggled from code-behind. -->
                            <StackPanel x:Name="RotateNowPanel"
                                        Margin="0,12,0,0"
                                        Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <Button Click="OnRotateNow"
                                            Style="{StaticResource ButtonPrimary}"
                                            MinWidth="140"
                                            Padding="12,6">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                       Text="&#xE72C;"
                                                       Margin="0,0,8,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="Rotate IP now"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <TextBlock x:Name="RotateHint"
                                               Style="{StaticResource DimText}"
                                               TextWrapping="Wrap"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               Width="320"
                                               Text="Tests the rotation URL by fetching a new exit IP — handy before you commit a freshly-pasted URL."/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Default proxy -->
                    <CheckBox x:Name="IsDefaultField"
                              Margin="0,0,0,4"
                              Content="Make this the default proxy"/>
                    <TextBlock Style="{StaticResource DimText}"
                               Margin="22,0,0,12"
                               TextWrapping="Wrap"
                               Text="Profiles without an explicit assignment will use this."/>

                    <!-- Notes -->
                    <TextBlock Style="{StaticResource MutedText}"
                               Text="Notes (optional)" Margin="0,0,0,4"/>
                    <TextBox x:Name="NotesField"
                             AcceptsReturn="True"
                             MinHeight="56"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             Margin="0,0,0,12"/>

                    <!-- Auto-test -->
                    <CheckBox x:Name="AutoTestField"
                              IsChecked="True"
                              Content="Test connection after saving"/>

                    <!-- Validation message -->
                    <TextBlock x:Name="ErrorText"
                               Foreground="{StaticResource ErrBrush}"
                               FontSize="11"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>

            <!-- ─── Footer ─── -->
            <Border Grid.Row="2" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="0,1,0,0"
                    Padding="18,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Click="OnCancel"
                            MinWidth="84" Margin="0,0,8,0"/>
                    <Button x:Name="SaveBtn"
                            Content="Save" Click="OnSave"
                            Style="{StaticResource ButtonPrimary}"
                            MinWidth="84"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
