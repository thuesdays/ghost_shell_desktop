<Window x:Class="GhostShell.App.Dialogs.GroupEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Group editor"
        Width="640" Height="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{StaticResource BgBase}">

    <Border BorderBrush="{StaticResource BorderStrong}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <Border Grid.Row="0" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
                    Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TitleText"
                                   Text="✨ Create new group"
                                   Foreground="{StaticResource Text}"
                                   FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"
                                   Text="Tick profiles to include. Same profile can belong to many groups."/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Style="{StaticResource ChromeButton}"
                            Width="28" Height="28"
                            Click="OnCancel" ToolTip="Close">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Text="&#xE8BB;"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Body -->
            <Grid Grid.Row="1" Margin="22,18,22,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Name -->
                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Style="{StaticResource MutedText}" Text="Name *"/>
                    <TextBox x:Name="NameField" Margin="0,4,0,4"/>
                    <TextBlock Style="{StaticResource DimText}"
                               Text="e.g. Facebook — US East, Twitter — launch."/>
                </StackPanel>

                <!-- Description -->
                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                    <TextBlock Style="{StaticResource MutedText}" Text="Description"/>
                    <TextBox x:Name="DescriptionField" Margin="0,4,0,4"/>
                    <TextBlock Style="{StaticResource DimText}"
                               Text="Optional — short note for yourself."/>
                </StackPanel>

                <!-- Max parallel -->
                <StackPanel Grid.Row="2" Margin="0,0,0,12">
                    <TextBlock Style="{StaticResource MutedText}" Text="Max parallel"/>
                    <TextBox x:Name="MaxParallelField" Margin="0,4,0,4"/>
                    <TextBlock Style="{StaticResource DimText}" TextWrapping="Wrap"
                               Text="How many of this group's profiles can run simultaneously. Leave empty to inherit the global setting (overflow profiles stay queued)."/>
                </StackPanel>

                <!-- Members header -->
                <Grid Grid.Row="3" Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource MutedText}">
                        <Run Text="Members  ("/>
                        <Run x:Name="MemberCountText" Text="0"/>
                        <Run Text=" selected)"/>
                    </TextBlock>
                    <TextBox Grid.Column="1" x:Name="ProfileFilterField"
                             Width="200" Height="24"
                             ToolTip="Filter profile list"
                             TextChanged="OnFilterChanged"/>
                </Grid>

                <!-- Members list -->
                <Border Grid.Row="4"
                        Background="{StaticResource BgDeep}"
                        BorderBrush="{StaticResource Border}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <ListBox x:Name="MembersList"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem"
                                   BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          Click="OnMemberToggled">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{StaticResource Text}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Subtitle}"
                                                   Style="{StaticResource DimText}"/>
                                    </StackPanel>
                                </CheckBox>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0"
                    Padding="18,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="StatusText"
                               Style="{StaticResource DimText}"
                               VerticalAlignment="Center"
                               Text=""/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Cancel" Click="OnCancel"
                                MinWidth="84" Margin="0,0,8,0"/>
                        <Button x:Name="SaveBtn"
                                Content="Save"
                                Click="OnSave"
                                Style="{StaticResource ButtonPrimary}"
                                MinWidth="120"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
