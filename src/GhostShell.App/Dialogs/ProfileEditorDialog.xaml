<Window x:Class="GhostShell.App.Dialogs.ProfileEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Profile editor"
        Width="640" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource BgBase}">

    <Border BorderBrush="{StaticResource BorderStrong}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ─── Header with × close ─── -->
            <Border Grid.Row="0" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="0,0,0,1"
                    Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <!-- Title icon: MDL2 sparkle (E1CF). Renders at any
                             font size without the "missing-glyph" rectangle
                             that color-emoji sometimes produces in WPF. -->
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   Foreground="{StaticResource Accent}"
                                   Text="&#xE945;"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock x:Name="TitleText"
                                       Foreground="{StaticResource Text}"
                                       FontSize="16" FontWeight="SemiBold"
                                       Text="Create new profile"/>
                            <TextBlock Foreground="{StaticResource TextMuted}"
                                       FontSize="11" Margin="0,2,0,0"
                                       Text="Browser identity. Stored in the profiles table."/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Style="{StaticResource ChromeButton}"
                            Width="28" Height="28"
                            Click="OnCancel" ToolTip="Close">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   Text="&#xE8BB;"/>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" MaxHeight="640"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="18,18,18,12">

                    <!-- Profile name + 🎲 random -->
                    <TextBlock Style="{StaticResource MutedText}"
                               Text="Profile name *" Margin="0,0,0,4"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="NameField"/>
                        <Button Grid.Column="1" Margin="6,0,0,0"
                                Click="OnRandomName"
                                ToolTip="Generate a random name">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="13"
                                       Text="&#xE72C;"/>
                        </Button>
                    </Grid>
                    <TextBlock Style="{StaticResource DimText}"
                               Margin="0,0,0,14"
                               TextWrapping="Wrap"
                               Text="Unique identifier. Used as folder name and SHA256 seed for fingerprint."/>

                    <!-- Device template -->
                    <TextBlock Style="{StaticResource MutedText}"
                               Text="Device template" Margin="0,0,0,4"/>
                    <ComboBox x:Name="TemplateCombo" Margin="0,0,0,4"
                              SelectedValuePath="Id">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Header}"
                                               Visibility="{Binding HeaderVisibility}"
                                               Foreground="{StaticResource TextMuted}"
                                               FontSize="9.5"
                                               FontWeight="SemiBold"
                                               Margin="0,4,0,2"/>
                                    <TextBlock Text="{Binding Label}"
                                               Foreground="{StaticResource Text}"
                                               FontSize="11.5"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Style="{StaticResource DimText}"
                               Margin="0,0,0,14"
                               TextWrapping="Wrap"
                               Text="Determines the pool of plausible UA / screen / GPU. 'Auto' picks one randomly so each profile looks different."/>

                    <!-- Preferred language -->
                    <TextBlock Style="{StaticResource MutedText}"
                               Text="Preferred language" Margin="0,0,0,4"/>
                    <ComboBox x:Name="LanguageCombo" Margin="0,0,0,14"
                              SelectedValuePath="Tag">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}"
                                           Foreground="{StaticResource Text}"
                                           FontSize="11.5"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Group -->
                    <TextBlock Style="{StaticResource MutedText}"
                               Text="Group (optional)" Margin="0,0,0,4"/>
                    <TextBox x:Name="GroupField" Margin="0,0,0,14"/>

                    <!-- Proxy -->
                    <TextBlock Style="{StaticResource MutedText}"
                               Text="Proxy (optional)" Margin="0,0,0,4"/>
                    <ComboBox x:Name="ProxyCombo" Margin="0,0,0,14"
                              SelectedValuePath="Slug">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}"
                                               Foreground="{StaticResource Text}" FontSize="12"/>
                                    <TextBlock Text="{Binding SubLine}"
                                               Foreground="{StaticResource TextDim}" FontSize="10.5"
                                               Margin="0,1,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Enrich on first run -->
                    <CheckBox x:Name="EnrichField" IsChecked="True"
                              Content="Enrich on first run (history, bookmarks, top sites)"
                              Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource DimText}"
                               Margin="22,0,0,14"
                               TextWrapping="Wrap"
                               Text="Seeds a realistic browsing history. Without this, first visit looks like a brand-new browser — a known fingerprint signal. Recommended."/>

                    <!-- Status / ready -->
                    <CheckBox x:Name="IsReadyField"
                              Content="Mark profile as ready to launch"
                              Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource DimText}"
                               Margin="22,0,0,14"
                               TextWrapping="Wrap"
                               Text="Profile must be ready before it can be launched."/>

                    <!-- Auto-rotate IP on launch -->
                    <CheckBox x:Name="AutoRotateIpField"
                              Content="Auto-rotate IP on launch (if proxy supports it)"
                              Margin="0,0,0,4"
                              ToolTip="Triggers the proxy's rotation URL before each browser start. Only takes effect when the assigned proxy has a rotation URL configured."/>
                    <TextBlock Style="{StaticResource DimText}"
                               Margin="22,0,0,14"
                               TextWrapping="Wrap"
                               Text="When enabled, the runtime hits the proxy rotation URL right before launching the browser, getting a fresh IP for each session."/>

                    <!-- ─── Phase 20: Ad-domain configuration ────────
                         Drives the script runner's per-step domain
                         filters (skip_on_my_domain, skip_on_target,
                         only_on_target, only_on_my_domain) and the
                         four ad-aware condition kinds. Both are
                         comma-separated lists of bare domains.
                         Empty inputs make the filters pass through. -->
                    <TextBlock Style="{StaticResource MutedText}"
                               FontWeight="SemiBold"
                               Margin="0,4,0,4"
                               Text="AD-DOMAIN POLICY"/>

                    <TextBlock Style="{StaticResource MutedText}"
                               Text="My domains (comma-separated)" Margin="0,0,0,4"/>
                    <TextBox x:Name="MyDomainsField"
                             ToolTip="Domains the profile owns (won't self-click ads on these). E.g. example.com, www.example.com, store.example.com"
                             Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource DimText}"
                               FontSize="10"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"
                               Text="Used by skip_on_my_domain / only_on_my_domain step flags + ad_is_mine condition."/>

                    <TextBlock Style="{StaticResource MutedText}"
                               Text="Target domains (comma-separated)" Margin="0,0,0,4"/>
                    <TextBox x:Name="TargetDomainsField"
                             ToolTip="Domains paid traffic should drive to. E.g. partner.example.com, advertiser.com"
                             Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource DimText}"
                               FontSize="10"
                               Margin="0,0,0,14"
                               TextWrapping="Wrap"
                               Text="Used by skip_on_target / only_on_target step flags + ad_is_target / ad_is_competitor / ad_is_external conditions."/>

                    <!-- Notes -->
                    <TextBlock Style="{StaticResource MutedText}"
                               Text="Note (optional)" Margin="0,0,0,4"/>
                    <TextBox x:Name="NoteField"
                             AcceptsReturn="True"
                             MinHeight="56"
                             VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             Margin="0,0,0,4"/>

                    <!-- Validation message -->
                    <TextBlock x:Name="ErrorText"
                               Foreground="{StaticResource ErrBrush}"
                               FontSize="11"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource Border}"
                    BorderThickness="0,1,0,0"
                    Padding="18,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Click="OnCancel"
                            MinWidth="84" Margin="0,0,8,0"/>
                    <Button x:Name="SaveBtn"
                            Content="Save" Click="OnSave"
                            Style="{StaticResource ButtonPrimary}"
                            MinWidth="100"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
