  Phase 71n — reusable busy overlay. Drop on top of any page or panel
  whose load can take a noticeable beat (Profiles list with 500+ rows,
  Groups page hydrating row VMs, etc.). Bind IsActive to the view-model's
  IsBusy flag and the overlay fades in with a translucent + blurred
  backdrop, a spinning ring, and a configurable status caption.

  Drop-in usage:
      <Grid>
          <YourContent .../>
          <local:LoadingOverlay IsActive="{Binding IsBusy}"
                                Caption="Loading profiles…"/>
      </Grid>

  Kept layout-light: when IsActive=False the overlay collapses to
  Hit-test-invisible nothing and adds zero visual cost. When active
  it covers its parent cell, blocks input via IsHitTestVisible=True
  and rotates the ring at 60 FPS via a perpetual storyboard.
-->
<UserControl x:Class="GhostShell.App.Common.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Name="OverlayRoot"
             IsHitTestVisible="{Binding IsActive, ElementName=OverlayRoot}"
             Visibility="{Binding IsActive, ElementName=OverlayRoot,
                                  Converter={StaticResource BoolToVis}}"
             Focusable="False">
    <Grid Background="#80000000">
        <!-- Soft inner card so the spinner + caption sit on a
             subtle disc rather than floating bare on the dim
             backdrop. Border picks up theme colors so the
             overlay matches the rest of the UI in dark/light. -->
        <Border MinWidth="220"
                MaxWidth="320"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{StaticResource BgRaised}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="22,18">
            <StackPanel HorizontalAlignment="Center">
                <!-- Spinner — rotating arc rendered as a Path. The
                     Storyboard targets a RotateTransform on the
                     Path's RenderTransform so the rotation is
                     hardware-accelerated and never blocks the UI
                     thread. RepeatBehavior=Forever keeps it spinning
                     for as long as the overlay is visible. -->
                <Grid Width="36" Height="36" HorizontalAlignment="Center">
                    <Ellipse Width="36" Height="36"
                             Stroke="{StaticResource Border}"
                             StrokeThickness="3"
                             Opacity="0.35"/>
                    <Path Stroke="{StaticResource Accent}"
                          StrokeThickness="3"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          RenderTransformOrigin="0.5,0.5"
                          Data="M 18,2 A 16,16 0 0 1 33.86,15.5">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotation" Angle="0"/>
                        </Path.RenderTransform>
                        <Path.Triggers>
                            <EventTrigger RoutedEvent="Path.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="SpinnerRotation"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360"
                                                         Duration="0:0:0.9"
                                                         RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Path.Triggers>
                    </Path>
                </Grid>

                <!-- Primary caption -->
                <TextBlock Text="{Binding Caption, ElementName=OverlayRoot}"
                           Margin="0,12,0,0"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource Text}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>

                <!-- Secondary caption (optional, e.g. row count). -->
                <TextBlock Text="{Binding Subcaption, ElementName=OverlayRoot}"
                           Margin="0,4,0,0"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource TextDim}"
                           FontSize="11"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Visibility="{Binding HasSubcaption, ElementName=OverlayRoot,
                                                Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
