<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--
        Palette v3 — VSCode Dark+ / PyCharm-feel with Dolphin-style
        blue accent. Tailwind v4 colour names in comments so we can
        cross-reference quickly.

        Design rules:
          • Background hierarchy reads top-down: deepest wells (inputs)
            → page bg → raised cards. ≥10 luminance steps between layers.
          • Borders are deliberately faint — IDE feel comes from
            implied dividers, not heavy lines.
          • Accent is one specific blue (#3B82F6 / blue-500). Reused
            for focus, primary CTAs, and link-style highlights.
          • Semantic colours each have a SOFT variant (~12% alpha) for
            background fills (banners, pills, badges) without losing
            contrast on top.
    -->

    <!-- ─── Surfaces ─── -->
    <Color x:Key="ColorBgBase">#FF0F1117</Color>            <!-- main page bg (zinc-950ish) -->
    <Color x:Key="ColorBgRaised">#FF181B26</Color>          <!-- cards / toolbars -->
    <Color x:Key="ColorBgDeep">#FF0A0C12</Color>            <!-- inputs / table head -->
    <Color x:Key="ColorBgSidebar">#FF131620</Color>         <!-- sidebar -->
    <Color x:Key="ColorBgHover">#1F60A5FA</Color>           <!-- 12% blue-400 -->
    <Color x:Key="ColorBgActive">#3360A5FA</Color>          <!-- 20% blue-400 -->

    <!-- ─── Text ─── -->
    <Color x:Key="ColorText">#FFE4E7EC</Color>              <!-- zinc-200 -->
    <Color x:Key="ColorTextMuted">#FF98A1B3</Color>         <!-- zinc-400 -->
    <Color x:Key="ColorTextDim">#FF5C6473</Color>           <!-- zinc-600 -->

    <!-- ─── Borders ─── -->
    <!-- 12% / 22% indigo-200 — barely-there at rest, visible on hover -->
    <Color x:Key="ColorBorder">#1FA5B4FC</Color>
    <Color x:Key="ColorBorderStrong">#3DA5B4FC</Color>

    <!-- ─── Accent (blue-500, doc-link / primary CTA) ─── -->
    <Color x:Key="ColorAccent">#FF3B82F6</Color>            <!-- blue-500 -->
    <Color x:Key="ColorAccentDim">#FF2563EB</Color>         <!-- blue-600 hover-darker -->
    <Color x:Key="ColorAccentSoft">#263B82F6</Color>        <!-- 15% accent -->

    <!-- ─── Semantic, plus *Soft companions for fills ─── -->
    <Color x:Key="ColorOk">#FF22C55E</Color>                <!-- green-500 -->
    <Color x:Key="ColorOkSoft">#1F22C55E</Color>            <!-- 12% green -->

    <Color x:Key="ColorWarn">#FFF59E0B</Color>              <!-- amber-500 -->
    <Color x:Key="ColorWarnSoft">#1FF59E0B</Color>

    <Color x:Key="ColorErr">#FFEF4444</Color>               <!-- red-500 -->
    <Color x:Key="ColorErrSoft">#1FEF4444</Color>

    <Color x:Key="ColorInfo">#FF38BDF8</Color>              <!-- sky-400 -->
    <Color x:Key="ColorInfoSoft">#1F38BDF8</Color>

    <!-- ─── Brushes ─── -->
    <SolidColorBrush x:Key="BgBase"          Color="{StaticResource ColorBgBase}"/>
    <SolidColorBrush x:Key="BgRaised"        Color="{StaticResource ColorBgRaised}"/>
    <SolidColorBrush x:Key="BgDeep"          Color="{StaticResource ColorBgDeep}"/>
    <SolidColorBrush x:Key="BgSidebar"       Color="{StaticResource ColorBgSidebar}"/>
    <SolidColorBrush x:Key="BgHover"         Color="{StaticResource ColorBgHover}"/>
    <SolidColorBrush x:Key="BgActive"        Color="{StaticResource ColorBgActive}"/>

    <SolidColorBrush x:Key="Text"            Color="{StaticResource ColorText}"/>
    <SolidColorBrush x:Key="TextMuted"       Color="{StaticResource ColorTextMuted}"/>
    <SolidColorBrush x:Key="TextDim"         Color="{StaticResource ColorTextDim}"/>

    <SolidColorBrush x:Key="Border"          Color="{StaticResource ColorBorder}"/>
    <SolidColorBrush x:Key="BorderStrong"    Color="{StaticResource ColorBorderStrong}"/>

    <SolidColorBrush x:Key="Accent"          Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="AccentDim"       Color="{StaticResource ColorAccentDim}"/>
    <SolidColorBrush x:Key="AccentSoft"      Color="{StaticResource ColorAccentSoft}"/>

    <SolidColorBrush x:Key="OkBrush"         Color="{StaticResource ColorOk}"/>
    <SolidColorBrush x:Key="OkSoftBrush"     Color="{StaticResource ColorOkSoft}"/>
    <SolidColorBrush x:Key="WarnBrush"       Color="{StaticResource ColorWarn}"/>
    <SolidColorBrush x:Key="WarnSoftBrush"   Color="{StaticResource ColorWarnSoft}"/>
    <SolidColorBrush x:Key="ErrBrush"        Color="{StaticResource ColorErr}"/>
    <SolidColorBrush x:Key="ErrSoftBrush"    Color="{StaticResource ColorErrSoft}"/>
    <SolidColorBrush x:Key="InfoBrush"       Color="{StaticResource ColorInfo}"/>
    <SolidColorBrush x:Key="InfoSoftBrush"   Color="{StaticResource ColorInfoSoft}"/>

    <!-- ─── Per-page sidebar icon hues ─────────────────────────────
         Each top-level nav item gets a distinct icon tint so the
         sidebar reads as a colour map at a glance. Mirrors the
         legacy web's hue palette (CSS custom properties starting
         with two dashes) but applied to the icons themselves
         rather than only domain tiles.

         Tones picked from Tailwind v4 so they sit comfortably on
         the dark background (Tailwind 400/500 weights — bright
         enough to read, not garish). -->
    <Color x:Key="ColorHueBlue">#FF60A5FA</Color>      <!-- blue-400  : Overview -->
    <Color x:Key="ColorHueGreen">#FF34D399</Color>     <!-- green-400 : Profiles -->
    <Color x:Key="ColorHueOrange">#FFFB923C</Color>    <!-- orange-400: Runs -->
    <Color x:Key="ColorHueTeal">#FF2DD4BF</Color>      <!-- teal-400  : Proxy -->
    <Color x:Key="ColorHueViolet">#FFA78BFA</Color>    <!-- violet-400: Sessions -->
    <Color x:Key="ColorHuePink">#FFF472B6</Color>      <!-- pink-400  : Cookie packs -->
    <Color x:Key="ColorHueAmber">#FFFBBF24</Color>     <!-- amber-400 : Logs -->
    <Color x:Key="ColorHueIndigo">#FF818CF8</Color>    <!-- indigo-400: Groups -->
    <Color x:Key="ColorHueSlate">#FF94A3B8</Color>     <!-- slate-400 : Settings -->

    <SolidColorBrush x:Key="HueBlue"   Color="{StaticResource ColorHueBlue}"/>
    <SolidColorBrush x:Key="HueGreen"  Color="{StaticResource ColorHueGreen}"/>
    <SolidColorBrush x:Key="HueOrange" Color="{StaticResource ColorHueOrange}"/>
    <SolidColorBrush x:Key="HueTeal"   Color="{StaticResource ColorHueTeal}"/>
    <SolidColorBrush x:Key="HueViolet" Color="{StaticResource ColorHueViolet}"/>
    <SolidColorBrush x:Key="HuePink"   Color="{StaticResource ColorHuePink}"/>
    <SolidColorBrush x:Key="HueAmber"  Color="{StaticResource ColorHueAmber}"/>
    <SolidColorBrush x:Key="HueIndigo" Color="{StaticResource ColorHueIndigo}"/>
    <SolidColorBrush x:Key="HueSlate"  Color="{StaticResource ColorHueSlate}"/>

    <!-- ─── Typography ─────────────────────────────────────────────
         FontUi prefers the EMBEDDED Inter variable font (baked
         into the assembly via Assets\Fonts\Inter-Variable.ttf,
         auto-copied from F:\projects\inter_font\ by the
         CopyInterFont MSBuild target). The pack-URI short form
         "/Assets/Fonts/#Inter" resolves to the embedded TTF when
         present.

         Fallback chain — in order:
            1. /Assets/Fonts/#Inter  (embedded; guaranteed look)
            2. Inter                 (OS install if user has it)
            3. Segoe UI Variable Text (Win11 modern UI)
            4. Segoe UI              (Win10 / older Win11)
            5. Arial                 (universal)

         Comma-separated FontFamily lists need every entry to be
         a NAME (no commas inside any one entry). The pack-URI
         short form is comma-free, so it composes cleanly with the
         OS-name fallbacks. The full pack URI form
         (pack://application:,,,/...) WOULD break the list because
         it contains commas; we use the short form deliberately. -->
    <FontFamily x:Key="FontUi">/Assets/Fonts/#Inter, Inter, Segoe UI Variable Text, Segoe UI, Arial</FontFamily>
    <FontFamily x:Key="FontMono">Cascadia Code, Cascadia Mono, Consolas</FontFamily>

    <sys:Double x:Key="FontSizeXs">11</sys:Double>
    <sys:Double x:Key="FontSizeSm">12</sys:Double>
    <sys:Double x:Key="FontSizeMd">13</sys:Double>
    <sys:Double x:Key="FontSizeLg">14</sys:Double>
    <sys:Double x:Key="FontSizeXl">15</sys:Double>
    <sys:Double x:Key="FontSizeTitle">20</sys:Double>

</ResourceDictionary>
