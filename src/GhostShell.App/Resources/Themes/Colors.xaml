  Phase 71aa — palette loader. The actual surface/text/accent/hue
  Color and SolidColorBrush definitions live in:
      • Palette.Dark.xaml   — Variant C "Linear / Vercel"
      • Palette.Light.xaml  — Variant D "Solar"

  At app startup IThemeService inspects the saved theme preference
  and rewrites this dictionary's first MergedDictionaries[].Source
  to point at whichever palette the user picked. By default the
  dark palette loads — so if the user never opens Settings, the
  app looks identical to the pre-theming build.

  Typography (FontUi / FontMono / FontSize*) is theme-independent
  and lives below — bundled with the loader so consumers only need
  to merge Colors.xaml to get both palette and fonts.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <ResourceDictionary.MergedDictionaries>
        <!-- Default = Dark. ThemeService.Apply(theme) at startup
             rewrites this Source if the user picked Light. -->
        <ResourceDictionary Source="Palette.Dark.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ─── Typography (palette-independent) ─────────────────────────
         FontUi prefers the EMBEDDED Inter variable font (baked
         into the assembly via Assets\Fonts\Inter-Variable.ttf,
         auto-copied by the CopyInterFont MSBuild target). The
         pack-URI short form "/Assets/Fonts/#Inter" resolves to
         the embedded TTF when present.

         Fallback chain:
            1. /Assets/Fonts/#Inter     (embedded)
            2. Inter                    (OS install)
            3. Segoe UI Variable Text   (Win11)
            4. Segoe UI                 (Win10)
            5. Arial                    (universal) -->
    <FontFamily x:Key="FontUi">/Assets/Fonts/#Inter, Inter, Segoe UI Variable Text, Segoe UI, Arial</FontFamily>
    <FontFamily x:Key="FontMono">Cascadia Code, Cascadia Mono, Consolas</FontFamily>

    <sys:Double x:Key="FontSizeXs">11</sys:Double>
    <sys:Double x:Key="FontSizeSm">12</sys:Double>
    <sys:Double x:Key="FontSizeMd">13</sys:Double>
    <sys:Double x:Key="FontSizeLg">14</sys:Double>
    <sys:Double x:Key="FontSizeXl">15</sys:Double>
    <sys:Double x:Key="FontSizeTitle">20</sys:Double>

</ResourceDictionary>
