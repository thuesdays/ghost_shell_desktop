<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ════════════════════════════════════════════════════════════
         GLOBAL DEFAULTS — applied implicitly via TargetType
         ════════════════════════════════════════════════════════════ -->

    <Style TargetType="{x:Type Window}">
        <Setter Property="Background" Value="{StaticResource BgBase}"/>
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSizeMd}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
    </Style>

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontUi}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSizeMd}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <!-- IMPORTANT: keyed text styles must explicitly set Foreground.
         WPF does NOT inherit from the implicit (TargetType-only)
         style when an x:Key style is applied — so without these,
         text would render in WPF's framework default (black) and
         disappear on the dark background. -->
    <Style x:Key="MutedText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSizeSm}"/>
    </Style>

    <Style x:Key="DimText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSizeXs}"/>
    </Style>

    <Style x:Key="MonoText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSizeSm}"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         SIDEBAR — group label + nav items
         ════════════════════════════════════════════════════════════ -->

    <Style x:Key="SidebarSectionLabel" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
        <Setter Property="FontSize"   Value="9.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin"     Value="14,16,12,4"/>
    </Style>

    <Style x:Key="SidebarItem" TargetType="{x:Type ToggleButton}">
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="Margin"  Value="6,1"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgActive}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         BUTTONS
         ════════════════════════════════════════════════════════════ -->

    <Style TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{StaticResource BgRaised}"/>
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgActive}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ButtonPrimary" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource Accent}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentDim}"/>
    </Style>

    <Style x:Key="ButtonGhost" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
    </Style>

    <Style x:Key="ButtonDanger" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource ErrBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource ErrBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Window-chrome buttons (min/max/close) — flat, square, slim.
         FontFamily is set on the TextBlock content directly in
         MainWindow.xaml, not here, because ContentPresenter
         inheritance for FontFamily can be flaky depending on how
         the content is provided. -->
    <Style x:Key="ChromeButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ChromeButtonClose" TargetType="{x:Type Button}" BasedOn="{StaticResource ChromeButton}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource ErrBrush}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         CARDS
         ════════════════════════════════════════════════════════════ -->

    <Style x:Key="Card" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{StaticResource BgRaised}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="5"/>
        <Setter Property="Padding" Value="14"/>
    </Style>

    <Style x:Key="CardHeader" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
        <Setter Property="FontSize" Value="9.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="CardValue" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
    </Style>

    <Style x:Key="CardSubvalue" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         PAGE HEADER
         ════════════════════════════════════════════════════════════ -->

    <Style x:Key="PageTitle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeTitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
    </Style>

    <Style x:Key="PageSubtitle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}"/>
        <!-- WarnBrush (amber/yellow) is more legible against the dark
             bg than the previous TextMuted, and ensures the subtitle
             stays visible even if the toolbar buttons sit close to it. -->
        <Setter Property="Foreground" Value="{StaticResource WarnBrush}"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         TABLE / DATAGRID — minimal flat look
         ════════════════════════════════════════════════════════════ -->

    <Style TargetType="{x:Type DataGrid}">
        <Setter Property="Background" Value="{StaticResource BgRaised}"/>
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="RowBackground" Value="Transparent"/>
        <Setter Property="AlternatingRowBackground" Value="Transparent"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Border}"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserDeleteRows" Value="False"/>
        <Setter Property="CanUserResizeRows" Value="False"/>
        <!-- Bumped from 24 → 36 to give the action buttons (28×28 each)
             breathing room and to read better with the +1 font sizes. -->
        <Setter Property="RowHeight" Value="36"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}"/>
        <Setter Property="ColumnHeaderHeight" Value="32"/>
    </Style>

    <Style TargetType="{x:Type DataGridColumnHeader}">
        <Setter Property="Background" Value="{StaticResource BgDeep}"/>
        <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>

    <Style TargetType="{x:Type DataGridCell}">
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type DataGridCell}">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource BgActive}"/>
                <Setter Property="Foreground" Value="{StaticResource Text}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type DataGridRow}">
        <Setter Property="Background" Value="Transparent"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BgHover}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         INPUTS
         ════════════════════════════════════════════════════════════ -->

    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{StaticResource BgDeep}"/>
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Accent}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         SCROLLBAR — overlay-style (VSCode / macOS feel)
         ════════════════════════════════════════════════════════════
         Two layers replace WPF's three-button default chrome:
           • Track   — transparent (no chrome, blends into the page)
           • Thumb   — rounded pill, semi-transparent at rest, grows
                        opacity on hover and drag for affordance
         The track-click PageUp/PageDown shortcut is preserved via
         two invisible RepeatButtons that sandwich the thumb. We do
         NOT show line-up / line-down arrow buttons — they're an
         affordance from physical scroll wheels and aren't needed in
         an app where mouse-wheel and touch are first-class inputs.
         ════════════════════════════════════════════════════════════ -->

    <!-- Invisible repeat-button used for page-click. Has a hit area
         but no painted surface, so the user gets the page-jump
         behaviour without visual noise. -->
    <Style x:Key="ScrollPageButtonStyle" TargetType="{x:Type RepeatButton}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop"          Value="False"/>
        <Setter Property="Focusable"          Value="False"/>
        <Setter Property="Background"         Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- The visible scroll thumb. Margin=2 keeps it visually inset
         inside the 10px track, which reads as an "overlay" rather
         than filling the whole gutter. -->
    <Style x:Key="ScrollThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Cursor"    Value="Arrow"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border x:Name="Bd"
                            Background="#40FFFFFF"
                            CornerRadius="4"
                            Margin="2"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#70FFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#A0FFFFFF"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Vertical bar template (default Orientation=Vertical). -->
    <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Background="{TemplateBinding Background}">
            <Track x:Name="PART_Track"
                   IsDirectionReversed="True"
                   Focusable="False">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                  Style="{StaticResource ScrollPageButtonStyle}"/>
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                  Style="{StaticResource ScrollPageButtonStyle}"/>
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollThumbStyle}" MinHeight="24"/>
                </Track.Thumb>
            </Track>
        </Grid>
    </ControlTemplate>

    <!-- Horizontal bar template (Orientation=Horizontal). Same layout
         but rotated; commands swap to PageLeft / PageRight. -->
    <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="{x:Type ScrollBar}">
        <Grid Background="{TemplateBinding Background}">
            <Track x:Name="PART_Track"
                   Focusable="False">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageLeftCommand"
                                  Style="{StaticResource ScrollPageButtonStyle}"/>
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageRightCommand"
                                  Style="{StaticResource ScrollPageButtonStyle}"/>
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollThumbStyle}" MinWidth="24"/>
                </Track.Thumb>
            </Track>
        </Grid>
    </ControlTemplate>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Background"            Value="Transparent"/>
        <Setter Property="Foreground"            Value="{StaticResource Text}"/>
        <Setter Property="BorderBrush"           Value="Transparent"/>
        <Setter Property="BorderThickness"       Value="0"/>
        <Setter Property="SnapsToDevicePixels"   Value="True"/>
        <!-- Vertical defaults; the horizontal trigger below overrides. -->
        <Setter Property="Width"     Value="10"/>
        <Setter Property="MinWidth"  Value="10"/>
        <Setter Property="Template"  Value="{StaticResource VerticalScrollBarTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width"     Value="Auto"/>
                <Setter Property="MinWidth"  Value="0"/>
                <Setter Property="Height"    Value="10"/>
                <Setter Property="MinHeight" Value="10"/>
                <Setter Property="Template"  Value="{StaticResource HorizontalScrollBarTemplate}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         COMBOBOX — full custom template
         WPF's default ComboBox template ignores Background/Border
         setters because the Aero theme paints its own background
         under our chrome. The only reliable fix is a complete
         ControlTemplate. Three layers:
           • ToggleButton (the visible field) with its own template
             so we control its background, border, and chevron.
           • Selected-content presenter (left side, shows current item).
           • Popup (the dropdown) painted dark with our brushes.
         ════════════════════════════════════════════════════════════ -->

    <ControlTemplate x:Key="ComboBoxToggleButtonTemplate" TargetType="{x:Type ToggleButton}">
        <Border x:Name="Bd"
                Background="{StaticResource BgDeep}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="22"/>
                </Grid.ColumnDefinitions>
                <Path Grid.Column="1"
                      x:Name="Chevron"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Fill="{StaticResource TextMuted}"
                      Data="M 0 0 L 4 4 L 8 0 Z"
                      Stretch="None"/>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="Background" Value="{StaticResource BgDeep}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Template="{StaticResource ComboBoxToggleButtonTemplate}"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen,
                                                  Mode=TwoWay,
                                                  RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press"/>
                        <ContentPresenter x:Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          TextBlock.Foreground="{StaticResource Text}"
                                          TextElement.Foreground="{StaticResource Text}">
                            <!-- Auto-generated TextBlocks inside the
                                 SelectionBoxItem (when DisplayMemberPath
                                 is set) inherit Foreground via the TextBlock
                                 type — TextElement.Foreground alone doesn't
                                 propagate through the ContentPresenter's
                                 visual subtree on .NET 8. Pin both to be
                                 safe. -->
                            <ContentPresenter.Resources>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Foreground"
                                            Value="{StaticResource Text}"/>
                                </Style>
                            </ContentPresenter.Resources>
                        </ContentPresenter>
                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border x:Name="DropDownBorder"
                                    Background="{StaticResource BgRaised}"
                                    BorderBrush="{StaticResource BorderStrong}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Margin="0,2,0,0">
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgActive}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         CHECKBOX — custom 14×14 dark box, indigo when checked
         ════════════════════════════════════════════════════════════ -->

    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="Box"
                                Width="14" Height="14"
                                CornerRadius="3"
                                Background="{StaticResource BgDeep}"
                                BorderBrush="{StaticResource BorderStrong}"
                                BorderThickness="1"
                                VerticalAlignment="Center">
                            <Path x:Name="Tick"
                                  Stroke="White" StrokeThickness="1.5"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 2 7 L 6 11 L 12 4"
                                  Stretch="None"
                                  Visibility="Collapsed"/>
                        </Border>
                        <ContentPresenter Margin="8,0,0,0"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{StaticResource Accent}"/>
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            <Setter TargetName="Tick" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         RADIO BUTTON — circle 16×16, accent dot when checked
         ════════════════════════════════════════════════════════════
         The default WPF radio template renders an 11px circle with a
         pale-grey ring and a tiny dot — barely visible on a dark
         background, easy to miss when checked. We replace it with a
         16×16 outlined circle and a 8×8 accent-coloured fill when
         selected. Centred vertically with the content via the parent
         StackPanel's Background+Center alignment.
         ════════════════════════════════════════════════════════════ -->

    <Style TargetType="{x:Type RadioButton}">
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSizeSm}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor"     Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RadioButton}">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <!-- Outer ring -->
                        <Grid Width="16" Height="16" VerticalAlignment="Center">
                            <Ellipse x:Name="OuterRing"
                                     Stroke="{StaticResource BorderStrong}"
                                     StrokeThickness="1.5"
                                     Fill="{StaticResource BgDeep}"/>
                            <!-- Inner accent dot (visible when checked) -->
                            <Ellipse x:Name="InnerDot"
                                     Width="8" Height="8"
                                     Fill="{StaticResource Accent}"
                                     Visibility="Collapsed"/>
                        </Grid>
                        <ContentPresenter Margin="8,0,0,0"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="OuterRing" Property="Stroke"
                                    Value="{StaticResource Accent}"/>
                            <Setter TargetName="InnerDot"  Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterRing" Property="Stroke"
                                    Value="{StaticResource Accent}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{StaticResource TextDim}"/>
                            <Setter TargetName="OuterRing" Property="Stroke"
                                    Value="{StaticResource Border}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         CONTEXT MENU + MENU ITEM — dark, flat, dense
         ════════════════════════════════════════════════════════════ -->

    <!-- WPF default ContextMenu uses an OS Aero popup decorator that
         draws a translucent rectangle around our Border, which on
         dark backgrounds looks like a light halo + shows through to
         whatever's behind. The Template override below replaces the
         decorator with a plain solid Border so the menu is fully
         opaque + dark-themed end-to-end. -->
    <Style TargetType="{x:Type ContextMenu}">
        <Setter Property="Background" Value="{StaticResource BgRaised}"/>
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderStrong}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ItemsPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="HasDropShadow" Value="False"/>
    </Style>

    <Style TargetType="{x:Type MenuItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="3">
                        <ContentPresenter ContentSource="Header"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgActive}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type Separator}">
        <Setter Property="Background" Value="{StaticResource Border}"/>
        <Setter Property="Height" Value="1"/>
        <Setter Property="Margin" Value="6,4"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         INLINE SPINNER
         Tiny rotating arc used for transient busy states (Start
         button → Starting…, dialog "saving…", etc). 14×14 default.
         Built as a templated Control so consumers don't have to
         re-stamp the geometry + storyboard inline. The storyboard
         starts on Loaded and runs forever; container Visibility
         drives the actual stop/start (animation is cheap when
         nobody can see it).
         Usage:
           <Control Style="{StaticResource Spinner}"/>
           <Control Style="{StaticResource Spinner}" Width="20" Height="20"/>
         Foreground swaps colour without touching the template.
         ════════════════════════════════════════════════════════════ -->

    <Style x:Key="Spinner" TargetType="{x:Type Control}">
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource Accent}"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Control}">
                    <Grid RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <RotateTransform x:Name="Rot" Angle="0"/>
                        </Grid.RenderTransform>

                        <!-- Faint backing ring for context — keeps the
                             spinner visible against any background even
                             when the active arc is mid-rotation. -->
                        <Ellipse Stroke="{TemplateBinding Foreground}"
                                 StrokeThickness="1.5"
                                 Opacity="0.18"/>

                        <!-- Active arc — ~270° of the circle (top → right
                             → bottom → left). IsLargeArc="True" forces
                             the long clockwise path so the only break
                             in the ring is the top-to-left quadrant.
                             That gives the standard "circular spinner"
                             silhouette. -->
                        <Path Stroke="{TemplateBinding Foreground}"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="7,1">
                                        <ArcSegment Point="1,7"
                                                    Size="6,6"
                                                    SweepDirection="Clockwise"
                                                    IsLargeArc="True"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                        </Path>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="Rot"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360"
                                                     Duration="0:0:0.9"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         ROW-ACTION ICON BUTTONS (small, transparent, hover-tinted).
         Used in DataGrid action columns where we need a 22x22 icon
         button (✎ edit, 🗑 delete, ✕ remove). Defining the style
         here means rows stay tidy without per-cell template noise.
         ════════════════════════════════════════════════════════════ -->

    <Style x:Key="RowActionButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Cursor" Value="Hand"/>
        <!-- HorizontalContentAlignment="Center" + VerticalContentAlignment="Center"
             pass through to the ContentPresenter so any TextBlock content
             centers reliably regardless of its line-height padding. -->
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.FontSize="{TemplateBinding FontSize}"
                                          TextOptions.TextFormattingMode="Display"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHover}"/>
                            <Setter Property="Foreground" Value="{StaticResource Text}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RowActionDanger" TargetType="{x:Type Button}"
           BasedOn="{StaticResource RowActionButton}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource ErrBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Dedicated style for the MDL2/Fluent icon TextBlock that lives
         inside a RowActionButton. Pinning text alignment and rendering
         hints here means we don't repeat them in every page XAML. -->
    <Style x:Key="RowActionIcon" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         INFO BANNERS
         Inline rectangles used for inline notices / call-outs (the
         "Protect your account with 2FA" banner pattern from Dolphin).
         Each variant pairs a tinted background + matching left
         accent strip + matching icon colour.
         Usage: wrap your message in a <Border Style="..."> with two
         children — a small icon TextBlock + a text-block stack.
         Variants:
           InfoBannerInfo / Success / Warn / Error
         ════════════════════════════════════════════════════════════ -->

    <Style x:Key="InfoBannerBase" TargetType="{x:Type Border}">
        <Setter Property="Padding" Value="14,12"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="BorderThickness" Value="1,1,1,1"/>
        <Setter Property="MinHeight" Value="44"/>
    </Style>

    <Style x:Key="InfoBannerInfo" TargetType="{x:Type Border}" BasedOn="{StaticResource InfoBannerBase}">
        <Setter Property="Background"  Value="{StaticResource InfoSoftBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource InfoBrush}"/>
    </Style>
    <Style x:Key="InfoBannerSuccess" TargetType="{x:Type Border}" BasedOn="{StaticResource InfoBannerBase}">
        <Setter Property="Background"  Value="{StaticResource OkSoftBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OkBrush}"/>
    </Style>
    <Style x:Key="InfoBannerWarn" TargetType="{x:Type Border}" BasedOn="{StaticResource InfoBannerBase}">
        <Setter Property="Background"  Value="{StaticResource WarnSoftBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WarnBrush}"/>
    </Style>
    <Style x:Key="InfoBannerError" TargetType="{x:Type Border}" BasedOn="{StaticResource InfoBannerBase}">
        <Setter Property="Background"  Value="{StaticResource ErrSoftBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ErrBrush}"/>
    </Style>
    <Style x:Key="InfoBannerAccent" TargetType="{x:Type Border}" BasedOn="{StaticResource InfoBannerBase}">
        <Setter Property="Background"  Value="{StaticResource AccentSoft}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
    </Style>

    <Style x:Key="InfoBannerTitle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource Text}"/>
    </Style>

    <Style x:Key="InfoBannerBody" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}"/>
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         PILLS / BADGES
         Compact status indicators ("NEW", "ACTIVE", "FAILED"). Two
         variants per colour: Soft (filled background, used for
         neutral table cells) and Outline (transparent bg + colored
         border, used for emphatic states like "BURNED").
         ════════════════════════════════════════════════════════════ -->

    <Style x:Key="PillBase" TargetType="{x:Type Border}">
        <Setter Property="Padding" Value="8,2"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="MinHeight" Value="20"/>
    </Style>

    <Style x:Key="PillNeutral" TargetType="{x:Type Border}" BasedOn="{StaticResource PillBase}">
        <Setter Property="Background"  Value="{StaticResource BgRaised}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
    </Style>
    <Style x:Key="PillOk" TargetType="{x:Type Border}" BasedOn="{StaticResource PillBase}">
        <Setter Property="Background"  Value="{StaticResource OkSoftBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource OkBrush}"/>
    </Style>
    <Style x:Key="PillWarn" TargetType="{x:Type Border}" BasedOn="{StaticResource PillBase}">
        <Setter Property="Background"  Value="{StaticResource WarnSoftBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource WarnBrush}"/>
    </Style>
    <Style x:Key="PillErr" TargetType="{x:Type Border}" BasedOn="{StaticResource PillBase}">
        <Setter Property="Background"  Value="{StaticResource ErrSoftBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ErrBrush}"/>
    </Style>
    <Style x:Key="PillInfo" TargetType="{x:Type Border}" BasedOn="{StaticResource PillBase}">
        <Setter Property="Background"  Value="{StaticResource InfoSoftBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource InfoBrush}"/>
    </Style>
    <Style x:Key="PillAccent" TargetType="{x:Type Border}" BasedOn="{StaticResource PillBase}">
        <Setter Property="Background"  Value="{StaticResource AccentSoft}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
    </Style>

    <Style x:Key="PillText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontSize" Value="10.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         TABS — flat dark, underline-on-active style.
         WPF's default TabControl ships with a 90s-Aero chrome (light
         border, raised inactive tabs, white interior). The implicit
         styles below replace it with a flat IDE look: each tab is a
         transparent strip, the active tab carries an accent underline,
         the body has zero border. NO white surfaces anywhere.
         ════════════════════════════════════════════════════════════ -->

    <Style TargetType="{x:Type TabControl}">
        <Setter Property="Background"   Value="Transparent"/>
        <Setter Property="BorderBrush"  Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"      Value="0"/>
        <Setter Property="Foreground"   Value="{StaticResource Text}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <Grid ClipToBounds="True"
                          KeyboardNavigation.TabNavigation="Local">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Tab strip + thin divider line beneath -->
                        <Border Grid.Row="0"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="0,0,0,1">
                            <TabPanel x:Name="HeaderPanel"
                                      Panel.ZIndex="1"
                                      IsItemsHost="True"
                                      Background="Transparent"
                                      Margin="0,0,0,0"/>
                        </Border>

                        <!-- Body — no border, no chrome. The tab content
                             provides its own card backgrounds.
                             ContentPresenter has no Background prop;
                             since we wrap nothing around it the
                             surface stays transparent against the
                             page bg by default. -->
                        <ContentPresenter x:Name="PART_SelectedContentHost"
                                          Grid.Row="1"
                                          ContentSource="SelectedContent"
                                          Margin="0"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type TabItem}">
        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Margin"  Value="0,0,4,0"/>
        <Setter Property="Cursor"  Value="Hand"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="2"/>
                        </Grid.RowDefinitions>
                        <Border x:Name="Bd"
                                Grid.Row="0"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter x:Name="ContentSite"
                                              ContentSource="Header"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <!-- Underline (active-tab marker) — accent
                             colour, full bleed under the header. -->
                        <Border x:Name="Underline"
                                Grid.Row="1"
                                Background="Transparent"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource BgHover}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource Text}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground"
                                    Value="{StaticResource Text}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter TargetName="Underline" Property="Background"
                                    Value="{StaticResource Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         TOOLTIP — dark-theme override

         Default WPF ToolTip uses light-mode chrome (white background,
         barely-readable text on Win11). User reported invisible
         tooltip text on the Runs row "View logs for this run" button.
         A simple set of colour overrides (no Template retemplate)
         flips every `ToolTip="..."` in the app to dark.

         Note: ContextMenu / MenuItem / Separator already have their
         own implicit styles further up in this file (around line
         540) — DO NOT add new styles for those types here, WPF
         throws "Item has already been added" at deferred-content
         load time when the same TargetType has two implicit styles
         in one dictionary.
         ════════════════════════════════════════════════════════════ -->

    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="Background"      Value="{StaticResource BgRaised}"/>
        <Setter Property="Foreground"      Value="{StaticResource Text}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="8,4"/>
        <Setter Property="FontFamily"      Value="{StaticResource FontUi}"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSizeSm}"/>
        <Setter Property="HasDropShadow"   Value="True"/>
    </Style>

    <!-- ════════════════════════════════════════════════════════════
         TOGGLE BUTTON — dark theme override

         Default WPF ToggleButton uses the Aero/Win11 light-mode
         template (white-grey background). The Schedule editor's
         "Active days" Mon..Sun chips and any future toggle pills
         need to read against our dark background. We retemplate
         instead of just overriding colours because the default
         ToggleButton's gradient brushes are baked into its template
         and ignore Background setter changes when IsChecked toggles.

         Three visual states:
           default   — flat raised surface, muted text
           hover     — accent-soft tint
           checked   — accent background, bright text
         ════════════════════════════════════════════════════════════ -->

    <Style TargetType="{x:Type ToggleButton}">
        <Setter Property="Background"      Value="{StaticResource BgDeep}"/>
        <Setter Property="Foreground"      Value="{StaticResource TextMuted}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="10,4"/>
        <Setter Property="MinHeight"       Value="26"/>
        <Setter Property="FontFamily"      Value="{StaticResource FontUi}"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSizeSm}"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment"   Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          TextElement.FontFamily="{TemplateBinding FontFamily}"
                                          TextElement.FontSize="{TemplateBinding FontSize}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource BgHover}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource Text}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource AccentSoft}"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource Accent}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource Text}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
