  Phase 71aa — LIGHT palette ("Solar"). Inverse of the Linear/Vercel
  dark theme: cards are pure white sitting on a near-white canvas
  with a soft gray sidebar. Big delta between BgRaised (#FFFFFF)
  and BgDeep (#F0F0F2) keeps the same "cards lift off" feel as the
  dark theme — just inverted.

  Design rules:
    • Body text near-black for max legibility on white surfaces.
    • Hue palette bumped from tailwind-400 → tailwind-500 since
      the lighter weights wash out on white.
    • Soft (alpha) brushes use 12-15% — same alpha logic, looks
      slightly different on light bg but reads correctly.
    • Accent stays tailwind blue but uses blue-600 for legibility
      against white.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ─── Surfaces ───
         Phase 71ff — second contrast pass. The user reported Cancel
         buttons on dialog footers still reading as invisible after
         71ee bumped Border #E2 → #C5. Two issues:
           (1) Border alone wasn't enough — 1px @ #C5 still anti-
               aliases away on high-DPI screens.
           (2) BgDeep at #DDE2EA was visually too close to BgRaised
               white (8 luma) for default buttons to "lift" off
               their footer.
         Pushed BgDeep darker (slate-300, ~14 luma below white) and
         Border to slate-400 (#94A3B8, ~13 luma darker than before).
         Cards/inputs/buttons on either canvas now have a sharp
         outline. -->
    <Color x:Key="ColorBgBase">#FFEDEFF3</Color>            <!-- canvas (slate-100ish) -->
    <Color x:Key="ColorBgRaised">#FFFFFFFF</Color>          <!-- pure white cards -->
    <Color x:Key="ColorBgDeep">#FFCFD6E0</Color>            <!-- input wells, footers (slate-300) -->
    <Color x:Key="ColorBgSidebar">#FFDFE3EA</Color>         <!-- between Base and Deep -->
    <Color x:Key="ColorBgHover">#1F000000</Color>           <!-- 12% black overlay -->
    <Color x:Key="ColorBgActive">#33000000</Color>          <!-- 20% black overlay -->

    <!-- ─── Text ───
         Phase 71ff — Text body stays near-black for max contrast on
         white surfaces. Muted/Dim tuned to read on both BgRaised
         (white) and BgDeep (slate-300). -->
    <Color x:Key="ColorText">#FF1A1D27</Color>              <!-- near-black body -->
    <Color x:Key="ColorTextMuted">#FF445063</Color>         <!-- slate-700 — clearly readable -->
    <Color x:Key="ColorTextDim">#FF6B7689</Color>           <!-- slate-500/600 -->

    <!-- ─── Borders ───
         Phase 71ff — pushed to slate-400 weight so a 1-px outline
         survives anti-aliasing on a white card and reads as a
         deliberate divider rather than a haze. Default-styled
         buttons (Cancel etc.) now have a clearly outlined edge. -->
    <Color x:Key="ColorBorder">#FF94A3B8</Color>            <!-- slate-400, visible -->
    <Color x:Key="ColorBorderStrong">#FF64748B</Color>      <!-- slate-500, emphasised -->

    <!-- ─── Accent (blue-600 for legibility on white) ─── -->
    <Color x:Key="ColorAccent">#FF2563EB</Color>            <!-- tailwind blue-600 -->
    <Color x:Key="ColorAccentDim">#FF1D4ED8</Color>         <!-- blue-700 hover-darker -->
    <Color x:Key="ColorAccentSoft">#262563EB</Color>        <!-- 15% accent -->

    <!-- ─── Semantic + Soft companions ───
         Use 600 weights so coloured text reads cleanly on white;
         soft fills stay at ~12-15% alpha — works on either bg. -->
    <Color x:Key="ColorOk">#FF16A34A</Color>                <!-- green-600 -->
    <Color x:Key="ColorOkSoft">#1F16A34A</Color>            <!-- 12% green -->
    <Color x:Key="ColorWarn">#FFD97706</Color>              <!-- amber-600 -->
    <Color x:Key="ColorWarnSoft">#1FD97706</Color>
    <Color x:Key="ColorErr">#FFDC2626</Color>               <!-- red-600 -->
    <Color x:Key="ColorErrSoft">#1FDC2626</Color>
    <Color x:Key="ColorInfo">#FF0284C7</Color>              <!-- sky-600 -->
    <Color x:Key="ColorInfoSoft">#1F0284C7</Color>

    <!-- ─── Brushes ─── -->
    <SolidColorBrush x:Key="BgBase"          Color="{StaticResource ColorBgBase}"/>
    <SolidColorBrush x:Key="BgRaised"        Color="{StaticResource ColorBgRaised}"/>
    <SolidColorBrush x:Key="BgDeep"          Color="{StaticResource ColorBgDeep}"/>
    <SolidColorBrush x:Key="BgSidebar"       Color="{StaticResource ColorBgSidebar}"/>
    <SolidColorBrush x:Key="BgHover"         Color="{StaticResource ColorBgHover}"/>
    <SolidColorBrush x:Key="BgActive"        Color="{StaticResource ColorBgActive}"/>

    <SolidColorBrush x:Key="Text"            Color="{StaticResource ColorText}"/>
    <SolidColorBrush x:Key="TextMuted"       Color="{StaticResource ColorTextMuted}"/>
    <SolidColorBrush x:Key="TextDim"         Color="{StaticResource ColorTextDim}"/>

    <SolidColorBrush x:Key="Border"          Color="{StaticResource ColorBorder}"/>
    <SolidColorBrush x:Key="BorderStrong"    Color="{StaticResource ColorBorderStrong}"/>

    <SolidColorBrush x:Key="Accent"          Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="AccentDim"       Color="{StaticResource ColorAccentDim}"/>
    <SolidColorBrush x:Key="AccentSoft"      Color="{StaticResource ColorAccentSoft}"/>

    <SolidColorBrush x:Key="OkBrush"         Color="{StaticResource ColorOk}"/>
    <SolidColorBrush x:Key="OkSoftBrush"     Color="{StaticResource ColorOkSoft}"/>
    <SolidColorBrush x:Key="WarnBrush"       Color="{StaticResource ColorWarn}"/>
    <SolidColorBrush x:Key="WarnSoftBrush"   Color="{StaticResource ColorWarnSoft}"/>
    <SolidColorBrush x:Key="ErrBrush"        Color="{StaticResource ColorErr}"/>
    <SolidColorBrush x:Key="ErrSoftBrush"    Color="{StaticResource ColorErrSoft}"/>
    <SolidColorBrush x:Key="InfoBrush"       Color="{StaticResource ColorInfo}"/>
    <SolidColorBrush x:Key="InfoSoftBrush"   Color="{StaticResource ColorInfoSoft}"/>

    <!-- ─── Per-page sidebar icon hues (tailwind 500 — punchier on white) ─── -->
    <Color x:Key="ColorHueBlue">#FF3B82F6</Color>      <!-- blue-500  -->
    <Color x:Key="ColorHueGreen">#FF22C55E</Color>     <!-- green-500 -->
    <Color x:Key="ColorHueOrange">#FFF97316</Color>    <!-- orange-500-->
    <Color x:Key="ColorHueTeal">#FF14B8A6</Color>      <!-- teal-500  -->
    <Color x:Key="ColorHueViolet">#FF8B5CF6</Color>    <!-- violet-500-->
    <Color x:Key="ColorHuePink">#FFEC4899</Color>      <!-- pink-500  -->
    <Color x:Key="ColorHueAmber">#FFF59E0B</Color>     <!-- amber-500 -->
    <Color x:Key="ColorHueIndigo">#FF6366F1</Color>    <!-- indigo-500-->
    <Color x:Key="ColorHueSlate">#FF64748B</Color>     <!-- slate-500 -->

    <SolidColorBrush x:Key="HueBlue"   Color="{StaticResource ColorHueBlue}"/>
    <SolidColorBrush x:Key="HueGreen"  Color="{StaticResource ColorHueGreen}"/>
    <SolidColorBrush x:Key="HueOrange" Color="{StaticResource ColorHueOrange}"/>
    <SolidColorBrush x:Key="HueTeal"   Color="{StaticResource ColorHueTeal}"/>
    <SolidColorBrush x:Key="HueViolet" Color="{StaticResource ColorHueViolet}"/>
    <SolidColorBrush x:Key="HuePink"   Color="{StaticResource ColorHuePink}"/>
    <SolidColorBrush x:Key="HueAmber"  Color="{StaticResource ColorHueAmber}"/>
    <SolidColorBrush x:Key="HueIndigo" Color="{StaticResource ColorHueIndigo}"/>
    <SolidColorBrush x:Key="HueSlate"  Color="{StaticResource ColorHueSlate}"/>

    <!-- ─── Hue *Soft (~8% alpha — tinted bg fills) ─── -->
    <Color x:Key="ColorHueBlueSoft">#143B82F6</Color>
    <Color x:Key="ColorHueGreenSoft">#1422C55E</Color>
    <Color x:Key="ColorHueOrangeSoft">#14F97316</Color>
    <Color x:Key="ColorHueTealSoft">#1414B8A6</Color>
    <Color x:Key="ColorHueVioletSoft">#148B5CF6</Color>
    <Color x:Key="ColorHuePinkSoft">#14EC4899</Color>
    <Color x:Key="ColorHueAmberSoft">#14F59E0B</Color>
    <Color x:Key="ColorHueIndigoSoft">#146366F1</Color>

    <SolidColorBrush x:Key="HueBlueSoft"   Color="{StaticResource ColorHueBlueSoft}"/>
    <SolidColorBrush x:Key="HueGreenSoft"  Color="{StaticResource ColorHueGreenSoft}"/>
    <SolidColorBrush x:Key="HueOrangeSoft" Color="{StaticResource ColorHueOrangeSoft}"/>
    <SolidColorBrush x:Key="HueTealSoft"   Color="{StaticResource ColorHueTealSoft}"/>
    <SolidColorBrush x:Key="HueVioletSoft" Color="{StaticResource ColorHueVioletSoft}"/>
    <SolidColorBrush x:Key="HuePinkSoft"   Color="{StaticResource ColorHuePinkSoft}"/>
    <SolidColorBrush x:Key="HueAmberSoft"  Color="{StaticResource ColorHueAmberSoft}"/>
    <SolidColorBrush x:Key="HueIndigoSoft" Color="{StaticResource ColorHueIndigoSoft}"/>

</ResourceDictionary>
