  Phase 71aa — DARK palette. This file owns ONLY the surface +
  text + accent + hue colours. Typography lives in Colors.xaml
  (palette-independent). The active palette is selected at app
  startup by IThemeService — it edits the inner MergedDictionaries
  source on Colors.xaml so all StaticResource references inside
  the rest of the theme resolve against whichever palette is
  active at parse time.

  Dark = Variant C "Linear / Vercel". High-contrast inkblot dark.
  Big delta between BgBase (near-black) and BgRaised so cards
  literally lift off the page rather than blending in.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ─── Surfaces ─── -->
    <Color x:Key="ColorBgBase">#FF0A0A0B</Color>            <!-- near-black canvas -->
    <Color x:Key="ColorBgRaised">#FF1F1F22</Color>          <!-- cards LIFTED — big delta -->
    <Color x:Key="ColorBgDeep">#FF050507</Color>            <!-- input wells, near pitch -->
    <Color x:Key="ColorBgSidebar">#FF131316</Color>         <!-- between Base and Raised -->
    <Color x:Key="ColorBgHover">#1FFFFFFF</Color>           <!-- 12% white overlay -->
    <Color x:Key="ColorBgActive">#33FFFFFF</Color>          <!-- 20% white overlay -->

    <!-- ─── Text ─── -->
    <Color x:Key="ColorText">#FFFAFAFA</Color>              <!-- bright off-white -->
    <Color x:Key="ColorTextMuted">#FFA0A0AB</Color>         <!-- neutral muted -->
    <Color x:Key="ColorTextDim">#FF606069</Color>           <!-- neutral dim -->

    <!-- ─── Borders ─── -->
    <Color x:Key="ColorBorder">#FF2A2A2F</Color>            <!-- crisp neutral divider -->
    <Color x:Key="ColorBorderStrong">#FF3F3F46</Color>      <!-- emphasised on hover -->

    <!-- ─── Accent ─── -->
    <Color x:Key="ColorAccent">#FF3B82F6</Color>            <!-- tailwind blue-500 -->
    <Color x:Key="ColorAccentDim">#FF2563EB</Color>         <!-- blue-600 hover-darker -->
    <Color x:Key="ColorAccentSoft">#263B82F6</Color>        <!-- 15% accent -->

    <!-- ─── Semantic + Soft companions ─── -->
    <Color x:Key="ColorOk">#FF22C55E</Color>                <!-- green-500 -->
    <Color x:Key="ColorOkSoft">#1F22C55E</Color>            <!-- 12% green -->
    <Color x:Key="ColorWarn">#FFF59E0B</Color>              <!-- amber-500 -->
    <Color x:Key="ColorWarnSoft">#1FF59E0B</Color>
    <Color x:Key="ColorErr">#FFEF4444</Color>               <!-- red-500 -->
    <Color x:Key="ColorErrSoft">#1FEF4444</Color>
    <Color x:Key="ColorInfo">#FF38BDF8</Color>              <!-- sky-400 -->
    <Color x:Key="ColorInfoSoft">#1F38BDF8</Color>

    <!-- ─── Brushes (surface/text/border/accent/semantic) ─── -->
    <SolidColorBrush x:Key="BgBase"          Color="{StaticResource ColorBgBase}"/>
    <SolidColorBrush x:Key="BgRaised"        Color="{StaticResource ColorBgRaised}"/>
    <SolidColorBrush x:Key="BgDeep"          Color="{StaticResource ColorBgDeep}"/>
    <SolidColorBrush x:Key="BgSidebar"       Color="{StaticResource ColorBgSidebar}"/>
    <SolidColorBrush x:Key="BgHover"         Color="{StaticResource ColorBgHover}"/>
    <SolidColorBrush x:Key="BgActive"        Color="{StaticResource ColorBgActive}"/>

    <SolidColorBrush x:Key="Text"            Color="{StaticResource ColorText}"/>
    <SolidColorBrush x:Key="TextMuted"       Color="{StaticResource ColorTextMuted}"/>
    <SolidColorBrush x:Key="TextDim"         Color="{StaticResource ColorTextDim}"/>

    <SolidColorBrush x:Key="Border"          Color="{StaticResource ColorBorder}"/>
    <SolidColorBrush x:Key="BorderStrong"    Color="{StaticResource ColorBorderStrong}"/>

    <SolidColorBrush x:Key="Accent"          Color="{StaticResource ColorAccent}"/>
    <SolidColorBrush x:Key="AccentDim"       Color="{StaticResource ColorAccentDim}"/>
    <SolidColorBrush x:Key="AccentSoft"      Color="{StaticResource ColorAccentSoft}"/>

    <SolidColorBrush x:Key="OkBrush"         Color="{StaticResource ColorOk}"/>
    <SolidColorBrush x:Key="OkSoftBrush"     Color="{StaticResource ColorOkSoft}"/>
    <SolidColorBrush x:Key="WarnBrush"       Color="{StaticResource ColorWarn}"/>
    <SolidColorBrush x:Key="WarnSoftBrush"   Color="{StaticResource ColorWarnSoft}"/>
    <SolidColorBrush x:Key="ErrBrush"        Color="{StaticResource ColorErr}"/>
    <SolidColorBrush x:Key="ErrSoftBrush"    Color="{StaticResource ColorErrSoft}"/>
    <SolidColorBrush x:Key="InfoBrush"       Color="{StaticResource ColorInfo}"/>
    <SolidColorBrush x:Key="InfoSoftBrush"   Color="{StaticResource ColorInfoSoft}"/>

    <!-- ─── Per-page sidebar icon hues (Tailwind v4 400 weights) ─── -->
    <Color x:Key="ColorHueBlue">#FF60A5FA</Color>      <!-- blue-400  -->
    <Color x:Key="ColorHueGreen">#FF34D399</Color>     <!-- green-400 -->
    <Color x:Key="ColorHueOrange">#FFFB923C</Color>    <!-- orange-400-->
    <Color x:Key="ColorHueTeal">#FF2DD4BF</Color>      <!-- teal-400  -->
    <Color x:Key="ColorHueViolet">#FFA78BFA</Color>    <!-- violet-400-->
    <Color x:Key="ColorHuePink">#FFF472B6</Color>      <!-- pink-400  -->
    <Color x:Key="ColorHueAmber">#FFFBBF24</Color>     <!-- amber-400 -->
    <Color x:Key="ColorHueIndigo">#FF818CF8</Color>    <!-- indigo-400-->
    <Color x:Key="ColorHueSlate">#FF94A3B8</Color>     <!-- slate-400 -->

    <SolidColorBrush x:Key="HueBlue"   Color="{StaticResource ColorHueBlue}"/>
    <SolidColorBrush x:Key="HueGreen"  Color="{StaticResource ColorHueGreen}"/>
    <SolidColorBrush x:Key="HueOrange" Color="{StaticResource ColorHueOrange}"/>
    <SolidColorBrush x:Key="HueTeal"   Color="{StaticResource ColorHueTeal}"/>
    <SolidColorBrush x:Key="HueViolet" Color="{StaticResource ColorHueViolet}"/>
    <SolidColorBrush x:Key="HuePink"   Color="{StaticResource ColorHuePink}"/>
    <SolidColorBrush x:Key="HueAmber"  Color="{StaticResource ColorHueAmber}"/>
    <SolidColorBrush x:Key="HueIndigo" Color="{StaticResource ColorHueIndigo}"/>
    <SolidColorBrush x:Key="HueSlate"  Color="{StaticResource ColorHueSlate}"/>

    <!-- ─── Hue *Soft (~8% alpha) for tile backgrounds ─── -->
    <Color x:Key="ColorHueBlueSoft">#1460A5FA</Color>
    <Color x:Key="ColorHueGreenSoft">#1434D399</Color>
    <Color x:Key="ColorHueOrangeSoft">#14FB923C</Color>
    <Color x:Key="ColorHueTealSoft">#142DD4BF</Color>
    <Color x:Key="ColorHueVioletSoft">#14A78BFA</Color>
    <Color x:Key="ColorHuePinkSoft">#14F472B6</Color>
    <Color x:Key="ColorHueAmberSoft">#14FBBF24</Color>
    <Color x:Key="ColorHueIndigoSoft">#14818CF8</Color>

    <SolidColorBrush x:Key="HueBlueSoft"   Color="{StaticResource ColorHueBlueSoft}"/>
    <SolidColorBrush x:Key="HueGreenSoft"  Color="{StaticResource ColorHueGreenSoft}"/>
    <SolidColorBrush x:Key="HueOrangeSoft" Color="{StaticResource ColorHueOrangeSoft}"/>
    <SolidColorBrush x:Key="HueTealSoft"   Color="{StaticResource ColorHueTealSoft}"/>
    <SolidColorBrush x:Key="HueVioletSoft" Color="{StaticResource ColorHueVioletSoft}"/>
    <SolidColorBrush x:Key="HuePinkSoft"   Color="{StaticResource ColorHuePinkSoft}"/>
    <SolidColorBrush x:Key="HueAmberSoft"  Color="{StaticResource ColorHueAmberSoft}"/>
    <SolidColorBrush x:Key="HueIndigoSoft" Color="{StaticResource ColorHueIndigoSoft}"/>

</ResourceDictionary>
